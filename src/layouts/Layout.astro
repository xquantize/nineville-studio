---
import '../styles/global.css';
import { site, absoluteUrl } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.title,
  description = site.description,
  ogImage = site.ogImage,
} = Astro.props;

const canonicalUrl = absoluteUrl('/');
const ogImageUrl = absoluteUrl(ogImage);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        if (sessionStorage.getItem('seen-intro') === '1') {
          document.documentElement.classList.add('skip-intro');
        }
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('skip-intro');
        }

        /* Real viewport height — fixes mobile gap when URL bar shows/hides */
        function setAppSize() {
          document.documentElement.style.setProperty('--app-height', window.innerHeight + 'px');
          document.documentElement.style.setProperty('--app-width', window.innerWidth + 'px');
        }
        setAppSize();
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
        window.addEventListener('resize', setAppSize);
        window.addEventListener('orientationchange', function () {
          setTimeout(setAppSize, 150);
        });
      })();
    </script>
    <link
      rel="preload"
      as="image"
      href="/images/background-mobile.webp"
      type="image/webp"
      media="(max-width: 767px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="/images/background.webp"
      type="image/webp"
      media="(min-width: 768px)"
      fetchpriority="high"
    />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;1,14..32,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        var reveals = document.querySelectorAll('[data-reveal], [data-reveal-fade]');
        if (!reveals.length) return;

        var observerOptions = { threshold: 0.01, rootMargin: '120px 0px -40px 0px' };

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          observerOptions
        );

        reveals.forEach(function (el) {
          observer.observe(el);
        });

        document.querySelectorAll('[data-media-frame]').forEach(function (img) {
          function markLoaded() {
            img.classList.add('is-loaded');
            img.parentElement?.classList.add('is-loaded');
          }

          if (img.complete && img.naturalWidth > 0) {
            markLoaded();
          } else {
            img.addEventListener('load', markLoaded, { once: true });
            img.addEventListener(
              'error',
              function () {
                img.parentElement?.classList.add('is-error');
              },
              { once: true }
            );
          }
        });
      })();
    </script>
  </body>
</html>
