---
import '../styles/global.css';
import { site, absoluteUrl } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.title,
  description = site.description,
  ogImage = site.ogImage,
} = Astro.props;

const canonicalUrl = absoluteUrl('/');
const ogImageUrl = absoluteUrl(ogImage);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        if (sessionStorage.getItem('seen-intro') === '1') {
          document.documentElement.classList.add('skip-intro');
        }
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('skip-intro');
        }

        /* Real viewport height — fixes mobile gap when URL bar shows/hides */
        function setAppSize() {
          document.documentElement.style.setProperty('--app-height', window.innerHeight + 'px');
          document.documentElement.style.setProperty('--app-width', window.innerWidth + 'px');
        }
        setAppSize();
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
        window.addEventListener('resize', setAppSize);
        window.addEventListener('orientationchange', function () {
          setTimeout(setAppSize, 150);
        });
      })();
    </script>
    <link
      rel="preload"
      as="image"
      href="/images/background-mobile.webp"
      type="image/webp"
      media="(max-width: 767px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="/images/background.webp"
      type="image/webp"
      media="(min-width: 768px)"
      fetchpriority="high"
    />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;1,14..32,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function () {
        var reveals = Array.prototype.slice.call(
          document.querySelectorAll('[data-reveal], [data-reveal-fade]')
        );

        // Media frames fade in once their image decodes (runs on all devices).
        document.querySelectorAll('[data-media-frame]').forEach(function (img) {
          function markLoaded() {
            img.classList.add('is-loaded');
            if (img.parentElement) img.parentElement.classList.add('is-loaded');
          }
          if (img.complete && img.naturalWidth > 0) {
            markLoaded();
          } else {
            img.addEventListener('load', markLoaded, { once: true });
            img.addEventListener(
              'error',
              function () {
                if (img.parentElement) img.parentElement.classList.add('is-error');
              },
              { once: true }
            );
          }
        });

        function revealAll() {
          reveals.forEach(function (el) {
            el.classList.add('is-visible');
          });
        }

        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !reveals.length || !('IntersectionObserver' in window)) {
          revealAll();
          return;
        }

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.01, rootMargin: '0px 0px 12% 0px' }
        );

        reveals.forEach(function (el) {
          observer.observe(el);
        });

        // iOS Safari can withhold the first paint of content layered over a
        // fixed background until the user interacts. Briefly promoting <main>
        // to its own layer forces the compositor to repaint its subtree.
        // (The fixed background and nav are siblings of <main>, not children,
        // so this transform can't break their positioning.)
        var mainEl = document.querySelector('main');
        function forceRepaint() {
          if (!mainEl) return;
          mainEl.style.transform = 'translateZ(0)';
          void mainEl.offsetHeight;
          requestAnimationFrame(function () {
            mainEl.style.transform = '';
          });
        }

        // Reveal anything already on screen right away. Without this, the
        // observer's first paint can be delayed until the user scrolls,
        // leaving the landing content invisible on load.
        function revealInView() {
          var vh = window.innerHeight || document.documentElement.clientHeight;
          reveals.forEach(function (el) {
            if (el.classList.contains('is-visible')) return;
            var r = el.getBoundingClientRect();
            if (r.top < vh * 0.98 && r.bottom > 0) {
              el.classList.add('is-visible');
              observer.unobserve(el);
            }
          });
          forceRepaint();
        }

        requestAnimationFrame(function () {
          requestAnimationFrame(revealInView);
        });
        window.addEventListener('load', revealInView);
        window.addEventListener('pageshow', revealInView);
        // Repeat a few times to cover the intro fade-out and late layout.
        [150, 500, 1000, 1800].forEach(function (t) {
          window.setTimeout(revealInView, t);
        });
      })();
    </script>
  </body>
</html>
