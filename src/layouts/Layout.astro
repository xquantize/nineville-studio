---
import '../styles/global.css';
import { site, absoluteUrl } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.title,
  description = site.description,
  ogImage = site.ogImage,
} = Astro.props;

const canonicalUrl = absoluteUrl('/');
const ogImageUrl = absoluteUrl(ogImage);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        var root = document.documentElement;
        // Marks that JS is running so the hero can start hidden and animate in.
        // Without JS (or if anything fails), the hero stays visible by default.
        root.classList.add('js-hero');

        if (sessionStorage.getItem('seen-intro') === '1') {
          root.classList.add('skip-intro');
        }
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          root.classList.add('skip-intro');
        }

        /* Real viewport height for the hero. Only update on WIDTH change
           (orientation) — recalculating on every URL-bar show/hide resized the
           hero and made content jump while scrolling on mobile. */
        var lastW = 0;
        function setAppSize() {
          var w = window.innerWidth;
          if (w === lastW) return;
          lastW = w;
          root.style.setProperty('--app-height', window.innerHeight + 'px');
          root.style.setProperty('--app-width', w + 'px');
        }
        setAppSize();
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
        window.addEventListener('resize', setAppSize);
        window.addEventListener('orientationchange', function () {
          lastW = 0;
          setTimeout(setAppSize, 150);
        });
      })();
    </script>
    <link
      rel="preload"
      as="image"
      href="/images/background-mobile.webp"
      type="image/webp"
      media="(max-width: 767px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="/images/background.webp"
      type="image/webp"
      media="(min-width: 768px)"
      fetchpriority="high"
    />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#141820" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;1,14..32,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function () {
        var root = document.documentElement;

        // Reveal the hero. On iOS, content over a position:fixed background
        // won't repaint from an opacity change alone (only a real touch-scroll
        // triggers it). Toggling display forces a full re-render of the hero
        // subtree, which iOS does honor — so the text appears without a scroll.
        function revealHero() {
          if (root.classList.contains('hero-ready')) return;
          root.classList.add('hero-ready');
          var hero = document.querySelector('.hero');
          if (hero) {
            hero.style.display = 'none';
            void hero.offsetHeight;
            hero.style.display = '';
          }
        }

        if (root.classList.contains('skip-intro')) {
          requestAnimationFrame(function () {
            requestAnimationFrame(revealHero);
          });
        }
        window.addEventListener('intro-fading', revealHero);
        // Failsafe: the hero can never stay hidden.
        window.setTimeout(revealHero, 2600);

        var reveals = Array.prototype.slice.call(
          document.querySelectorAll('[data-reveal], [data-reveal-fade]')
        );

        // Media frames fade in once their image decodes (runs on all devices).
        document.querySelectorAll('[data-media-frame]').forEach(function (img) {
          function markLoaded() {
            img.classList.add('is-loaded');
            if (img.parentElement) img.parentElement.classList.add('is-loaded');
          }
          if (img.complete && img.naturalWidth > 0) {
            markLoaded();
          } else {
            img.addEventListener('load', markLoaded, { once: true });
            img.addEventListener(
              'error',
              function () {
                if (img.parentElement) img.parentElement.classList.add('is-error');
              },
              { once: true }
            );
          }
        });

        function revealAll() {
          reveals.forEach(function (el) {
            el.classList.add('is-visible');
          });
        }

        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !reveals.length || !('IntersectionObserver' in window)) {
          revealAll();
          return;
        }

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.01, rootMargin: '0px 0px 12% 0px' }
        );

        reveals.forEach(function (el) {
          observer.observe(el);
        });

        // Reveal anything already on screen right away so the landing content
        // is visible without waiting for a scroll.
        function revealInView() {
          var vh = window.innerHeight || document.documentElement.clientHeight;
          reveals.forEach(function (el) {
            if (el.classList.contains('is-visible')) return;
            var r = el.getBoundingClientRect();
            if (r.top < vh * 0.98 && r.bottom > 0) {
              el.classList.add('is-visible');
              observer.unobserve(el);
            }
          });
        }

        requestAnimationFrame(function () {
          requestAnimationFrame(revealInView);
        });
        window.addEventListener('load', revealInView);
      })();
    </script>
  </body>
</html>
