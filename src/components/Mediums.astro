---
import { mediums } from '../data/mediums';
import MediaFrame from './MediaFrame.astro';
---

<section class="mediums">
  <div id="mediums" class="mediums__process">
    <div class="panel-inner">
      <div class="mediums__process-grid">
        <div class="mediums__intro-col">
          <p class="section-kicker" data-reveal>The Process</p>

          <h2 class="mediums__method" data-reveal>
            <span class="mediums__method-word">Her</span>
            <span class="mediums__method-accent">Method</span>
          </h2>

          <p class="mediums__blend" data-reveal>Texture · Resin · Acrylic</p>

          <div class="mediums__copy" data-reveal>
            <p>
              Her artistic process blends sculptural texture with fluid resin, where she captures the
              beautiful contradiction of the different mediums.
            </p>
            <p>
              Together, they create artworks that continuously evolve throughout the day; textures
              cast changing shadows while resin catches the light, making every piece feel alive from
              every angle.
            </p>
          </div>
        </div>

        <div class="mediums__video" data-reveal aria-label="Process video coming soon">
          <span class="mediums__video-play" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M8 5.5 L18 12 L8 18.5 Z" fill="currentColor" />
            </svg>
          </span>
        </div>
      </div>
    </div>
  </div>

  {/* Tight overlapping cluster — click a chip or label for the copy */}
  <div class="mediums__cards">
    <div class="panel-inner">
      <div class="mediums__cluster" data-reveal>
        <div class="mediums__stack" role="tablist" aria-label="Mediums" data-medium-stack>
          {
            mediums.map((medium, i) => (
              <button
                type="button"
                class={`mediums__chip is-pos-${i}`}
                style={`--i: ${i}`}
                role="tab"
                aria-selected="false"
                aria-controls="mediums-detail"
                data-medium-tab={medium.slug}
                data-medium-chip
              >
                <span class="mediums__chip-frame">
                  <MediaFrame src={medium.image} alt="" width={360} height={480} />
                </span>
              </button>
            ))
          }
        </div>

        <div class="mediums__labels">
          {
            mediums.map((medium, i) => (
              <>
                {i > 0 && <span class="mediums__labels-sep" aria-hidden="true">·</span>}
                <button
                  type="button"
                  class="mediums__label"
                  data-medium-tab={medium.slug}
                  aria-controls="mediums-detail"
                >
                  <span class="mediums__label-num">{String(i + 1).padStart(2, '0')}</span>
                  {medium.name}
                </button>
              </>
            ))
          }
        </div>

        <div id="mediums-detail" class="mediums__detail" hidden>
          {
            mediums.map((medium) => (
              <p class="mediums__detail-copy" data-medium-copy={medium.slug} hidden>
                {medium.description}
              </p>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('.mediums');
  if (root) {
    const cluster = root.querySelector<HTMLElement>('.mediums__cluster');
    const stack = root.querySelector<HTMLElement>('[data-medium-stack]');
    const chips = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-medium-chip]'));
    const triggers = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-medium-tab]'));
    const detail = root.querySelector<HTMLElement>('.mediums__detail');
    const copies = Array.from(root.querySelectorAll<HTMLElement>('[data-medium-copy]'));
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    let active: string | null = null;
    let front = 1;
    let timer: number | null = null;
    let inView = true;
    let paused = false;
    let peekSlug: string | null = null;

    function applyDeck() {
      const n = chips.length;
      chips.forEach((chip, i) => {
        // Keep the front index in the center slot (pos 1)
        const pos = (i - front + 1 + n) % n;
        chip.classList.remove('is-pos-0', 'is-pos-1', 'is-pos-2');
        chip.classList.add(`is-pos-${pos}`);
        chip.classList.toggle('is-front', pos === 1 && !active && !peekSlug);
        chip.classList.toggle('is-peek', chip.dataset.mediumTab === peekSlug);
      });

      // Soft label pulse on the front / peeked card (not the click-open state)
      if (!active) {
        const highlight =
          peekSlug ?? chips.find((c) => c.classList.contains('is-front'))?.dataset.mediumTab;
        triggers.forEach((btn) => {
          if (btn.getAttribute('role') === 'tab') return;
          btn.classList.toggle('is-front', btn.dataset.mediumTab === highlight);
        });
      }
    }

    function stopCycle() {
      if (timer !== null) {
        window.clearInterval(timer);
        timer = null;
      }
    }

    function startCycle() {
      if (reduceMotion || active || paused || !inView || timer !== null) return;
      timer = window.setInterval(() => {
        front = (front + 1) % chips.length;
        applyDeck();
      }, 2800);
    }

    function pause() {
      paused = true;
      stopCycle();
    }

    function resume() {
      paused = false;
      if (!active) {
        peekSlug = null;
        applyDeck();
        startCycle();
      }
    }

    function setPeek(slug: string | null) {
      if (!finePointer || active) return;
      if (peekSlug === slug) return;
      peekSlug = slug;
      if (slug) {
        const idx = chips.findIndex((c) => c.dataset.mediumTab === slug);
        // Lift in place — don't reshuffle slots on peek (avoids hover loss mid-move)
        if (idx >= 0) applyDeck();
      } else {
        applyDeck();
      }
    }

    function select(slug: string) {
      const next = active === slug ? null : slug;
      active = next;
      peekSlug = null;

      cluster?.classList.toggle('has-detail', Boolean(next));

      triggers.forEach((btn) => {
        const on = btn.dataset.mediumTab === next;
        btn.classList.toggle('is-active', on);
        btn.classList.remove('is-front');
        btn.classList.remove('is-peek');
        if (btn.getAttribute('role') === 'tab') {
          btn.setAttribute('aria-selected', String(on));
        }
      });

      if (!detail) return;

      if (!next) {
        detail.hidden = true;
        copies.forEach((copy) => (copy.hidden = true));
        applyDeck();
        if (!paused) startCycle();
        return;
      }

      // Bring the opened medium to the front and hold the deck
      stopCycle();
      const idx = chips.findIndex((c) => c.dataset.mediumTab === next);
      if (idx >= 0) {
        front = idx;
        applyDeck();
      }

      detail.hidden = false;
      copies.forEach((copy) => {
        copy.hidden = copy.dataset.mediumCopy !== next;
      });
    }

    triggers.forEach((btn) => {
      btn.addEventListener('click', (event) => {
        event.preventDefault();
        const slug = btn.dataset.mediumTab;
        if (slug) select(slug);
      });
    });

    // Pause while hovering the cluster — desktop only.
    // On touch, pointerleave is unreliable and can leave the deck stuck paused.
    if (finePointer) {
      cluster?.addEventListener('pointerenter', pause);
      cluster?.addEventListener('pointerleave', resume);

      chips.forEach((chip) => {
        chip.addEventListener('pointerenter', () => {
          setPeek(chip.dataset.mediumTab ?? null);
        });
        chip.addEventListener('pointerleave', () => {
          if (peekSlug === chip.dataset.mediumTab) setPeek(null);
        });
      });
    }

    if (!reduceMotion && stack) {
      const io = new IntersectionObserver(
        ([entry]) => {
          inView = entry?.isIntersecting ?? false;
          if (inView) startCycle();
          else stopCycle();
        },
        { threshold: 0.35 }
      );
      io.observe(stack);
      applyDeck();
      startCycle();
    } else {
      applyDeck();
    }
  }
</script>

<style>
  .mediums {
    --process-blue: #07294a;
  }

  /* Soft edge fades, solid navy holds most of the band */
  .mediums__process {
    position: relative;
    margin: clamp(4.5rem, 9vw, 8rem) 0 clamp(3.5rem, 7vw, 6rem);
    padding: clamp(5.5rem, 10vw, 9rem) 0;
    background: linear-gradient(
      180deg,
      rgba(7, 41, 74, 0) 0%,
      rgba(7, 41, 74, 0.65) 10%,
      var(--process-blue) 18%,
      var(--process-blue) 82%,
      rgba(7, 41, 74, 0.65) 90%,
      rgba(7, 41, 74, 0) 100%
    );
    scroll-margin-top: calc(var(--scroll-anchor-offset) + var(--space-3));
  }

  .mediums__process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;
    max-width: 1040px;
    margin: 0 auto;
  }

  .mediums__method {
    display: flex;
    flex-direction: column;
    margin: 0 0 var(--space-3);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 0.86;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    font-size: clamp(52px, 8vw, 104px);
  }

  .mediums__method-word {
    color: #ffffff;
  }

  .mediums__method-accent {
    color: #ff7f89;
  }

  .mediums__blend {
    margin: 0 0 var(--space-4);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .mediums__copy p {
    margin: 0 0 var(--space-3);
    max-width: 42ch;
    font-size: 16px;
    line-height: 1.7;
    color: rgba(251, 246, 234, 0.9);
  }

  .mediums__copy p:last-child {
    margin-bottom: 0;
  }

  .mediums__video {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(120% 120% at 50% 38%, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.02)),
      rgba(8, 14, 22, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  .mediums__video-play {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(251, 246, 234, 0.92);
    color: #12303f;
    padding-left: 4px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .mediums__video:hover .mediums__video-play {
    transform: scale(1.06);
  }

  /* ——— Overlapping cluster ——— */
  .mediums__cards {
    padding: clamp(6rem, 12vw, 9rem) 0 clamp(5rem, 10vw, 8rem);
  }

  .mediums__cluster {
    max-width: 1040px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mediums__stack {
    position: relative;
    width: min(100%, 680px);
    height: 400px;
    margin-bottom: var(--space-4);
  }

  .mediums__chip {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 260px;
    aspect-ratio: 3 / 4;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    transform-origin: center bottom;
    transition:
      transform 0.85s var(--ease-gentle),
      filter 0.85s var(--ease-gentle);
    /* Isolate hit-testing from sibling paints during z-index flips */
    touch-action: manipulation;
  }

  /* Deck slots — JS rotates which chip sits in each */
  .mediums__chip.is-pos-0 {
    z-index: 1;
    transform: translate(-98%, -48%) rotate(-12deg) scale(0.92);
    filter: brightness(0.82);
  }

  .mediums__chip.is-pos-1 {
    z-index: 3;
    transform: translate(-50%, -56%) rotate(1.5deg) scale(1);
    filter: brightness(1);
  }

  .mediums__chip.is-pos-2 {
    z-index: 2;
    transform: translate(-2%, -48%) rotate(11deg) scale(0.92);
    filter: brightness(0.82);
  }

  /* Peek / active lift — driven by JS (.is-peek), not CSS :hover,
     so auto-rotate + overlap don't steal the hovered card. */
  .mediums__chip.is-pos-0.is-peek,
  .mediums__chip.is-pos-0.is-active {
    z-index: 6;
    transform: translate(-102%, -54%) rotate(-15deg) scale(0.98);
    filter: brightness(1);
  }

  .mediums__chip.is-pos-1.is-peek,
  .mediums__chip.is-pos-1.is-active,
  .mediums__chip.is-pos-1.is-front {
    z-index: 5;
    transform: translate(-50%, -62%) rotate(0deg) scale(1.05);
  }

  .mediums__chip.is-pos-2.is-peek,
  .mediums__chip.is-pos-2.is-active {
    z-index: 6;
    transform: translate(2%, -54%) rotate(14deg) scale(0.98);
    filter: brightness(1);
  }

  .mediums__chip:focus-visible .mediums__chip-frame {
    outline: 2px solid #ff7f89;
    outline-offset: 3px;
  }

  .mediums__chip-frame {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(8, 12, 20, 0.65);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.42);
    transition:
      border-color var(--duration-fast) var(--ease-out),
      box-shadow 0.85s var(--ease-gentle);
    pointer-events: none;
  }

  .mediums__chip.is-front .mediums__chip-frame,
  .mediums__chip.is-active .mediums__chip-frame,
  .mediums__chip.is-peek .mediums__chip-frame {
    border-color: rgba(255, 127, 137, 0.55);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.5);
  }

  .mediums__chip-frame .media-frame {
    background: transparent;
  }

  .mediums__chip-frame .media-frame__img {
    object-fit: cover;
    object-position: center;
  }

  .mediums__labels {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 0.45em 0.55em;
    margin-bottom: 0;
  }

  .mediums__labels-sep {
    color: var(--text-on-veil-muted);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .mediums__label {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    padding: 0;
    border: none;
    background: none;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-muted);
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .mediums__label-num {
    color: #ff7f89;
  }

  .mediums__label:hover,
  .mediums__label.is-front {
    color: var(--sand-50);
  }

  .mediums__label.is-active {
    color: #ff7f89;
  }

  .mediums__detail {
    width: 100%;
    max-width: 42ch;
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    text-align: center;
  }

  .mediums__detail[hidden] {
    display: none;
  }

  .mediums__detail-copy {
    margin: 0;
    font-size: 14px;
    font-style: italic;
    line-height: 1.7;
    color: var(--text-on-veil);
  }

  .mediums__detail-copy[hidden] {
    display: none;
  }

  @media (min-width: 900px) {
    .mediums__process-grid {
      grid-template-columns: 1.05fr 0.95fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 767px) {
    .mediums__process {
      margin-left: calc(-1 * var(--space-2));
      margin-right: calc(-1 * var(--space-2));
    }

    .mediums__copy p {
      font-size: 15px;
    }

    .mediums__stack {
      width: min(100%, 480px);
      height: 300px;
    }

    .mediums__chip {
      width: 180px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mediums__video-play,
    .mediums__chip,
    .mediums__chip-frame {
      transition: none;
    }
  }
</style>
