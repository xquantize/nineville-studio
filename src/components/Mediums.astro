---
import { mediums } from '../data/mediums';
import MediaFrame from './MediaFrame.astro';
---

<section class="mediums">
  <div id="mediums" class="mediums__process">
    <div class="panel-inner">
      <div class="mediums__process-grid">
        <div class="mediums__intro-col">
          <p class="section-kicker" data-reveal>The Process</p>

          <h2 class="mediums__method" data-reveal>
            <span class="mediums__method-word">Her</span>
            <span class="mediums__method-accent">Method</span>
          </h2>

          <p class="mediums__blend" data-reveal>Texture · Resin · Acrylic</p>

          <div class="mediums__copy" data-reveal>
            <p>
              Her artistic process blends sculptural texture with fluid resin, where she captures the
              beautiful contradiction of the different mediums.
            </p>
            <p>
              Together, they create artworks that continuously evolve throughout the day; textures
              cast changing shadows while resin catches the light, making every piece feel alive from
              every angle.
            </p>
          </div>
        </div>

        <div
          class="mediums__video"
          data-method-open
          data-reveal
          role="button"
          tabindex="0"
          aria-label="Watch the full method film"
        >
          <span class="mediums__video-plate" aria-hidden="true"></span>
          <span class="mediums__video-mat">
            <video
              class="mediums__video-el"
              data-method-preview
              src="/videos/method/method-preview.mp4"
              poster="/videos/method/method-poster.webp"
              muted
              autoplay
              playsinline
              webkit-playsinline
              loop
              preload="none"
              disablepictureinpicture
              disableremoteplayback
              aria-hidden="true"
            ></video>
            <span class="mediums__video-shade" aria-hidden="true"></span>
            <span class="mediums__video-hint">
              <span class="mediums__video-hint--touch">Tap to watch more</span>
              <span class="mediums__video-hint--desk">Click to watch more</span>
            </span>
          </span>
        </div>
      </div>
    </div>
  </div>

  {/* Tight overlapping cluster — click a chip or label for the copy */}
  <div class="mediums__cards">
    <div class="panel-inner">
      <div class="mediums__cluster" data-reveal>
        <div class="mediums__stack" role="tablist" aria-label="Mediums" data-medium-stack>
          {
            mediums.map((medium, i) => (
              <button
                type="button"
                class={`mediums__chip is-pos-${i}`}
                style={`--i: ${i}`}
                role="tab"
                aria-selected="false"
                aria-controls="mediums-detail"
                data-medium-tab={medium.slug}
                data-medium-chip
              >
                <span class="mediums__chip-frame">
                  <MediaFrame src={medium.image} alt="" width={360} height={480} />
                </span>
              </button>
            ))
          }
        </div>

        <div class="mediums__labels">
          {
            mediums.map((medium, i) => (
              <>
                {i > 0 && <span class="mediums__labels-sep" aria-hidden="true">·</span>}
                <button
                  type="button"
                  class="mediums__label"
                  data-medium-tab={medium.slug}
                  aria-controls="mediums-detail"
                >
                  <span class="mediums__label-num">{String(i + 1).padStart(2, '0')}</span>
                  {medium.name}
                </button>
              </>
            ))
          }
        </div>

        <p class="mediums__hint" data-medium-hint>
          <span class="mediums__hint--touch">Tap a medium for details</span>
          <span class="mediums__hint--desk">Click a medium for details</span>
        </p>

        <div id="mediums-detail" class="mediums__detail" hidden>
          {
            mediums.map((medium) => (
              <p class="mediums__detail-copy" data-medium-copy={medium.slug} hidden>
                {medium.description}
              </p>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { lockPageScroll, unlockPageScroll } from '../scripts/scroll-lock';

  const root = document.querySelector<HTMLElement>('.mediums');
  if (root) {
    const cluster = root.querySelector<HTMLElement>('.mediums__cluster');
    const stack = root.querySelector<HTMLElement>('[data-medium-stack]');
    const chips = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-medium-chip]'));
    const triggers = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-medium-tab]'));
    const detail = root.querySelector<HTMLElement>('.mediums__detail');
    const copies = Array.from(root.querySelectorAll<HTMLElement>('[data-medium-copy]'));
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    // Auto-rotate on touch feels glitchy — chips move under the finger mid-tap.
    const allowCycle = !reduceMotion && finePointer;
    let active: string | null = null;
    let front = 1;
    let timer: number | null = null;
    let inView = true;
    let paused = false;
    let peekSlug: string | null = null;
    let peekClearTimer = 0;

    function applyDeck() {
      const n = chips.length;
      chips.forEach((chip, i) => {
        // Keep the front index in the center slot (pos 1)
        const pos = (i - front + 1 + n) % n;
        const nextPos = `is-pos-${pos}`;
        if (!chip.classList.contains(nextPos)) {
          chip.classList.remove('is-pos-0', 'is-pos-1', 'is-pos-2');
          chip.classList.add(nextPos);
        }
        chip.classList.toggle('is-front', pos === 1 && !active && !peekSlug);
        chip.classList.toggle('is-peek', !active && chip.dataset.mediumTab === peekSlug);
        chip.classList.toggle('is-active', chip.dataset.mediumTab === active);
        chip.setAttribute('aria-selected', String(chip.dataset.mediumTab === active));
      });

      // Soft label pulse on the front / peeked card (not the click-open state)
      const highlight = active ?? peekSlug ?? chips.find((c) => c.classList.contains('is-front'))?.dataset.mediumTab;
      triggers.forEach((btn) => {
        if (btn.hasAttribute('data-medium-chip')) return;
        const slug = btn.dataset.mediumTab;
        btn.classList.toggle('is-front', !active && slug === highlight);
        btn.classList.toggle('is-active', Boolean(active) && slug === active);
      });
    }

    function stopCycle() {
      if (timer !== null) {
        window.clearInterval(timer);
        timer = null;
      }
    }

    function startCycle() {
      if (!allowCycle || active || paused || !inView || timer !== null) return;
      timer = window.setInterval(() => {
        front = (front + 1) % chips.length;
        applyDeck();
      }, 3200);
    }

    function pause() {
      paused = true;
      stopCycle();
    }

    function resume() {
      paused = false;
      if (!active) {
        peekSlug = null;
        applyDeck();
        startCycle();
      }
    }

    function setPeek(slug: string | null) {
      if (!finePointer || active) return;
      if (peekSlug === slug) return;
      peekSlug = slug;
      applyDeck();
    }

    function chipFromPoint(x: number, y: number) {
      const els = document.elementsFromPoint(x, y);
      for (const el of els) {
        const chip = (el as Element).closest?.('[data-medium-chip]');
        if (chip instanceof HTMLElement && stack?.contains(chip)) return chip;
      }
      return null;
    }

    function select(slug: string) {
      const next = active === slug ? null : slug;
      active = next;
      peekSlug = null;
      window.clearTimeout(peekClearTimer);

      cluster?.classList.toggle('has-detail', Boolean(next));

      if (!detail) {
        applyDeck();
        return;
      }

      if (!next) {
        detail.hidden = true;
        copies.forEach((copy) => (copy.hidden = true));
        applyDeck();
        if (!paused) startCycle();
        return;
      }

      // Bring the opened medium to the front and hold the deck
      pause();
      const idx = chips.findIndex((c) => c.dataset.mediumTab === next);
      if (idx >= 0) front = idx;
      applyDeck();

      detail.hidden = false;
      copies.forEach((copy) => {
        copy.hidden = copy.dataset.mediumCopy !== next;
      });
    }

    triggers.forEach((btn) => {
      btn.addEventListener('click', (event) => {
        event.preventDefault();
        const slug = btn.dataset.mediumTab;
        if (slug) select(slug);
      });
    });

    // Desktop: hit-test peeks (stable while chips transform under the cursor).
    if (finePointer && stack) {
      stack.addEventListener('pointerenter', () => {
        window.clearTimeout(peekClearTimer);
        pause();
      });

      stack.addEventListener('pointermove', (event) => {
        if (active || event.pointerType !== 'mouse') return;
        const chip = chipFromPoint(event.clientX, event.clientY);
        setPeek(chip?.dataset.mediumTab ?? null);
      });

      stack.addEventListener('pointerleave', () => {
        window.clearTimeout(peekClearTimer);
        peekClearTimer = window.setTimeout(() => {
          setPeek(null);
          if (!active) resume();
        }, 120);
      });

      // Labels also preview their chip
      triggers.forEach((btn) => {
        if (btn.hasAttribute('data-medium-chip')) return;
        btn.addEventListener('pointerenter', () => {
          pause();
          setPeek(btn.dataset.mediumTab ?? null);
        });
        btn.addEventListener('pointerleave', () => {
          if (peekSlug === btn.dataset.mediumTab) setPeek(null);
        });
      });

      cluster?.addEventListener('pointerleave', () => {
        window.clearTimeout(peekClearTimer);
        peekClearTimer = window.setTimeout(() => {
          setPeek(null);
          if (!active) resume();
        }, 140);
      });
    }

    if (allowCycle && stack) {
      const io = new IntersectionObserver(
        ([entry]) => {
          inView = entry?.isIntersecting ?? false;
          if (inView) startCycle();
          else stopCycle();
        },
        { threshold: 0.35 }
      );
      io.observe(stack);
      applyDeck();
      startCycle();
    } else {
      applyDeck();
    }
  }

  // ——— Method film: always muted, mobile autoplay, Laura lightbox ———
  const previewBtn = document.querySelector<HTMLElement>('[data-method-open]');
  const preview = document.querySelector<HTMLVideoElement>('[data-method-preview]');
  const lightbox = document.querySelector<HTMLElement>('[data-method-lightbox]');
  const fullVideo = document.querySelector<HTMLVideoElement>('[data-method-full]');
  const closeBtns = document.querySelectorAll<HTMLElement>('[data-method-close]');
  const reduceVideoMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let lightboxOpen = false;
  let closeTimer: number | null = null;
  let previewWantsPlay = false;
  let previewRetryTimer: number | null = null;

  function forceMute(video: HTMLVideoElement) {
    video.muted = true;
    video.defaultMuted = true;
    video.volume = 0;
    video.setAttribute('muted', '');
  }

  function attachFullSource() {
    if (!fullVideo || fullVideo.dataset.ready === '1') return;
    const src = fullVideo.dataset.src;
    if (!src) return;
    forceMute(fullVideo);
    fullVideo.setAttribute('playsinline', '');
    fullVideo.setAttribute('webkit-playsinline', '');
    fullVideo.playsInline = true;
    fullVideo.src = src;
    fullVideo.load();
    fullVideo.dataset.ready = '1';
  }

  function playMuted(video: HTMLVideoElement) {
    forceMute(video);
    const result = video.play();
    if (result && typeof result.catch === 'function') {
      result.catch(() => {
        // iOS often rejects the first play() before enough data — retry below
      });
    }
  }

  function stopPreviewRetries() {
    if (previewRetryTimer !== null) {
      window.clearInterval(previewRetryTimer);
      previewRetryTimer = null;
    }
  }

  function kickPreview() {
    if (!preview || reduceVideoMotion || lightboxOpen || !previewWantsPlay) return;
    forceMute(preview);
    preview.playsInline = true;
    preview.setAttribute('playsinline', '');
    preview.setAttribute('webkit-playsinline', '');
    preview.autoplay = true;
    preview.loop = true;
    // Do NOT call load() — on iOS it resets the element and blocks muted autoplay
    // until a tap. Src is already in the HTML; just raise preload and play.
    if (preview.preload !== 'auto') preview.preload = 'auto';
    playMuted(preview);
  }

  function setPreviewWantsPlay(on: boolean) {
    previewWantsPlay = on;
    if (!preview) return;
    if (on && !lightboxOpen && !reduceVideoMotion) {
      kickPreview();
      stopPreviewRetries();
      // Keep retrying while in view — iOS often needs several play() attempts
      previewRetryTimer = window.setInterval(() => {
        if (!previewWantsPlay || lightboxOpen || reduceVideoMotion) {
          stopPreviewRetries();
          return;
        }
        if (preview.paused) kickPreview();
      }, 400);
    } else {
      stopPreviewRetries();
      preview.pause();
    }
  }

  /** iOS: first touch unlocks muted playback for later IntersectionObserver plays */
  function unlockPreviewMedia() {
    if (!preview || preview.dataset.mediaUnlocked === '1') return;
    forceMute(preview);
    preview.playsInline = true;
    const play = preview.play();
    if (play && typeof play.then === 'function') {
      play
        .then(() => {
          preview.dataset.mediaUnlocked = '1';
          if (!previewWantsPlay || lightboxOpen) preview.pause();
          else kickPreview();
        })
        .catch(() => {});
    }
  }

  function openMethodFilm() {
    if (!lightbox || !fullVideo || lightboxOpen) return;
    if (closeTimer !== null) {
      window.clearTimeout(closeTimer);
      closeTimer = null;
    }
    preview?.pause();
    stopPreviewRetries();
    attachFullSource();
    forceMute(fullVideo);
    lightbox.hidden = false;
    document.documentElement.classList.add('is-method-open');
    lockPageScroll();
    requestAnimationFrame(() => {
      lightbox.classList.add('is-open');
      lightbox.classList.remove('is-closing');
    });
    lightboxOpen = true;
    playMuted(fullVideo);
  }

  function closeMethodFilm() {
    if (!lightbox || !fullVideo || !lightboxOpen) return;
    lightboxOpen = false;
    fullVideo.pause();
    fullVideo.currentTime = 0;
    lightbox.classList.add('is-closing');
    lightbox.classList.remove('is-open');
    document.documentElement.classList.remove('is-method-open');
    unlockPageScroll();
    const finish = () => {
      lightbox.hidden = true;
      lightbox.classList.remove('is-closing');
      closeTimer = null;
      if (previewWantsPlay) setPreviewWantsPlay(true);
    };
    if (reduceVideoMotion) finish();
    else closeTimer = window.setTimeout(finish, 420);
  }

  previewBtn?.addEventListener('click', openMethodFilm);
  previewBtn?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault();
      openMethodFilm();
    }
  });
  closeBtns.forEach((btn) => btn.addEventListener('click', closeMethodFilm));
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && lightboxOpen) closeMethodFilm();
  });

  [preview, fullVideo].forEach((video) => {
    if (!video) return;
    forceMute(video);
    video.addEventListener('volumechange', () => forceMute(video));
  });

  if (preview && !reduceVideoMotion) {
    forceMute(preview);
    preview.playsInline = true;
    preview.setAttribute('playsinline', '');
    preview.setAttribute('webkit-playsinline', '');
    preview.autoplay = true;
    preview.loop = true;

    // When data arrives, try again (covers the common iOS first-reject case)
    preview.addEventListener('loadeddata', () => kickPreview());
    preview.addEventListener('canplay', () => kickPreview());
    preview.addEventListener('canplaythrough', () => kickPreview());

    if ('IntersectionObserver' in window) {
      const warmIO = new IntersectionObserver(
        ([entry]) => {
          if (!entry?.isIntersecting) return;
          preview.preload = 'auto';
          forceMute(preview);
          warmIO.disconnect();
        },
        { rootMargin: '1000px 0px', threshold: 0 }
      );

      const playIO = new IntersectionObserver(
        ([entry]) => {
          const on = Boolean(entry?.isIntersecting);
          setPreviewWantsPlay(on);
        },
        // threshold 0 = any pixel visible — more reliable on mobile URL-bar resize
        { threshold: 0, rootMargin: '40px 0px' }
      );

      const target = previewBtn ?? preview;
      warmIO.observe(target);
      playIO.observe(target);
    } else {
      setPreviewWantsPlay(true);
    }

    // Touch during scroll counts as a gesture on iOS — unlock muted play
    document.addEventListener('touchstart', unlockPreviewMedia, { passive: true });
    document.addEventListener('touchend', unlockPreviewMedia, { passive: true });

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible' && previewWantsPlay) kickPreview();
    });
  }
</script>

<style>
  .mediums {
    --process-blue: #07294a;
  }

  /* Soft edge fades, solid navy holds most of the band */
  .mediums__process {
    position: relative;
    margin: clamp(2.5rem, 5vw, 4.5rem) 0 clamp(3.5rem, 7vw, 6rem);
    padding: clamp(3.5rem, 7vw, 6rem) 0 clamp(5.5rem, 10vw, 9rem);
    background: linear-gradient(
      180deg,
      rgba(7, 41, 74, 0) 0%,
      rgba(7, 41, 74, 0.65) 10%,
      var(--process-blue) 18%,
      var(--process-blue) 82%,
      rgba(7, 41, 74, 0.65) 90%,
      rgba(7, 41, 74, 0) 100%
    );
    scroll-margin-top: calc(var(--scroll-anchor-offset) + var(--space-3));
  }

  .mediums__process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;
    max-width: var(--content-rail);
    margin: 0 auto;
  }

  .mediums__method {
    display: flex;
    flex-direction: column;
    margin: 0 0 var(--space-3);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 0.86;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    font-size: var(--text-display);
  }

  .mediums__method-word {
    color: #ffffff;
  }

  .mediums__method-accent {
    color: #ff7f89;
  }

  .mediums__blend {
    margin: 0 0 var(--space-4);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .mediums__copy p {
    margin: 0 0 var(--space-3);
    max-width: 42ch;
    font-size: 16px;
    line-height: 1.7;
    color: rgba(251, 246, 234, 0.9);
  }

  .mediums__copy p:last-child {
    margin-bottom: 0;
  }

  .mediums__video {
    --video-tilt: -1.4deg;
    position: relative;
    width: 100%;
    max-width: var(--media-video);
    margin-inline: auto;
    aspect-ratio: 16 / 10;
    padding: 0;
    border: none;
    background: none;
    display: block;
    cursor: pointer;
    isolation: isolate;
    -webkit-tap-highlight-color: transparent;
    transform: rotate(var(--video-tilt));
    transition: transform 0.45s var(--ease-gentle);
  }

  .mediums__video-plate {
    position: absolute;
    inset: -0.45rem -0.55rem -0.6rem -0.45rem;
    z-index: -1;
    border-radius: 10px;
    background: linear-gradient(145deg, #0b3a66 0%, #07294a 100%);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.38);
    transform: rotate(2.2deg) translate(0.15rem, 0.2rem);
    transition:
      transform 0.45s var(--ease-gentle),
      box-shadow 0.45s var(--ease-gentle);
  }

  .mediums__video-mat {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    padding: 2px;
    border-radius: 8px;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(255, 127, 137, 0.92) 42%,
      rgba(255, 255, 255, 0.78) 72%,
      rgba(255, 127, 137, 0.85) 100%
    );
    box-shadow:
      0 10px 28px rgba(0, 0, 0, 0.3);
    transition: box-shadow 0.35s var(--ease-gentle);
  }

  .mediums__video-el {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    border-radius: 6px;
    background: #0a1018;
    pointer-events: none;
  }

  .mediums__video-shade {
    position: absolute;
    inset: 2px;
    border-radius: 6px;
    background: linear-gradient(
      180deg,
      transparent 42%,
      rgba(8, 14, 22, 0.38) 78%,
      rgba(8, 14, 22, 0.7) 100%
    );
    pointer-events: none;
  }

  .mediums__video:hover,
  .mediums__video:focus-visible {
    transform: rotate(var(--video-tilt)) translateY(-0.35rem) scale(1.015);
  }

  .mediums__video:hover .mediums__video-plate,
  .mediums__video:focus-visible .mediums__video-plate {
    transform: rotate(3.2deg) translate(0.28rem, 0.3rem);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.44);
  }

  .mediums__video:hover .mediums__video-mat,
  .mediums__video:focus-visible .mediums__video-mat {
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.38);
  }

  .mediums__video:focus-visible {
    outline: 2px solid #ff7f89;
    outline-offset: 4px;  
  }

  .mediums__video-hint {
    position: absolute;
    left: 2px;
    right: 2px;
    bottom: calc(0.9rem + 2px);
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(251, 246, 234, 0.9);
    text-align: center;
    pointer-events: none;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.5);
  }

  .mediums__video-hint--touch {
    display: none;
  }

  @media (hover: none) {
    .mediums__video-hint--touch {
      display: inline;
    }

    .mediums__video-hint--desk {
      display: none;
    }

    .mediums__video:hover,
    .mediums__video:focus-visible {
      transform: rotate(var(--video-tilt));
    }

    .mediums__video:hover .mediums__video-plate,
    .mediums__video:focus-visible .mediums__video-plate {
      transform: rotate(2.2deg) translate(0.15rem, 0.2rem);
      box-shadow: 0 18px 42px rgba(0, 0, 0, 0.38);
    }
  }

  /* ——— Overlapping cluster ——— */
  .mediums__cards {
    padding: clamp(6rem, 12vw, 9rem) 0 clamp(5rem, 10vw, 8rem);
  }

  .mediums__cluster {
    max-width: var(--content-rail);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mediums__stack {
    position: relative;
    width: min(100%, var(--media-deck));
    height: 400px;
    margin-bottom: var(--space-4);
  }

  .mediums__chip {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 260px;
    aspect-ratio: 3 / 4;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    transform-origin: center bottom;
    transition:
      transform 0.7s var(--ease-gentle),
      filter 0.7s var(--ease-gentle);
    /* Isolate hit-testing from sibling paints during z-index flips */
    touch-action: manipulation;
  }

  /* Deck slots — JS rotates which chip sits in each */
  .mediums__chip.is-pos-0 {
    z-index: 1;
    transform: translate(-98%, -48%) rotate(-12deg) scale(0.92);
    filter: brightness(0.82);
  }

  .mediums__chip.is-pos-1 {
    z-index: 3;
    transform: translate(-50%, -56%) rotate(1.5deg) scale(1);
    filter: brightness(1);
  }

  .mediums__chip.is-pos-2 {
    z-index: 2;
    transform: translate(-2%, -48%) rotate(11deg) scale(0.92);
    filter: brightness(0.82);
  }

