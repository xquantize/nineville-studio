---
import { mediums } from '../data/mediums';
import MediaFrame from './MediaFrame.astro';
---

<section id="mediums" class="panel">
  <div class="panel-inner">
    <p class="section-kicker" data-reveal>What she works with</p>
    <h2 class="section-heading" data-reveal>Mediums</h2>

    <div class="mediums__grid">
      {
        mediums.map((medium) => (
          <article class="medium-card" data-reveal-fade>
            <div class="medium-card__image">
              <MediaFrame
                src={medium.image}
                alt=""
                width={400}
                height={400}
              />
            </div>
            <div class="medium-card__body">
              <h3 class="medium-card__name">{medium.name}</h3>
              <p class="medium-card__desc">{medium.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .mediums__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
    align-items: stretch;
  }

  .medium-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--card-bg);
    border: 0.5px solid rgba(184, 154, 106, 0.2);
    border-radius: 4px;
    overflow: hidden;
    transition:
      box-shadow var(--duration-gentle) var(--ease-gentle),
      border-color var(--duration-gentle) var(--ease-gentle);
  }

  .medium-card:hover {
    box-shadow: 0 12px 32px rgba(43, 36, 25, 0.08);
    border-color: rgba(184, 154, 106, 0.35);
  }

  .medium-card__image {
    flex-shrink: 0;
    aspect-ratio: 1;
    overflow: hidden;
  }

  .medium-card__image .media-frame__img {
    transition: transform 1.1s var(--ease-gentle);
  }

  .medium-card:hover .medium-card__image .media-frame__img {
    transform: scale(1.03);
  }

  .medium-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: var(--space-3);
    min-height: 5.5rem;
  }

  .medium-card__name {
    margin: 0 0 var(--space-1);
    font-size: 22px;
  }

  .medium-card__desc {
    margin: 0;
    font-size: 13px;
    font-style: italic;
    line-height: 1.5;
    color: var(--text-on-veil-muted);
  }

  @media (max-width: 767px) {
    .medium-card__body {
      padding: var(--space-1) var(--space-1) var(--space-2);
      min-height: auto;
    }

    .medium-card__name {
      font-size: 15px;
      line-height: 1.25;
      margin-bottom: 0;
    }

    .medium-card__desc {
      display: none;
    }

    .medium-card:hover {
      box-shadow: none;
    }

    .medium-card:hover .medium-card__image .media-frame__img {
      transform: none;
    }
  }

  @media (min-width: 768px) {
    .mediums__grid {
      gap: var(--space-4);
    }
  }

  @media (min-width: 900px) {
    .mediums__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-3);
    }

    .medium-card__body {
      padding: var(--space-2) var(--space-2) var(--space-3);
    }

    .medium-card__name {
      font-size: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .medium-card:hover {
      box-shadow: none;
    }

    .medium-card:hover .medium-card__image .media-frame__img {
      transform: none;
    }
  }
</style>
