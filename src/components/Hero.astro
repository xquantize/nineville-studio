<section id="top" class="hero" aria-label="Introduction">
  <div class="hero__content panel-inner">
    <div class="hero__mark">
      <div class="hero__title-wrap">
        <h1 class="hero__title">
          <span class="hero__title-line">Nineville</span>
          <span class="hero__title-line">Studio</span>
        </h1>
        <svg
          class="hero__understroke"
          viewBox="0 0 520 36"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <defs>
            <linearGradient id="hero-stroke-fade" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#ff7f89" stop-opacity="0" />
              <stop offset="14%" stop-color="#ff7f89" stop-opacity="0.85" />
              <stop offset="78%" stop-color="#ff96a0" stop-opacity="0.75" />
              <stop offset="100%" stop-color="#ff7f89" stop-opacity="0" />
            </linearGradient>
          </defs>
          <path
            class="hero__understroke-ghost"
            d="M16 22 C64 4, 108 34, 156 14 C204 -2, 248 32, 300 12 C352 -4, 400 30, 456 10 C484 2, 502 16, 512 20"
            fill="none"
            stroke="#ff7f89"
            stroke-width="7"
            stroke-linecap="round"
            pathLength="100"
          />
          <path
            class="hero__understroke-path"
            d="M16 22 C64 4, 108 34, 156 14 C204 -2, 248 32, 300 12 C352 -4, 400 30, 456 10 C484 2, 502 16, 512 20"
            fill="none"
            stroke="url(#hero-stroke-fade)"
            stroke-width="2.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            pathLength="100"
          />
        </svg>
      </div>
      <p class="hero__subtitle">art by Laura Neundörfer</p>
    </div>
  </div>

  <a href="#bio" class="hero__scroll" aria-label="Scroll to bio section">
    <svg class="hero__chevron" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true">
      <path d="M5 8 L10 13 L15 8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span class="hero__scroll-label">scroll</span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: var(--app-height, 100svh);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: stretch;
    padding: calc(var(--nav-height) + var(--space-4)) 0
      calc(var(--space-12) + env(safe-area-inset-bottom, 0px));
    box-sizing: border-box;
    background: transparent;
  }

  .hero__content {
    width: 100%;
    text-align: left;
  }

  .hero__mark {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: stretch;
  }

  .hero__title-wrap {
    position: relative;
    padding-bottom: 0.42em;
  }

  /* Hidden only while JS controls the intro; revealed via .hero-ready. */
  html.js-hero .hero__content {
    opacity: 0;
    transform: translateY(10px);
    will-change: transform, opacity;
  }

  html.js-hero.hero-ready .hero__content {
    opacity: 1;
    transform: none;
    will-change: auto;
    transition:
      opacity 1.3s var(--ease-gentle),
      transform 1.3s var(--ease-gentle);
  }

  .hero__title {
    margin: 0;
    font-size: var(--text-hero);
    letter-spacing: 0.01em;
    line-height: 1.02;
    color: var(--sand-50);
    text-shadow:
      0 2px 28px rgba(0, 0, 0, 0.4),
      0 0 48px rgba(0, 0, 0, 0.15);
  }

  /* Desktop: keep as one horizontal phrase */
  .hero__title-line + .hero__title-line::before {
    content: '\00a0';
  }

  .hero__understroke {
    position: absolute;
    left: 2%;
    top: calc(100% - 0.38em);
    width: 78%;
    height: clamp(16px, 2.4vw, 28px);
    overflow: visible;
    pointer-events: none;
  }

  .hero__understroke-ghost,
  .hero__understroke-path {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }

  .hero__understroke-ghost {
    opacity: 0.18;
    filter: blur(3px);
  }

  :global(html.js-hero.hero-ready) .hero__understroke-ghost {
    animation:
      hero-draw-understroke 1.45s var(--ease-gentle) 0.55s forwards,
      hero-tide-glow 4.2s var(--ease-in-out) 2.1s infinite;
  }

  :global(html.js-hero.hero-ready) .hero__understroke-path {
    animation:
      hero-draw-understroke 1.45s var(--ease-gentle) 0.55s forwards,
      hero-tide-pulse 4.2s var(--ease-in-out) 2.1s infinite;
  }

  /* No-JS / already-ready fallback so the stroke is never stuck invisible */
  :global(html:not(.js-hero)) .hero__understroke-ghost,
  :global(html.skip-intro) .hero__understroke-ghost {
    stroke-dashoffset: 0;
    animation: hero-tide-glow 4.2s var(--ease-in-out) infinite;
  }

  :global(html:not(.js-hero)) .hero__understroke-path,
  :global(html.skip-intro) .hero__understroke-path {
    stroke-dashoffset: 0;
    animation: hero-tide-pulse 4.2s var(--ease-in-out) infinite;
  }

  .hero__subtitle {
    margin: var(--space-3) 0 0;
    align-self: stretch;
    padding-right: 4.5em;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.08em;
    color: var(--sand-50);
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.3);
  }

  .hero__scroll {
    position: absolute;
    bottom: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-decoration: none;
    color: var(--sand-50);
    min-width: 44px;
    min-height: 44px;
    justify-content: center;
    opacity: 0.8;
    transition: opacity var(--duration-normal) var(--ease-out);
    z-index: 1;
  }

  html.js-hero .hero__scroll {
    opacity: 0;
  }

  html.js-hero.hero-ready .hero__scroll {
    opacity: 0.8;
    transition: opacity 1.2s var(--ease-gentle) 0.5s;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: var(--hero-fade);
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(22, 26, 36, 0.08) 50%,
      rgba(22, 26, 36, 0.22) 100%
    );
    pointer-events: none;
  }

  .hero__scroll:hover {
    opacity: 1;
  }

  .hero__scroll-label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero__chevron {
    animation: bounce 2.4s var(--ease-in-out) infinite;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  @keyframes hero-draw-understroke {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes hero-tide-pulse {
    0%,
    100% {
      opacity: 0.82;
      filter: brightness(1);
    }
    50% {
      opacity: 1;
      filter: brightness(1.15);
    }
  }

  @keyframes hero-tide-glow {
    0%,
    100% {
      opacity: 0.14;
    }
    50% {
      opacity: 0.28;
    }
  }

  @media (max-width: 767px) {
    .hero {
      /* 100lvh is stable (unlike 100dvh). Dynamic viewport height was resizing
         the hero as the iOS URL bar showed/hid — that shifted the whole page
         mid-fling and felt like the scroll was “grabbing”. */
      min-height: 100svh;
      min-height: 100lvh;
      padding-bottom: calc(var(--space-16) + env(safe-area-inset-bottom, 0px));
    }

    .hero__title {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      font-size: clamp(48px, 15vw, 72px);
      line-height: 0.92;
    }

    .hero__title-line + .hero__title-line::before {
      content: none;
    }

    .hero__understroke {
      left: 3%;
      top: calc(100% - 0.42em);
      width: 86%;
      height: 18px;
    }

    .hero__subtitle {
      font-size: 13px;
      letter-spacing: 0.08em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html.js-hero .hero__content,
    html.js-hero.hero-ready .hero__content {
      opacity: 1;
      transform: none;
      transition: none;
    }

    html.js-hero .hero__scroll,
    html.js-hero.hero-ready .hero__scroll {
      opacity: 0.8;
      transition: none;
    }

    .hero__chevron {
      animation: none;
    }

    .hero__understroke-ghost,
    .hero__understroke-path,
    :global(html.js-hero.hero-ready) .hero__understroke-ghost,
    :global(html.js-hero.hero-ready) .hero__understroke-path {
      animation: none;
      stroke-dashoffset: 0;
    }
  }
</style>
