---
import {
  series,
  getWorksInSeries,
  getWorkIndexBySlug,
  getSeriesAtmosphere,
  takeAtmosphere,
  formatWorkMeta,
} from '../data/works';
---

<section id="gallery" class="gallery">
  {/* Shown once a series is open */}
  <div class="panel-inner">
    <div class="gallery__head">
      <button type="button" class="gallery__collections" data-series-clear hidden>
        ← Collections
      </button>

      <div class="gallery__head-text">
        <p class="section-kicker" data-reveal>Collections</p>
        <h2 class="gallery__title gallery__title--open" data-reveal>
          <span class="gallery__title-word">The</span>
          <span class="gallery__title-accent">Gallery</span>
        </h2>
      </div>
    </div>
  </div>

  {/* Landing: stage + title + names in one composition */}
  <div class="panel-inner">
    <div class="gallery__portal" data-gallery-portal>
      <div class="gallery__portal-stage" aria-hidden="true">
        <div class="gallery__portal-glow" />
        {
          series.map((s, i) => {
            const atmosphere = getSeriesAtmosphere(s);
            const peeks = takeAtmosphere(atmosphere.pool, 3);
            return (
              <div
                class:list={['gallery__portal-stack', { 'is-active': i === 0 }]}
                data-series-plate={s.slug}
                data-peek-mode={atmosphere.mode}
                data-peek-pool={JSON.stringify(atmosphere.pool)}
              >
                {peeks.map((src, pi) => (
                  <div class={`gallery__portal-shard gallery__portal-shard--${pi + 1}`}>
                    <img
                      src={i === 0 ? src : undefined}
                      data-src={src}
                      alt=""
                      width={480}
                      height={600}
                      loading={i === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  </div>
                ))}
              </div>
            );
          })
        }
        <div class="gallery__portal-meta">
          <p class="gallery__portal-tag" data-portal-tag>
            {series[0]?.tagline ?? ''}
          </p>
          <p class="gallery__portal-count" data-portal-count>
            {(() => {
              const n = getWorksInSeries(series[0]).length;
              return `${n} ${n === 1 ? 'work' : 'works'}`;
            })()}
          </p>
        </div>
      </div>

      <div class="gallery__portal-side" data-reveal>
        <p class="section-kicker">Collections</p>
        <h2 class="gallery__title gallery__title--portal">
          <span class="gallery__title-word">The</span>
          <span class="gallery__title-accent">Gallery</span>
        </h2>

        <div class="gallery__portal-list" role="list">
          {
            series.map((s, i) => {
              const count = getWorksInSeries(s).length;
              return (
                <button
                  type="button"
                  class:list={['gallery__portal-item', { 'is-focus': i === 0 }]}
                  role="listitem"
                  data-series-focus={s.slug}
                  data-series-open={s.slug}
                  data-tagline={s.tagline ?? ''}
                  data-count={`${count} ${count === 1 ? 'work' : 'works'}`}
                  aria-label={`Open ${s.name} series`}
                >
                  <span class="gallery__portal-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="gallery__portal-name">{s.name}</span>
                </button>
              );
            })
          }
        </div>

        <p class="gallery__portal-hint">
          <span class="gallery__portal-hint--touch">Tap a series to open</span>
          <span class="gallery__portal-hint--desk">Click a series to open</span>
        </p>
      </div>
    </div>
  </div>

  <div class="gallery__works">
    <div class="panel-inner">
      {
        series.map((s) => (
          <div class="gallery__series-intro" data-series-intro={s.slug} hidden>
            <p class="section-kicker">{s.name}</p>
            <p class="gallery__series-desc">{s.description}</p>
          </div>
        ))
      }
    </div>

    {
      series.map((s) =>
        getWorksInSeries(s).map((work) => {
          const index = getWorkIndexBySlug(work.slug);
          const available = !work.status || work.status === 'available';
          return (
            <article class="gallery__piece" data-series={s.slug} hidden>
              <div class="gallery__rail">
                <button
                  type="button"
                  class="gallery__strip-nav gallery__strip-nav--prev"
                  data-strip-prev
                  aria-label={`Previous photos of ${work.title}`}
                  tabindex="-1"
                  hidden
                >
                  <span class="gallery__strip-nav-icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24">
                      <path
                        d="M14.5 5.5 L8 12 L14.5 18.5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </button>
                <button
                  type="button"
                  class="gallery__strip-nav gallery__strip-nav--next"
                  data-strip-next
                  aria-label={`Next photos of ${work.title}`}
                  tabindex="-1"
                  hidden
                >
                  <span class="gallery__strip-nav-icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24">
                      <path
                        d="M9.5 5.5 L16 12 L9.5 18.5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </button>
                <div class="gallery__strip">
                  <div class="gallery__track" data-count={work.images.length}>
                    {work.images.map((photo, ii) => (
                      <button
                        type="button"
                        class="gallery__photo"
                        data-work-open={index}
                        data-photo-index={ii}
                        aria-label={`View ${work.title}, photo ${ii + 1}`}
                      >
                        <img
                          class="gallery__photo-img"
                          src={photo.src}
                          alt={photo.alt}
                          width={560}
                          height={700}
                          sizes="(max-width: 767px) 72vw, min(28vw, 448px)"
                          loading="lazy"
                          decoding="async"
                          data-media-frame
                        />
                      </button>
                    ))}
                  </div>
                </div>
              </div>

              <div class="panel-inner">
                <p class="gallery__caption">
                  <span class="gallery__caption-name">{work.title}</span>
                  <span class="gallery__caption-sep" aria-hidden="true">·</span>
                  <span class="gallery__caption-meta">{formatWorkMeta(work)}</span>
                  {available && (
                    <>
                      <span class="gallery__caption-sep gallery__caption-sep--pink" aria-hidden="true">
                        ·
                      </span>
                      <a
                        class="gallery__caption-inquire"
                        href="#get-in-touch"
                        data-contact-trigger
                        data-contact-topic="artwork"
                        data-contact-artwork={work.title}
                        data-contact-subject={`Artwork inquiry: ${work.title}`}
                        data-contact-message={`Anything you’d like to know about “${work.title}”...`}
                      >
                        Inquire &rarr;
                      </a>
                    </>
                  )}
                </p>
              </div>
            </article>
          );
        })
      )
    }
  </div>

  <div class="panel-inner">
    <div class="gallery__foot" data-series-foot hidden>
      <button type="button" class="gallery__collections gallery__collections--foot" data-series-clear>
        ← Collections
      </button>
    </div>
  </div>
</section>

<script>
  import '../scripts/gallery.ts';
</script>

<style>
  .gallery {
    --gallery-col: var(--content-rail);
    --section-gap: clamp(3.5rem, 6vw, 7rem);
    position: relative;
    margin-top: var(--section-gap);
    padding: clamp(3rem, 5.5vw, 5rem) 0;
    scroll-margin-top: calc(var(--scroll-anchor-offset) + var(--space-3));
  }

  /* Landing fills the viewport so the next colour band doesn’t peek in */
  .gallery:not(.has-series) {
    min-height: calc(100svh - var(--scroll-anchor-offset));
    padding-top: clamp(3rem, 5.5vw, 5rem);
    padding-bottom: clamp(4.5rem, 10vh, 8rem);
    box-sizing: border-box;
  }

  .gallery__head {
    max-width: var(--content-rail);
    margin: 0 auto;
    display: none;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .gallery.has-series .gallery__head {
    display: flex;
    margin-bottom: var(--space-6);
  }

  .gallery__head-text {
    text-align: right;
    margin-left: auto;
  }

  .gallery__title {
    display: flex;
    flex-direction: column;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    font-size: var(--text-display);
  }

  .gallery__title--open {
    align-items: flex-end;
  }

  .gallery__title--portal {
    align-items: flex-start;
    margin-bottom: var(--space-4);
    font-size: var(--text-display-sm);
  }

  .gallery__portal-side .section-kicker {
    margin-bottom: var(--space-2);
  }

  .gallery__head-text .section-kicker {
    margin-bottom: var(--space-2);
  }

  .gallery__title-word {
    color: #ffffff;
  }

  .gallery__title-accent {
    color: #ff7f89;
  }

  /* Back control — only when a series is open */
  .gallery__collections {
    margin: 0;
    padding: 0;
    border: none;
    background: none;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ff7f89;
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .gallery__collections:hover {
    color: var(--sand-50);
  }

  .gallery__collections:focus-visible {
    outline: 2px solid #ff7f89;
    outline-offset: 4px;
  }

  .gallery:not(.has-series) .gallery__collections {
    display: none;
  }

  .gallery__foot {
    display: none;
    max-width: var(--gallery-col);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) 0 clamp(1rem, 2vw, 1.5rem);
    text-align: center;
  }

  .gallery.has-series .gallery__foot {
    display: block;
  }

  .gallery__collections--foot {
    font-size: 13px;
    letter-spacing: 0.16em;
  }

  /* ——— Landing portal: stage + title + names ——— */
  .gallery__portal {
    max-width: var(--content-rail);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2.25rem);
    align-items: start;
    background: none;
  }

  .gallery.has-series .gallery__portal {
    display: none;
  }

  .gallery__portal-side {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .gallery__portal-list {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
  }

  .gallery__portal-item {
    display: flex;
    align-items: baseline;
    gap: 0.75em;
    padding: 0.1rem 0;
    border: none;
    background: none;
    color: inherit;
    cursor: pointer;
    text-align: left;
  }

  .gallery__portal-item:focus-visible {
    outline: 2px solid #ff7f89;
    outline-offset: 6px;
  }

  .gallery__portal-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: rgba(255, 127, 137, 0.55);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .gallery__portal-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-title);
    line-height: 0.9;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: rgba(251, 246, 234, 0.38);
    transition:
      color 0.45s var(--ease-gentle),
      transform 0.45s var(--ease-gentle);
  }

  .gallery__portal-item.is-focus .gallery__portal-num {
    color: #ff7f89;
  }

  .gallery__portal-item.is-focus .gallery__portal-name {
    color: var(--sand-50);
    transform: translateX(6px);
  }

  .gallery__portal-item:hover .gallery__portal-name {
    color: rgba(251, 246, 234, 0.72);
  }

  .gallery__portal-item.is-focus:hover .gallery__portal-name {
    color: #ff7f89;
  }

  .gallery__portal-stage {
    position: relative;
    justify-self: center;
    width: min(100%, var(--media-piece));
    /* Tall enough for shards + meta — no opaque “card” fill behind them */
    aspect-ratio: 3 / 4;
    background: none;
    overflow: visible;
  }

  .gallery__portal-glow {
    display: none;
  }

  .gallery__portal-stack {
    position: absolute;
    inset: 0 0 2.75rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.7s var(--ease-gentle);
    z-index: 1;
    background: none;
  }

  .gallery__portal-stack.is-active {
    opacity: 1;
    z-index: 2;
  }

  .gallery__portal-shard {
    position: absolute;
    overflow: hidden;
    background: transparent;
    border: none;
    outline: none;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.4);
    border-radius: 8px;
    transition: transform 1s var(--ease-gentle);
  }

  .gallery__portal-shard img {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    outline: none;
    object-fit: cover;
    object-position: center 42%;
    transform: scale(1.55);
    transition: transform 1.2s var(--ease-gentle);
  }

  /* Constellation — tall wing + hero + lower rectangle */
  .gallery__portal-shard--1 {
    width: 46%;
    aspect-ratio: 3 / 5;
    left: 0;
    top: 6%;
    z-index: 1;
    border-radius: 8px;
    transform: rotate(-14deg) translate(-6%, 8%);
    opacity: 1;
  }

  .gallery__portal-shard--1 img {
    object-position: 35% 48%;
    transform: scale(1.7);
  }

  .gallery__portal-shard--2 {
    width: 68%;
    aspect-ratio: 4 / 5;
    left: 26%;
    top: 0;
    z-index: 3;
    border-radius: 10px;
    transform: rotate(3deg);
  }

  .gallery__portal-shard--2 img {
    object-position: 50% 40%;
    transform: scale(1.5);
  }

  .gallery__portal-shard--3 {
    width: 40%;
    aspect-ratio: 4 / 5;
    right: -12%;
    top: auto;
    bottom: 22%;
    height: auto;
    z-index: 4;
    border-radius: 8px;
    transform: rotate(0deg) translate(0, 0);
  }

  .gallery__portal-shard--3 img {
    object-position: 55% 45%;
    transform: scale(1.65);
  }

  .gallery__portal-stack.is-active .gallery__portal-shard--1 {
    transform: rotate(-16deg) translate(-8%, 4%);
  }

  .gallery__portal-stack.is-active .gallery__portal-shard--2 {
    transform: rotate(2deg) translate(0, -3%);
  }

  .gallery__portal-stack.is-active .gallery__portal-shard--3 {
    transform: rotate(0deg) translate(0, 0);
  }

  .gallery__portal:hover .gallery__portal-stack.is-active .gallery__portal-shard--1 {
    transform: rotate(-18deg) translate(-12%, 2%);
    opacity: 0.95;
  }

  .gallery__portal:hover .gallery__portal-stack.is-active .gallery__portal-shard--2 {
    transform: rotate(1deg) translate(2%, -5%) scale(1.03);
  }

  .gallery__portal:hover .gallery__portal-stack.is-active .gallery__portal-shard--2 img {
    transform: scale(1.58);
  }

  .gallery__portal:hover .gallery__portal-stack.is-active .gallery__portal-shard--3 {
    transform: rotate(0deg) translate(4%, -2%);
  }

  .gallery__portal:hover .gallery__portal-stack.is-active .gallery__portal-shard--3 img {
    transform: scale(1.72);
  }

  .gallery__portal-meta {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 7rem;
    z-index: 3;
    text-align: center;
  }

  .gallery__portal-tag,
  .gallery__portal-count {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .gallery__portal-tag {
    color: var(--sand-50);
    min-height: 1.2em;
  }

  .gallery__portal-count {
    margin-top: 0.35rem;
    color: #ff7f89;
  }

  .gallery__portal-hint {
    margin: var(--space-3) 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
    opacity: 0.85;
  }

  .gallery__portal-hint--touch {
    display: none;
  }

  @media (hover: none) {
    .gallery__portal-hint--touch {
      display: inline;
    }

    .gallery__portal-hint--desk {
      display: none;
    }
  }

  .gallery.has-series .gallery__portal-hint {
    display: none;
  }

  @media (min-width: 800px) {
    .gallery__portal {
      grid-template-columns: 1.2fr 0.8fr;
      gap: clamp(2rem, 4vw, 3.5rem);
      align-items: center;
    }

    .gallery__portal-stage {
      width: min(100%, var(--media-stage));
      min-height: clamp(36rem, 58vh, 50rem);
      justify-self: center;
      padding-left: clamp(1rem, 3vw, 2.5rem);
    }

    .gallery__portal-side {
      align-items: flex-end;
      padding-top: 0;
    }

    .gallery__title--portal {
      align-items: flex-end;
      text-align: right;
      margin-bottom: var(--space-6);
    }

    .gallery__portal-side .section-kicker {
      align-self: flex-end;
      text-align: right;
    }

    .gallery__portal-list {
      align-items: flex-end;
    }

    .gallery__portal-hint {
      align-self: flex-end;
      text-align: right;
    }

    .gallery__portal-item {
      flex-direction: row-reverse;
      text-align: right;
    }

    .gallery__portal-item.is-focus .gallery__portal-name {
      transform: translateX(-6px);
    }

    .gallery__portal-meta {
      text-align: left;
      padding-left: 12%;
      bottom: 7.5rem;
    }
  }

  @media (max-width: 767px) {
    .gallery {
      margin-top: var(--space-5);
      padding-top: var(--space-3);
      padding-bottom: var(--space-6);
    }

    .gallery:not(.has-series) {
      min-height: auto;
      padding-top: var(--space-2);
      padding-bottom: var(--space-6);
    }

    .gallery.has-series .gallery__head {
      align-items: flex-start;
      gap: var(--space-2);
      margin-bottom: var(--space-4);
    }

    .gallery__head-text {
      width: 100%;
      margin-left: 0;
      text-align: left;
    }

    .gallery__title {
      font-size: clamp(42px, 14vw, 64px);
    }

    .gallery__title--open {
      align-items: flex-start;
    }

    .gallery__collections {
      min-height: 42px;
      padding: 0.7rem 1rem;
      border: none;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.06);
      line-height: 1;
    }

    /*
      Mobile layout: title + series list first (tappable), then a proper-sized
      collage underneath — one readable stack without the tiny side-by-side.
    */
    .gallery__portal {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      align-items: stretch;
    }

    .gallery__portal-stage {
      order: 2;
      width: min(100%, 360px);
      aspect-ratio: 4 / 5;
      max-height: none;
      height: auto;
      min-height: 0;
      overflow: visible;
      margin-inline: auto;
      background: none;
      justify-self: center;
    }

    .gallery__portal-side {
      order: 1;
      padding-top: 0;
      min-width: 0;
      align-items: flex-start;
    }

    .gallery__portal-side .section-kicker {
      margin-bottom: 0.35rem;
    }

    .gallery__title--portal {
      margin-bottom: var(--space-2);
      font-size: clamp(36px, 12vw, 52px);
      line-height: 0.9;
    }

    .gallery__portal-list {
      width: 100%;
      gap: 0.05rem;
    }

    .gallery__portal-hint {
      margin-top: var(--space-2);
      align-self: flex-start;
    }

    .gallery__portal-item {
      width: 100%;
      min-height: 40px;
      padding: 0.15rem 0;
      gap: 0.65em;
      touch-action: manipulation;
    }

    .gallery__portal-num {
      font-size: 10px;
    }

    .gallery__portal-name {
      font-size: clamp(26px, 8.5vw, 36px);
      color: rgba(251, 246, 234, 0.55);
    }

    .gallery__portal-item.is-focus .gallery__portal-name {
      transform: translateX(4px);
    }

    .gallery__portal-meta {
      display: none;
    }

    .gallery__portal-glow {
      display: none;
    }

    .gallery__portal-stack {
      inset: 0;
      transition: opacity 0.75s var(--ease-gentle);
    }

    .gallery__portal-shard {
      background: none;
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.28);
      border: none;
      outline: none;
      border-radius: 6px;
      -webkit-mask-image: none;
      mask-image: none;
      transition: transform 0.85s var(--ease-gentle);
    }

    .gallery__portal-shard img {
      transform: scale(1.45);
      filter: none;
      object-fit: cover;
      transition: transform 1s var(--ease-gentle);
    }

    .gallery__portal-shard--1 {
      width: 42%;
      left: 4%;
      top: 14%;
      transform: rotate(-9deg);
      opacity: 1;
    }

    .gallery__portal-shard--1 img {
      transform: scale(1.5);
      object-position: 40% 46%;
    }

    .gallery__portal-shard--2 {
      width: 62%;
      left: 24%;
      top: 2%;
      transform: rotate(1.5deg);
    }

    .gallery__portal-shard--2 img {
      transform: scale(1.45);
      object-position: 50% 42%;
    }

    .gallery__portal-shard--3 {
      width: 36%;
      right: 0%;
      bottom: 12%;
      transform: rotate(2deg);
    }

    .gallery__portal-shard--3 img {
      transform: scale(1.48);
    }

    .gallery__portal-stack.is-active .gallery__portal-shard--1 {
      transform: rotate(-10deg) translate(-2%, 2%);
    }

    .gallery__portal-stack.is-active .gallery__portal-shard--2 {
      transform: rotate(1deg) translate(0, -2%);
    }

    .gallery__portal-stack.is-active .gallery__portal-shard--3 {
      transform: rotate(2deg) translate(0, 0);
    }

    .gallery__portal-name {
