<section id="bio" class="bio">
  <div class="bio__band">
    <div class="panel-inner">
      <div class="bio__wrap">
        <header class="bio__header">
          <p class="section-kicker" data-reveal>Meet the artist</p>
          <h2 class="section-heading bio__title" data-reveal>
            <span class="bio__title-about">About</span>
            <span class="bio__title-name">Laura</span>
          </h2>
        </header>

        <figure class="bio__portrait" data-reveal>
          <span class="bio__portrait-glow" aria-hidden="true"></span>
          <span class="bio__portrait-clip">
            {/* Painting shows through the circle — synced to the fixed background */}
            <span class="bio__portrait-window" aria-hidden="true"></span>
            <img
              class="bio__portrait-cutout"
              src="/images/bio-portrait-cutout.webp"
              alt="Laura Neundörfer"
              width={700}
              height={700}
              loading="eager"
              decoding="async"
              fetchpriority="low"
            />
          </span>
        </figure>

        <div class="bio__text" data-reveal>
          <p class="bio__lead">
            Laura is a mixed-media artist creating textured artworks that bridge the gap between
            structure and fluid mediums.
          </p>
          <p>
            For the first part of her life, her world was defined by systems and structures in
            Germany. It was a predictable rhythm that kept her safe, but left little space for
            creativity.
          </p>
          <p>
            What began as a passion for surfing evolved into a whole new way of living: She left the
            landlocked lifestyle behind, moved abroad to the coast and allowed herself to be guided
            by creativity, freedom and flow.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bio {
    --bio-blue: #07294a;
    --bio-gap: clamp(3.5rem, 7vw, 6.5rem);
    --bio-portrait: clamp(12.5rem, 22vw, 19rem);
    scroll-margin-top: var(--scroll-anchor-offset);
  }

  /* Soft edge fades, solid navy holds most of the band. */
  .bio__band {
    position: relative;
    margin: 0 0 clamp(3.5rem, 7vw, 6rem);
    padding: clamp(4.75rem, 7.5vw, 7rem) 0 clamp(5.5rem, 10vw, 9rem);
    background: linear-gradient(
      180deg,
      rgba(7, 41, 74, 0) 0%,
      rgba(7, 41, 74, 0.65) 10%,
      var(--bio-blue) 18%,
      var(--bio-blue) 82%,
      rgba(7, 41, 74, 0.65) 90%,
      rgba(7, 41, 74, 0) 100%
    );
  }

  .bio__wrap {
    max-width: var(--content-rail);
    margin: 0 auto;
    display: grid;
    grid-template-columns: var(--bio-portrait) minmax(0, 1fr);
    grid-template-areas:
      'portrait header'
      'portrait text';
    column-gap: var(--bio-gap);
    row-gap: var(--space-3);
    align-items: start;
  }

  .bio__header {
    grid-area: header;
    text-align: left;
    min-width: 0;
    padding-left: clamp(0.5rem, 2vw, 1.75rem);
  }

  .bio__band .section-kicker {
    color: rgba(255, 255, 255, 0.55);
  }

  .bio__title {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: flex-start;
    gap: clamp(0.45rem, 1.4vw, 1rem);
    line-height: 0.9;
    font-size: var(--text-display);
    text-transform: uppercase;
    margin: 0;
  }

  .bio__title-about {
    color: #ffffff;
  }

  .bio__title-name {
    color: #ff7f89;
  }

  .bio__lead {
    color: #ffffff;
    font-weight: 700;
  }

  .bio__portrait {
    grid-area: portrait;
    position: relative;
    width: 100%;
    max-width: var(--bio-portrait);
    aspect-ratio: 1;
    margin: 0;
    border-radius: 50%;
    box-sizing: border-box;
    justify-self: stretch;
    align-self: center;
    z-index: 1;
  }

  .bio__portrait-glow {
    position: absolute;
    inset: -22%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 48%,
      rgba(255, 127, 137, 0.5) 0%,
      rgba(255, 127, 137, 0.2) 40%,
      rgba(255, 127, 137, 0.06) 58%,
      transparent 72%
    );
    pointer-events: none;
    z-index: 0;
  }

  .bio__portrait-clip {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    overflow: hidden;
    clip-path: circle(50%);
    -webkit-clip-path: circle(50%);
    border: 1px solid rgba(255, 127, 137, 0.5);
    box-shadow:
      0 0 0 4px rgba(255, 127, 137, 0.12),
      0 10px 32px rgba(14, 16, 22, 0.35);
    z-index: 1;
    isolation: isolate;
  }

  /* Window into the scrolling painting — image URL from .scroll-bg__img */
  .bio__portrait-window {
    position: absolute;
    inset: 0;
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center top;
    will-change: background-position;
  }

  .bio__portrait-cutout {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.5) translate(-12%, -14%);
    transform-origin: center;
  }

  .bio__text {
    grid-area: text;
    min-width: 0;
    text-align: left;
    padding-top: 0.15rem;
    /* Extra breath from the portrait beyond the column gap */
    padding-left: clamp(0.5rem, 2vw, 1.75rem);
  }

  .bio__text p {
    margin: 0 0 var(--space-3);
    font-size: clamp(16px, 0.35vw + 15px, 18px);
    line-height: 1.7;
    color: rgba(251, 246, 234, 0.9);
    max-width: none;
  }

  .bio__text p:last-child {
    margin-bottom: 0;
  }

  /* Comfortable reading measure on wide desktops — avoid ultra-long lines */
  @media (min-width: 1100px) {
    .bio__text {
      text-align: left;
      text-wrap: pretty;
    }
  }

  /* Mid tablets: keep two columns, slightly tighter portrait */
  @media (min-width: 768px) and (max-width: 999px) {
    .bio {
      --bio-portrait: clamp(12rem, 28vw, 15rem);
      --bio-gap: clamp(2.75rem, 5vw, 4rem);
    }

    .bio__text {
      padding-left: clamp(0.35rem, 1.5vw, 1rem);
    }

    .bio__text p {
      max-width: none;
    }
  }

  @media (max-width: 767px) {
    .bio {
      --bio-portrait: clamp(10.5rem, 42vw, 13rem);
      --bio-gap: var(--space-4);
    }

    .bio__band {
      margin-left: calc(-1 * var(--space-2));
      margin-right: calc(-1 * var(--space-2));
      margin-top: 0;
      margin-bottom: clamp(2.5rem, 6vw, 4rem);
      padding-top: clamp(2.5rem, 8vw, 4rem);
      background: linear-gradient(
        180deg,
        rgba(7, 41, 74, 0) 0%,
        rgba(7, 41, 74, 0.35) 14%,
        var(--bio-blue) 32%,
        var(--bio-blue) 78%,
        rgba(7, 41, 74, 0.55) 90%,
        rgba(7, 41, 74, 0) 100%
      );
    }

    .bio__band .panel-inner {
      padding-left: var(--space-3);
      padding-right: var(--space-3);
    }

    .bio__wrap {
      grid-template-columns: 1fr;
      grid-template-areas:
        'header'
        'portrait'
        'text';
      justify-items: center;
      row-gap: var(--bio-gap);
    }

    .bio__header {
      justify-self: stretch;
      text-align: center;
      padding-left: 0;
    }

    .bio__title {
      justify-content: center;
      flex-wrap: wrap;
      row-gap: 0.1rem;
    }

    .bio__portrait {
      justify-self: center;
    }

    .bio__portrait-glow {
      inset: -18%;
      background: radial-gradient(
        circle at 50% 48%,
        rgba(255, 127, 137, 0.5) 0%,
        rgba(255, 127, 137, 0.18) 42%,
        transparent 70%
      );
    }

    .bio__portrait-window {
      background-position: center 22%;
      background-size: 140% auto;
      will-change: auto;
    }

    .bio__text {
      justify-self: stretch;
      text-align: left;
      padding-top: 0;
      padding-left: 0;
    }

    .bio__text p {
      max-width: none;
      font-size: 16px;
      line-height: 1.65;
      margin-bottom: var(--space-2);
    }
  }

  /* Short landscape phones: side-by-side without huge portrait */
  @media (max-width: 900px) and (orientation: landscape) and (max-height: 500px) {
    .bio {
      --bio-portrait: clamp(7.5rem, 28vh, 10rem);
      --bio-gap: var(--space-3);
    }

    .bio__wrap {
      grid-template-columns: var(--bio-portrait) minmax(0, 1fr);
      grid-template-areas:
        'portrait header'
        'portrait text';
      justify-items: stretch;
      row-gap: var(--space-1);
    }

    .bio__header {
      text-align: left;
    }

    .bio__title {
      justify-content: flex-start;
      font-size: clamp(2rem, 8vh, 3rem);
    }

    .bio__portrait-glow {
      inset: -14%;
    }

    .bio__band {
      padding-top: var(--space-4);
      padding-bottom: var(--space-4);
      margin-bottom: var(--space-4);
    }
  }
</style>

<script>
  const portrait = document.querySelector<HTMLElement>('.bio__portrait');
  const windowEl = document.querySelector<HTMLElement>('.bio__portrait-window');
  const bgImg = document.querySelector<HTMLImageElement>('.scroll-bg__img');

  if (portrait && windowEl) {
    const mobileQuery = window.matchMedia('(max-width: 767px)');
    let imgW = Number(bgImg?.getAttribute('width')) || 1638;
    let imgH = Number(bgImg?.getAttribute('height')) || 2048;
    let rafId = 0;
    let inView = true;

    // Reuse the already-loaded fixed background (cache hit) — keep the circle as a window into it.
    function syncFromScrollBg() {
      if (!bgImg) return;
      const src = bgImg.currentSrc || bgImg.src;
      if (!src) return;
      windowEl!.style.backgroundImage = `url("${src}")`;
      if (bgImg.naturalWidth && bgImg.naturalHeight) {
        imgW = bgImg.naturalWidth;
        imgH = bgImg.naturalHeight;
      }
    }

    // Mirror a viewport-fixed "cover" background so the circle is a window into it.
    function update() {
      if (mobileQuery.matches || !inView) return;
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const scale = Math.max(vw / imgW, vh / imgH);
      const bw = imgW * scale;
      const bh = imgH * scale;
      const ox = (vw - bw) / 2;
      const oy = (vh - bh) / 2;
      const rect = portrait!.getBoundingClientRect();

      windowEl!.style.backgroundSize = `${bw.toFixed(0)}px ${bh.toFixed(0)}px`;
      windowEl!.style.backgroundPosition = `${(ox - rect.left).toFixed(0)}px ${(oy - rect.top).toFixed(0)}px`;
    }

    function schedule() {
      if (mobileQuery.matches || !inView || rafId) return;
      rafId = requestAnimationFrame(() => {
        rafId = 0;
        update();
      });
    }

    function applyMode() {
      syncFromScrollBg();
      if (mobileQuery.matches) {
        windowEl!.style.backgroundSize = '';
        windowEl!.style.backgroundPosition = '';
        return;
      }
      schedule();
    }

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        ([entry]) => {
          inView = entry?.isIntersecting ?? false;
          if (inView) schedule();
        },
        { rootMargin: '20% 0px' }
      );
      io.observe(portrait);
    }

    window.addEventListener('app-scroll', schedule);
    window.addEventListener('scroll', schedule, { passive: true });
    window.addEventListener('resize', () => {
      syncFromScrollBg();
      schedule();
    });
    window.addEventListener('load', applyMode);
    mobileQuery.addEventListener('change', applyMode);

    if (bgImg && !bgImg.complete) {
      bgImg.addEventListener('load', applyMode, { once: true });
    }

    applyMode();
    update();
  }
</script>
