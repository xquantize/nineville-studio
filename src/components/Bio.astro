<section class="panel">
  <div class="panel-inner">
    <p class="section-kicker" data-reveal>About Laura</p>
    <h2 id="bio" class="section-heading" data-reveal>Bio</h2>

    <div class="bio__content">
      <figure class="bio__portrait" data-reveal>
        <span class="bio__portrait-window" aria-hidden="true"></span>
        <img
          class="bio__portrait-cutout"
          src="/images/bio-portrait-cutout.webp"
          alt="Laura Neundörfer"
          width={700}
          height={700}
          loading="lazy"
          decoding="async"
        />
      </figure>

      <div class="bio__text" data-reveal>
        <p>
          I am a mixed-media artist creating textured artworks that bridge the gap between
          structure and fluid mediums.
        </p>
        <p>
          For the first part of my life, my world was defined by systems and structures in
          Germany. It was a predictable rhythm that kept me safe, but left little space for
          creativity. What began as a passion for surfing evolved into a whole new way of living:
          I left the landlocked lifestyle behind, moved abroad to the coast and allowed myself to
          be guided by creativity, freedom and flow.
        </p>
        <p class="bio__text-clear">
          Today, my art is the tangible map of that journey. By pairing raw textures with fluid
          resin, I capture the beautiful contradiction of life and the coast.
        </p>
        <p>
          My work is designed to bring the vibrant and grounding energy into my collectors homes.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .bio__content {
    max-width: none;
  }

  .bio__content::after {
    content: '';
    display: table;
    clear: both;
  }

  .bio__portrait {
    position: relative;
    float: left;
    width: 8.5rem;
    aspect-ratio: 1;
    margin: 0.35rem var(--space-3) var(--space-2) 0;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(184, 154, 106, 0.5);
    box-shadow: 0 8px 28px rgba(14, 16, 22, 0.35);
    box-sizing: border-box;
  }

  /* Window into the scrolling painting behind Laura — position driven by JS */
  .bio__portrait-window {
    position: absolute;
    inset: 0;
    background-image: url('/images/background.webp');
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    will-change: background-position;
  }

  .bio__portrait-cutout {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.55) translate(-14%, -16%);
    transform-origin: center;
  }

  .bio__text {
    text-align: left;
  }

  .bio__text p {
    margin: 0 0 var(--space-3);
    font-size: 17px;
    line-height: 1.7;
  }

  .bio__text p:last-child {
    margin-bottom: 0;
  }

  /* Tablet+ — larger circle, justified text with a clean right edge */
  @media (min-width: 768px) {
    .bio__portrait {
      width: 12rem;
      margin: 0.4rem var(--space-4) var(--space-3) 0;
    }

    .bio__text {
      padding-top: var(--space-2);
      text-align: justify;
      text-justify: inter-word;
      hyphens: auto;
    }

    .bio__text-clear {
      clear: left;
    }
  }

  /* Phones — stack: portrait on top, all text below full-width */
  @media (max-width: 767px) {
    .bio__portrait {
      float: none;
      width: 8.5rem;
      margin: 0 0 var(--space-3);
    }

    .bio__text p {
      font-size: 16px;
      line-height: 1.65;
      margin-bottom: var(--space-2);
    }
  }
</style>

<script>
  const portrait = document.querySelector<HTMLElement>('.bio__portrait');
  const windowEl = document.querySelector<HTMLElement>('.bio__portrait-window');

  if (portrait && windowEl) {
    const mobileQuery = window.matchMedia('(max-width: 767px)');
    let imgW = 1638;
    let imgH = 2048;
    let rafId = 0;

    const bgImage = new Image();
    function loadNatural() {
      bgImage.src = mobileQuery.matches
        ? '/images/background-mobile.webp'
        : '/images/background.webp';
    }
    bgImage.addEventListener('load', () => {
      if (bgImage.naturalWidth && bgImage.naturalHeight) {
        imgW = bgImage.naturalWidth;
        imgH = bgImage.naturalHeight;
      }
      windowEl!.style.backgroundImage = `url('${bgImage.src}')`;
      update();
    });

    // Mirror a viewport-fixed "cover" background so the circle is a window into it.
    function update() {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const scale = Math.max(vw / imgW, vh / imgH);
      const bw = imgW * scale;
      const bh = imgH * scale;
      const ox = (vw - bw) / 2;
      const oy = (vh - bh) / 2;
      const rect = portrait!.getBoundingClientRect();

      windowEl!.style.backgroundSize = `${bw.toFixed(1)}px ${bh.toFixed(1)}px`;
      windowEl!.style.backgroundPosition = `${(ox - rect.left).toFixed(1)}px ${(oy - rect.top).toFixed(1)}px`;
    }

    function schedule() {
      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        rafId = 0;
        update();
      });
    }

    window.addEventListener('app-scroll', schedule);
    window.addEventListener('scroll', schedule, { passive: true });
    window.addEventListener('resize', () => {
      loadNatural();
      schedule();
    });
    window.addEventListener('load', schedule);
    mobileQuery.addEventListener('change', loadNatural);

    loadNatural();
    update();
  }
</script>
