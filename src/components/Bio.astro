<section id="bio" class="bio">
  <div class="bio__band">
    <div class="panel-inner">
      <div class="bio__wrap">
        <header class="bio__header">
          <p class="section-kicker" data-reveal>Meet the artist</p>
          <h2 class="section-heading bio__title" data-reveal>
            <span class="bio__title-about">About</span>
            <span class="bio__title-name">Laura</span>
          </h2>
        </header>

        <div class="bio__content">
          <figure class="bio__portrait" data-reveal>
            <span class="bio__portrait-glow" aria-hidden="true"></span>
            <span class="bio__portrait-clip">
              {/* Painting shows through the circle — synced to the fixed background */}
              <span class="bio__portrait-window" aria-hidden="true"></span>
              <img
                class="bio__portrait-cutout"
                src="/images/bio-portrait-cutout.webp"
                alt="Laura Neundörfer"
                width={700}
                height={700}
                loading="eager"
                decoding="async"
                fetchpriority="low"
              />
            </span>
          </figure>

          <div class="bio__text" data-reveal>
            <p class="bio__lead">
              Laura is a mixed-media artist creating textured artworks that bridge the gap between
              structure and fluid mediums.
            </p>
            <p>
              For the first part of her life, her world was defined by systems and structures in
              Germany. It was a predictable rhythm that kept her safe, but left little space for
              creativity.
            </p>
            <p>
              What began as a passion for surfing evolved into a whole new way of living: She left the
              landlocked lifestyle behind, moved abroad to the coast and allowed herself to be guided
              by creativity, freedom and flow.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bio {
    --bio-blue: #07294a;
    scroll-margin-top: var(--scroll-anchor-offset);
  }

  /* Soft edge fades, solid navy holds most of the band. */
  .bio__band {
    position: relative;
    margin: 0 0 clamp(3.5rem, 7vw, 6rem);
    padding: clamp(4.75rem, 7.5vw, 7rem) 0 clamp(5.5rem, 10vw, 9rem);
    background: linear-gradient(
      180deg,
      rgba(7, 41, 74, 0) 0%,
      rgba(7, 41, 74, 0.65) 10%,
      var(--bio-blue) 18%,
      var(--bio-blue) 82%,
      rgba(7, 41, 74, 0.65) 90%,
      rgba(7, 41, 74, 0) 100%
    );
  }

  .bio__wrap {
    max-width: 1040px;
    margin: 0 auto;
  }

  .bio__header {
    text-align: left;
  }

  .bio__band .section-kicker {
    color: rgba(255, 255, 255, 0.55);
  }

  .bio__title {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: flex-start;
    gap: clamp(0.45rem, 1.4vw, 1rem);
    line-height: 0.9;
    font-size: clamp(48px, 10vw, 104px);
    text-transform: uppercase;
    margin: 0 0 var(--space-3);
  }

  .bio__title-about {
    color: #ffffff;
  }

  .bio__title-name {
    color: #ff7f89;
  }

  .bio__content {
    max-width: none;
  }

  .bio__lead {
    color: #ffffff;
    font-weight: 700;
  }

  .bio__content::after {
    content: '';
    display: table;
    clear: both;
  }

  .bio__portrait {
    position: relative;
    float: left;
    width: 11rem;
    aspect-ratio: 1;
    margin: 0.35rem var(--space-3) var(--space-2) 0;
    border-radius: 50%;
    box-sizing: border-box;
    z-index: 1;
  }

  .bio__portrait-glow {
    position: absolute;
    inset: -26%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 50% 48%,
      rgba(255, 127, 137, 0.62) 0%,
      rgba(255, 127, 137, 0.28) 38%,
      rgba(255, 127, 137, 0.1) 56%,
      transparent 72%
    );
    /* Soft halo without live filter:blur (costly while scrolling) */
    pointer-events: none;
    z-index: 0;
  }

  .bio__portrait-clip {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    overflow: hidden;
    /* clip-path is reliable on Safari; border-radius alone can fail when
       a child uses filter / transform and paints outside the circle. */
    clip-path: circle(50%);
    -webkit-clip-path: circle(50%);
    border: 1px solid rgba(255, 127, 137, 0.55);
    box-shadow:
      0 0 0 5px rgba(255, 127, 137, 0.14),
      0 8px 28px rgba(14, 16, 22, 0.35);
    z-index: 1;
    isolation: isolate;
  }

  /* Window into the scrolling painting — not the blue band */
  .bio__portrait-window {
    position: absolute;
    inset: 0;
    background-image: url('/images/background.webp');
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center top;
    will-change: background-position;
  }

  .bio__portrait-cutout {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.55) translate(-14%, -16%);
    transform-origin: center;
  }

  .bio__text {
    text-align: left;
  }

  .bio__text p {
    margin: 0 0 var(--space-3);
    font-size: 17px;
    line-height: 1.7;
    color: rgba(251, 246, 234, 0.9);
  }

  .bio__text p:last-child {
    margin-bottom: 0;
  }

  @media (min-width: 768px) {
    .bio__header {
      margin-left: calc(16rem + var(--space-4));
    }

    .bio__portrait {
      width: 16rem;
      margin: 0.4rem var(--space-4) var(--space-3) 0;
    }

    .bio__text {
      padding-top: var(--space-2);
      text-align: justify;
      text-justify: inter-word;
      hyphens: none;
    }
  }

  @media (max-width: 767px) {
    .bio__band {
      /* Match veil gutter — no 100vw (overflow fights iOS scroll). */
      margin-left: calc(-1 * var(--space-2));
      margin-right: calc(-1 * var(--space-2));
      margin-top: 0;
      margin-bottom: clamp(2.5rem, 6vw, 4rem);
      padding-top: clamp(2.5rem, 8vw, 4rem);
      background: linear-gradient(
        180deg,
        rgba(7, 41, 74, 0) 0%,
        rgba(7, 41, 74, 0.35) 14%,
        var(--bio-blue) 32%,
        var(--bio-blue) 78%,
        rgba(7, 41, 74, 0.55) 90%,
        rgba(7, 41, 74, 0) 100%
      );
    }

    /* Full-bleed band, but keep the copy off the screen edges. The global
       mobile rule zeroes .panel-inner padding for .panel cards; restore a
       gutter here since the band isn't a card. */
    .bio__band .panel-inner {
      padding-left: var(--space-3);
      padding-right: var(--space-3);
    }

    .bio__portrait {
      float: none;
      width: 12rem;
      margin: 0 0 var(--space-3);
    }

    .bio__header {
      text-align: center;
    }

    .bio__title {
      justify-content: center;
      flex-wrap: wrap;
      row-gap: 0.1rem;
      margin-bottom: var(--space-4);
    }

    /* Soft pink halo — gradient only (no filter:blur). */
    .bio__portrait-glow {
      inset: -18%;
      background: radial-gradient(
        circle at 50% 48%,
        rgba(255, 127, 137, 0.55) 0%,
        rgba(255, 127, 137, 0.22) 42%,
        transparent 70%
      );
    }

    .bio__portrait-window {
      /* Soft painting fill — no filter blur (Safari turns that into a square). */
      background-image: url('/images/background-mobile.webp');
      background-position: center 22%;
      background-size: 140% auto;
      will-change: auto;
    }

    .bio__text p {
      font-size: 16px;
      line-height: 1.65;
      margin-bottom: var(--space-2);
    }
  }
</style>

<script>
  const portrait = document.querySelector<HTMLElement>('.bio__portrait');
  const windowEl = document.querySelector<HTMLElement>('.bio__portrait-window');

  if (portrait && windowEl) {
    const mobileQuery = window.matchMedia('(max-width: 767px)');
    if (!mobileQuery.matches) {
    let imgW = 1638;
    let imgH = 2048;
    let rafId = 0;
    let inView = true;

    const bgImage = new Image();
    function loadNatural() {
      bgImage.src = '/images/background.webp';
    }
    bgImage.addEventListener('load', () => {
      if (bgImage.naturalWidth && bgImage.naturalHeight) {
        imgW = bgImage.naturalWidth;
        imgH = bgImage.naturalHeight;
      }
      windowEl!.style.backgroundImage = `url('${bgImage.src}')`;
      update();
    });

    // Mirror a viewport-fixed "cover" background so the circle is a window into it.
    function update() {
      if (!inView) return;
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const scale = Math.max(vw / imgW, vh / imgH);
      const bw = imgW * scale;
      const bh = imgH * scale;
      const ox = (vw - bw) / 2;
      const oy = (vh - bh) / 2;
      const rect = portrait!.getBoundingClientRect();

      windowEl!.style.backgroundSize = `${bw.toFixed(0)}px ${bh.toFixed(0)}px`;
      windowEl!.style.backgroundPosition = `${(ox - rect.left).toFixed(0)}px ${(oy - rect.top).toFixed(0)}px`;
    }

    function schedule() {
      if (!inView || rafId) return;
      rafId = requestAnimationFrame(() => {
        rafId = 0;
        update();
      });
    }

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        ([entry]) => {
          inView = entry?.isIntersecting ?? false;
          if (inView) schedule();
        },
        { rootMargin: '20% 0px' }
      );
      io.observe(portrait);
    }

    window.addEventListener('app-scroll', schedule);
    window.addEventListener('scroll', schedule, { passive: true });
    window.addEventListener('resize', () => {
      loadNatural();
      schedule();
    });
    window.addEventListener('load', schedule);
    mobileQuery.addEventListener('change', () => {
      if (mobileQuery.matches) {
        windowEl!.style.backgroundSize = '';
        windowEl!.style.backgroundPosition = '';
      } else {
        loadNatural();
        schedule();
      }
    });

    loadNatural();
    update();
    }
  }
</script>
