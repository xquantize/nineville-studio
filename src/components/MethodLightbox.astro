---
---

{/* Lives outside .content-veil so position:fixed locks to the viewport
    (backdrop-filter on the veil creates a containing block otherwise). */}
<div
  class="method-lightbox"
  data-method-lightbox
  role="dialog"
  aria-modal="true"
  aria-label="Method film"
  hidden
>
  <div class="method-lightbox__backdrop" data-method-close tabindex="-1"></div>
  <button type="button" class="method-lightbox__close" data-method-close aria-label="Close video">
    <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
      <line
        x1="5"
        y1="5"
        x2="19"
        y2="19"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"></line>
      <line
        x1="19"
        y1="5"
        x2="5"
        y2="19"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"></line>
    </svg>
  </button>
  <div class="method-lightbox__stage">
    <p class="method-lightbox__kicker">Her Method</p>
    <div class="method-lightbox__frame">
      <video
        class="method-lightbox__video"
        data-method-full
        data-src="/videos/method/method-full.mp4"
        muted
        autoplay
        playsinline
        webkit-playsinline
        controls
        controlslist="nodownload noplaybackrate"
        disablepictureinpicture
        preload="none"
        poster="/videos/method/method-poster.webp"
      ></video>
    </div>
  </div>
</div>

<style>
  .method-lightbox {
    position: fixed;
    inset: 0;
    z-index: 210;
    display: grid;
    place-items: center;
    padding: max(var(--space-2), env(safe-area-inset-top))
      max(var(--space-2), env(safe-area-inset-right))
      max(var(--space-2), env(safe-area-inset-bottom))
      max(var(--space-2), env(safe-area-inset-left));
    box-sizing: border-box;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.4s var(--ease-gentle),
      visibility 0.4s var(--ease-gentle);
  }

  .method-lightbox.is-open {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
  }

  .method-lightbox.is-closing {
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
  }

  .method-lightbox[hidden] {
    display: none;
  }

  .method-lightbox__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(14, 16, 22, 0.9);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    pointer-events: auto;
    opacity: 0;
    transition: opacity 0.45s var(--ease-gentle);
  }

  .method-lightbox.is-open .method-lightbox__backdrop {
    opacity: 1;
  }

  .method-lightbox__close {
    position: fixed;
    top: max(var(--space-3), env(safe-area-inset-top));
    right: max(var(--space-3), env(safe-area-inset-right));
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(32, 36, 48, 0.75);
    color: var(--sand-50);
    cursor: pointer;
    pointer-events: auto;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .method-lightbox__close:hover {
    background: rgba(48, 52, 64, 0.9);
  }

  .method-lightbox__stage {
    position: relative;
    z-index: 1;
    width: min(92vw, 960px);
    display: grid;
    justify-items: center;
    gap: var(--space-2);
    opacity: 0;
    transform: translateY(14px) scale(0.985);
    transition:
      opacity 0.45s var(--ease-gentle),
      transform 0.55s var(--ease-gentle);
  }

  .method-lightbox.is-open .method-lightbox__stage {
    opacity: 1;
    transform: none;
  }

  .method-lightbox.is-closing .method-lightbox__stage {
    opacity: 0;
    transform: translateY(8px) scale(0.99);
  }

  .method-lightbox__kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ff7f89;
  }

  .method-lightbox__frame {
    width: 100%;
    padding: 2px;
    border-radius: 10px;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(255, 127, 137, 0.92) 42%,
      rgba(255, 255, 255, 0.78) 72%,
      rgba(255, 127, 137, 0.85) 100%
    );
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 127, 137, 0.25);
  }

  .method-lightbox__video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    background: #0a1018;
  }

  @media (max-width: 767px) {
    .method-lightbox__stage {
      width: min(100vw - 1rem, 960px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .method-lightbox,
    .method-lightbox__backdrop,
    .method-lightbox__stage {
      transition: none;
    }

    .method-lightbox__stage {
      transform: none;
    }
  }
</style>
