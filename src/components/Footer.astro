---
import SocialLinks from './SocialLinks.astro';
---

<footer class="footer">
  <div class="panel-inner footer__grid">
    <div class="footer__col">
      <p class="footer__brand">Nineville Studio</p>
      <p class="footer__artist">art by Laura Neundörfer</p>
    </div>

    <div class="footer__col">
      <p class="footer__label">Connect</p>
      <SocialLinks />
    </div>

    <div class="footer__col footer__col--copy">
      <p class="footer__copyright">© Nineville Studio 2026</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-6) 0 calc(var(--space-8) + env(safe-area-inset-bottom, 0px));
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .footer__brand {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 18px;
  }

  .footer__artist {
    margin: var(--space-1) 0 0;
    font-size: 13px;
    font-style: italic;
    color: var(--text-on-veil-muted);
  }

  .footer__label {
    margin: 0 0 var(--space-2);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
  }

  .footer__copyright {
    margin: 0;
    font-size: 12px;
    color: var(--text-on-veil-muted);
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }

    .footer__col--copy {
      text-align: right;
    }
  }
</style>
