---
import SocialLinks from './SocialLinks.astro';
import { site } from '../data/site';
---

<footer class="footer">
  <div class="panel-inner">
    <div class="footer__wrap">
      <div class="footer__mailing" data-reveal>
        <p class="footer__label">Join the studio mailing list</p>
        <form
          class="footer__form"
          action={site.mailingListUrl || undefined}
          method={site.mailingListUrl ? 'post' : undefined}
          target={site.mailingListUrl ? '_blank' : undefined}
          data-mailing-form
          data-fallback-email={site.email}
        >
          <input
            class="footer__input"
            type="email"
            name={site.mailingListUrl ? 'EMAIL' : 'email'}
            placeholder="Your email"
            required
            autocomplete="email"
          />
          <button class="footer__join" type="submit">Join</button>
        </form>
      </div>

      <div class="footer__main" data-reveal>
        <p class="footer__brand">Nineville Studio</p>
        <p class="footer__artist">art by Laura Neundörfer</p>

        <div class="footer__connect">
          <p class="footer__label">Connect</p>
          <SocialLinks class="footer__social" />
        </div>
      </div>

      <p class="footer__copyright">© Nineville Studio 2026</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    /* Soft blend into the solid end-cap — avoids a hard discoloured seam */
    background: linear-gradient(
      180deg,
      rgba(20, 24, 32, 0) 0%,
      rgba(20, 24, 32, 0.72) 4.5rem,
      #141820 7.5rem,
      #141820 100%
    );
    padding: clamp(4.5rem, 9vw, 7rem) 0 calc(var(--space-12) + env(safe-area-inset-bottom, 0px));
  }

  .footer__wrap {
    max-width: var(--content-rail);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .footer__mailing {
    width: 100%;
    max-width: 28rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
    border-bottom: none;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .footer__form {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
  }

  .footer__input {
    flex: 1 1 12rem;
    min-width: 0;
    padding: 12px 16px;
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-on-veil);
    font-family: var(--font-sans);
    /* Must be >=16px or iOS Safari auto-zooms the page when the field is
       focused, which is jarring on mobile. */
    font-size: 16px;
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .footer__input::placeholder {
    color: var(--text-on-veil-muted);
  }

  .footer__input:focus {
    border-color: rgba(255, 127, 137, 0.55);
  }

  .footer__join {
    flex-shrink: 0;
    padding: 12px 28px;
    border: none;
    border-radius: 100px;
    background: #ff7f89;
    color: #1a1e28;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    min-height: 44px;
    transition:
      background var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .footer__join:hover {
    background: #ff96a0;
  }

  .footer__join:active {
    transform: scale(0.98);
  }

  .footer__main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .footer__brand {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-title);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--sand-50);
  }

  .footer__artist {
    margin: 0 0 var(--space-5);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-muted);
  }

  .footer__connect {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .footer__connect :global(.social-links) {
    justify-content: center;
  }

  .footer__label {
    margin: 0 0 var(--space-2);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ff7f89;
  }

  .footer__copyright {
    margin: 0;
    padding-top: var(--space-4);
    border-top: none;
    width: 100%;
    max-width: 28rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-on-veil-muted);
  }

  @media (max-width: 767px) {
    .footer {
      padding-top: var(--space-6);
      padding-bottom: calc(var(--space-8) + env(safe-area-inset-bottom, 0px));
      margin-left: calc(-1 * var(--space-2));
      margin-right: calc(-1 * var(--space-2));
      margin-bottom: 0;
      padding-left: var(--space-2);
      padding-right: var(--space-2);
      /* Solid end-cap flush with the page — no veil padding peeking under */
      background: linear-gradient(
        180deg,
        rgba(20, 24, 32, 0) 0%,
        #141820 3.5rem,
        #141820 100%
      );
    }

    .footer__mailing {
      max-width: 21rem;
      margin-bottom: var(--space-6);
      padding-bottom: var(--space-6);
    }

    .footer__form {
      flex-wrap: nowrap;
      align-items: center;
      gap: var(--space-1);
    }

    .footer__input {
      flex: 1 1 auto;
      padding: 10px 14px;
    }

    .footer__join {
      width: auto;
      min-height: 42px;
      padding: 10px 18px;
    }
  }

  @media (max-width: 359px) {
    .footer__form {
      flex-direction: column;
      align-items: stretch;
    }

    .footer__join {
      width: 100%;
    }
  }
</style>

<script>
  const mailingForm = document.querySelector<HTMLFormElement>('[data-mailing-form]');
  if (mailingForm && !mailingForm.action) {
    mailingForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const email = new FormData(mailingForm).get('email');
      const to = mailingForm.dataset.fallbackEmail ?? '';
      if (!email || !to) return;

      const subject = encodeURIComponent('Mailing list signup');
      const body = encodeURIComponent(`Please add me to the studio mailing list: ${email}`);
      window.location.href = `mailto:${to}?subject=${subject}&body=${body}`;
    });
  }
</script>
