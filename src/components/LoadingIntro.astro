<div class="loading-intro" aria-hidden="true">
  <div class="loading-intro__inner">
    <div class="loading-wave" aria-hidden="true">
      <svg class="loading-wave__svg" viewBox="0 0 96 32" width="96" height="32">
        <g class="loading-wave__group">
          <path
            class="loading-wave__line loading-wave__line--1"
            d="M0 18 C12 8, 24 8, 36 18 S60 28, 72 18 S84 8, 96 18"
          />
          <path
            class="loading-wave__line loading-wave__line--2"
            d="M0 22 C12 12, 24 12, 36 22 S60 32, 72 22 S84 12, 96 22"
          />
          <path
            class="loading-wave__line loading-wave__line--3"
            d="M0 14 C12 4, 24 4, 36 14 S60 24, 72 14 S84 4, 96 14"
          />
        </g>
      </svg>
    </div>
    <p class="loading-intro__brand">Nineville Studio</p>
  </div>
</div>

<script>
  const intro = document.querySelector('.loading-intro') as HTMLElement | null;
  const bgImg = document.querySelector('.scroll-bg__img') as HTMLImageElement | null;

  if (intro && !document.documentElement.classList.contains('skip-intro')) {
    sessionStorage.setItem('seen-intro', '1');

    const minDisplay = 2400;
    const fadeDuration = 900;
    const started = performance.now();

    function dismiss() {
      const wait = Math.max(0, minDisplay - (performance.now() - started));

      window.setTimeout(() => {
        intro.classList.add('fade-out');
        intro.style.pointerEvents = 'none';
      }, wait);

      window.setTimeout(() => {
        intro.classList.add('hidden');
      }, wait + fadeDuration);
    }

    if (bgImg?.complete) {
      dismiss();
    } else if (bgImg) {
      bgImg.addEventListener('load', dismiss, { once: true });
      bgImg.addEventListener('error', dismiss, { once: true });
      window.setTimeout(dismiss, 3800);
    } else {
      dismiss();
    }
  }
</script>

<style>
  html.skip-intro .loading-intro {
    display: none;
  }

  .loading-intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      165deg,
      #141820 0%,
      #1a2230 40%,
      #1e2838 70%,
      #1a1e28 100%
    );
    opacity: 1;
    transition:
      opacity 900ms var(--ease-out),
      visibility 900ms;
    pointer-events: auto;
  }

  .loading-intro.fade-out {
    opacity: 0;
    visibility: hidden;
  }

  .loading-intro.hidden {
    display: none;
  }

  .loading-intro__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    animation: intro-rise 900ms var(--ease-out) both;
  }

  @keyframes intro-rise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .loading-wave {
    width: 96px;
    height: 32px;
    color: var(--sand-300);
  }

  .loading-wave__svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .loading-wave__group {
    animation: wave-flow 3.2s var(--ease-in-out) infinite;
  }

  @keyframes wave-flow {
    0%,
    100% {
      transform: translateX(-3px);
    }
    50% {
      transform: translateX(3px);
    }
  }

  .loading-wave__line {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .loading-wave__line--1 {
    opacity: 1;
    animation: wave-swell 2.2s var(--ease-in-out) infinite;
  }

  .loading-wave__line--2 {
    opacity: 0.55;
    animation: wave-swell 2.2s var(--ease-in-out) infinite;
    animation-delay: -0.35s;
  }

  .loading-wave__line--3 {
    opacity: 0.3;
    animation: wave-swell 2.2s var(--ease-in-out) infinite;
    animation-delay: -0.7s;
  }

  @keyframes wave-swell {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-3px);
    }
  }

  .loading-intro__brand {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 15px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(234, 223, 196, 0.72);
  }

  @media (prefers-reduced-motion: reduce) {
    .loading-intro {
      display: none;
    }

    .loading-intro__inner {
      animation: none;
    }

    .loading-wave__group,
    .loading-wave__line {
      animation: none;
    }
  }
</style>
