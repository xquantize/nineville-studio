<div class="loading-intro" aria-hidden="true">
  <div class="loading-intro__content">
    <p class="loading-intro__brand">Nineville Studio</p>
    <p class="loading-intro__artist">art by Laura Neundörfer</p>
  </div>
</div>

<script>
  const intro = document.querySelector('.loading-intro') as HTMLElement | null;
  const bgImg = document.querySelector('.scroll-bg__img') as HTMLImageElement | null;

  if (intro && !document.documentElement.classList.contains('skip-intro')) {
    sessionStorage.setItem('seen-intro', '1');

    const minDisplay = 750;
    const started = performance.now();

    function dismiss() {
      const wait = Math.max(0, minDisplay - (performance.now() - started));

      window.setTimeout(() => {
        intro.classList.add('fade-out');
        intro.style.pointerEvents = 'none';
      }, wait);

      window.setTimeout(() => {
        intro.classList.add('hidden');
      }, wait + 650);
    }

    if (bgImg?.complete) {
      dismiss();
    } else if (bgImg) {
      bgImg.addEventListener('load', dismiss, { once: true });
      bgImg.addEventListener('error', dismiss, { once: true });
      window.setTimeout(dismiss, 2200);
    } else {
      dismiss();
    }
  }
</script>

<style>
  html.skip-intro .loading-intro {
    display: none;
  }

  .loading-intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    opacity: 1;
    transition: opacity 650ms var(--ease-out);
    pointer-events: auto;
  }

  .loading-intro.fade-out {
    opacity: 0;
  }

  .loading-intro.hidden {
    display: none;
  }

  .loading-intro__content {
    text-align: center;
    animation: intro-enter 900ms var(--ease-out) both;
    animation-delay: 0.15s;
  }

  @keyframes intro-enter {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .loading-intro__brand {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(32px, 7vw, 64px);
    color: var(--sand-50);
    letter-spacing: -0.02em;
    text-shadow:
      0 2px 28px rgba(0, 0, 0, 0.45),
      0 0 48px rgba(0, 0, 0, 0.2);
  }

  .loading-intro__artist {
    margin: var(--space-2) 0 0;
    font-family: var(--font-sans);
    font-size: 13px;
    font-style: italic;
    letter-spacing: 0.12em;
    color: rgba(251, 246, 234, 0.92);
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.35);
  }

  @media (prefers-reduced-motion: reduce) {
    .loading-intro {
      display: none;
    }

    .loading-intro__content {
      animation: none;
    }
  }
</style>
