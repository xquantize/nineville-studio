---
import { workshops } from '../data/workshops';
import SipPaintFilm from './SipPaintFilm.astro';
---

<section class="panel workshops">
  <div class="panel-inner">
    <div id="workshops" class="workshops__wrap">
      <header class="workshops__head">
        <div class="workshops__titles" data-reveal>
          <p class="section-kicker">{workshops.kicker}</p>
          <h2 class="workshops__title">
            <span class="workshops__title-word">{workshops.titleWord}</span>
            <span class="workshops__title-accent">{workshops.titleAccent}</span>
          </h2>
        </div>

        <div class="workshops__intro" data-reveal>
          {workshops.intro.map((line) => <p>{line}</p>)}
        </div>
      </header>
  
      <div class="workshops__accordion" data-reveal>
        {/* ——— Public ——— */}
        <div class="workshops__item" data-workshop-item="public">
          <button
            type="button"
            class="workshops__trigger"
            aria-expanded="false"
            aria-controls="workshops-panel-public"
            id="workshops-tab-public"
            data-workshop-tab="public"
          >
            <span class="workshops__trigger-label">
              <span class="workshops__trigger-kicker">{workshops.public.kicker}</span>
              <span class="workshops__trigger-title">{workshops.public.heading}</span>
            </span>
            <span class="workshops__trigger-icon" aria-hidden="true"></span>
          </button>

          <div
            id="workshops-panel-public"
            class="workshops__panel"
            role="region"
            aria-labelledby="workshops-tab-public"
            data-workshop-panel="public"
            aria-hidden="true"
            inert
          >
            <div class="workshops__panel-inner">
              <ul class="workshops__dates">
                {
                  workshops.public.events.map((event) => (
                    <li class="workshops__date">
                      <time class="workshops__date-when" datetime={event.datetime}>
                        {event.date}
                      </time>
                      <div class="workshops__date-body">
                        <p class="workshops__date-title">{event.title}</p>
                        <p class="workshops__date-detail">{event.detail}</p>
                      </div>
                      <a
                        class="workshops__date-link"
                        href={event.href ?? workshops.public.allHref}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        More info
                      </a>
                    </li>
                  ))
                }
              </ul>

              <div class="workshops__actions">
                <a
                  class="workshops__inquire"
                  href="#get-in-touch"
                  data-contact-trigger
                  data-contact-topic="general"
                  data-contact-subject="Public Sip & Paint inquiry"
                  data-contact-message="Ask about an upcoming public Sip & Paint event..."
                >
                  Inquire &rarr;
                </a>
                <a
                  class="workshops__all"
                  href={workshops.public.allHref}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  All events &rarr;
                </a>
              </div>
            </div>
          </div>
        </div>

        {/* ——— Private ——— */}
        <div class="workshops__item" data-workshop-item="private">
          <button
            type="button"
            class="workshops__trigger"
            aria-expanded="false"
            aria-controls="workshops-panel-private"
            id="workshops-tab-private"
            data-workshop-tab="private"
          >
            <span class="workshops__trigger-label">
              <span class="workshops__trigger-kicker">{workshops.private.kicker}</span>
              <span class="workshops__trigger-title">{workshops.private.heading}</span>
            </span>
            <span class="workshops__trigger-icon" aria-hidden="true"></span>
          </button>

          <div
            id="workshops-panel-private"
            class="workshops__panel"
            role="region"
            aria-labelledby="workshops-tab-private"
            data-workshop-panel="private"
            aria-hidden="true"
            inert
          >
            <div class="workshops__panel-inner workshops__panel-inner--private">
              <p class="workshops__private-body">{workshops.private.body}</p>
              <div class="workshops__actions workshops__actions--private">
                <a
                  class="workshops__inquire"
                  href="#get-in-touch"
                  data-contact-trigger
                  data-contact-topic="workshops"
                  data-contact-workshop="private"
                  data-contact-subject="Private Sip & Paint inquiry"
                  data-contact-message="Any further details you’d like to share — theme, colour palette, ideas, vibe..."
                >
                  Inquire &rarr;
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <SipPaintFilm />
</section>

<script>
  const root = document.querySelector<HTMLElement>('.workshops');
  if (root) {
    const items = Array.from(root.querySelectorAll<HTMLElement>('[data-workshop-item]'));
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let active: string | null = null;
    let generation = 0;
    let busy = false;
    let pending: string | null | undefined;

    function panelEls(item: HTMLElement) {
      return {
        panel: item.querySelector<HTMLElement>('[data-workshop-panel]'),
        trigger: item.querySelector<HTMLButtonElement>('[data-workshop-tab]'),
      };
    }

    function waitForClose(panel: HTMLElement): Promise<void> {
      return new Promise((resolve) => {
        if (reduceMotion) {
          resolve();
          return;
        }

        let settled = false;
        const finish = () => {
          if (settled) return;
          settled = true;
          panel.removeEventListener('transitionend', onEnd);
          window.clearTimeout(timer);
          resolve();
        };
        const onEnd = (e: TransitionEvent) => {
          if (e.target !== panel) return;
          if (e.propertyName !== 'grid-template-rows') return;
          finish();
        };
        panel.addEventListener('transitionend', onEnd);
        const timer = window.setTimeout(finish, 520);
      });
    }

    async function closeItem(item: HTMLElement, token: number) {
      const { panel, trigger } = panelEls(item);
      if (!panel || !item.classList.contains('is-open')) return;

      item.classList.remove('is-open');
      panel.classList.remove('is-open');
      trigger?.setAttribute('aria-expanded', 'false');

      await waitForClose(panel);
      if (token !== generation) return;

      panel.setAttribute('inert', '');
      panel.setAttribute('aria-hidden', 'true');
    }

    function openItem(item: HTMLElement) {
      const { panel, trigger } = panelEls(item);
      if (!panel) return;

      panel.removeAttribute('inert');
      panel.removeAttribute('aria-hidden');
      trigger?.setAttribute('aria-expanded', 'true');
      item.classList.add('is-open');

      // Ensure we animate from the collapsed frame
      panel.classList.remove('is-open');
      void panel.offsetHeight;
      requestAnimationFrame(() => {
        panel.classList.add('is-open');
      });
    }

    async function apply(next: string | null) {
      const token = ++generation;

      const openOnes = items.filter((item) => item.classList.contains('is-open'));
      await Promise.all(openOnes.map((item) => closeItem(item, token)));
      if (token !== generation) return;

      active = next;
      if (next) {
        const item = items.find((el) => el.dataset.workshopItem === next);
        if (item) openItem(item);
      }
    }

    async function select(slug: string) {
      // Resolve against the latest intended state, not mid-animation stale active
      const current = pending !== undefined ? pending : active;
      const next = current === slug ? null : slug;

      if (busy) {
        pending = next;
        return;
      }

      busy = true;
      try {
        let target: string | null | undefined = next;
        while (target !== undefined) {
          pending = undefined;
          await apply(target);
          target = pending;
        }
      } finally {
        busy = false;
      }
    }

    items.forEach((item) => {
      const { trigger } = panelEls(item);
      trigger?.addEventListener('click', () => {
        const slug = trigger.dataset.workshopTab;
        if (slug) void select(slug);
      });
    });
  }
</script>

<style>
  .workshops__wrap {
    max-width: 1040px;
    margin: 0 auto;
    scroll-margin-top: calc(var(--scroll-anchor-offset) + var(--space-4));
  }

  .workshops__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .workshops__title {
    display: flex;
    flex-direction: column;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    font-size: clamp(48px, 10vw, 104px);
  }

  .workshops__title-word {
    color: #ffffff;
  }

  .workshops__title-accent {
    color: #ff7f89;
  }

  .workshops__intro {
    max-width: 42ch;
  }

  .workshops__intro p {
    margin: 0 0 var(--space-3);
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-on-veil);
  }

  .workshops__intro p:last-child {
    margin-bottom: 0;
  }

  /* ——— Accordion ——— */
  .workshops__accordion {
    border-top: 1px solid rgba(255, 255, 255, 0.16);
  }

  .workshops__item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
  }

  .workshops__trigger {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-4);
    align-items: center;
    padding: clamp(1.25rem, 2.5vw, 1.75rem) 0;
    border: none;
    background: none;
    color: inherit;
    text-align: left;
    cursor: pointer;
  }

  .workshops__trigger-label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .workshops__trigger-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ff7f89;
  }

  .workshops__trigger-title {
    font-family: var(--font-display);
    font-size: clamp(26px, 4vw, 40px);
    line-height: 1;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--sand-50);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .workshops__item.is-open .workshops__trigger-title,
  .workshops__trigger:hover .workshops__trigger-title {
    color: #ff7f89;
  }

  /* Plus → X */
  .workshops__trigger-icon {
    position: relative;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .workshops__trigger-icon::before,
  .workshops__trigger-icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 16px;
    height: 1.5px;
    background: #ff7f89;
    transition: transform 0.35s var(--ease-gentle);
  }

  .workshops__trigger-icon::before {
    transform: translate(-50%, -50%);
  }

  .workshops__trigger-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .workshops__item.is-open .workshops__trigger-icon::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .workshops__item.is-open .workshops__trigger-icon::after {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  /* Expand — stay as grid always (no display:none) so height animates cleanly */
  .workshops__panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 0.45s var(--ease-gentle),
      opacity 0.3s var(--ease-gentle);
  }

  .workshops__panel.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .workshops__panel-inner {
    overflow: hidden;
    min-height: 0;
    padding: 0 0 clamp(1.5rem, 3vw, 2.25rem);
  }

  .workshops__panel-inner--private {
    max-width: 42ch;
  }

  .workshops__dates {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .workshops__date {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-1) var(--space-4);
    align-items: start;
    padding: var(--space-3) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .workshops__date:first-child {
    border-top: none;
    padding-top: 0;
  }

  .workshops__date:last-child {
    padding-bottom: var(--space-2);
  }

  .workshops__date-when {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ff7f89;
    white-space: nowrap;
    padding-top: 2px;
  }

  .workshops__date-title {
    margin: 0 0 0.25em;
    font-size: 15px;
    line-height: 1.4;
    color: var(--sand-50);
  }

  .workshops__date-detail {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-on-veil-muted);
  }

  .workshops__date-link {
    grid-column: 2;
    justify-self: start;
    margin-top: var(--space-1);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ff7f89;
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .workshops__date-link:hover {
    opacity: 0.7;
  }

  .workshops__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4) var(--space-6);
    margin-top: clamp(1.75rem, 3.5vw, 2.5rem);
    padding-top: clamp(1.25rem, 2.5vw, 1.75rem);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .workshops__actions--private {
    justify-content: flex-start;
  }

  .workshops__all {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 0.65rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    background: rgba(8, 12, 20, 0.18);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sand-50);
    text-decoration: none;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .workshops__all:hover {
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.06);
  }

  .workshops__all:active {
    transform: scale(0.98);
  }

  .workshops__private-body {
    margin: 0;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-on-veil);
  }

  .workshops__inquire {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 0.65rem 1.2rem;
    border: none;
    border-radius: 999px;
    background: #ff7f89;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1a1e28;
    text-decoration: none;
    transition:
      background var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .workshops__inquire:hover {
    background: #ff96a0;
  }

  .workshops__inquire:active {
    transform: scale(0.98);
  }

  @media (min-width: 900px) {
    .workshops__head {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: var(--space-8);
      align-items: end;
    }

    .workshops__trigger {
      grid-template-columns: 1fr auto;
      align-items: end;
    }

    .workshops__trigger-label {
      flex-direction: row;
      align-items: baseline;
      gap: var(--space-4);
    }

    .workshops__date {
      grid-template-columns: 5.5rem 1fr auto;
      align-items: center;
      gap: var(--space-4);
    }

    .workshops__date-link {
      grid-column: auto;
      justify-self: end;
      margin-top: 0;
    }
  }

  @media (max-width: 767px) {
    .workshops__date-title {
      font-size: 14px;
    }

    .workshops__date-detail {
      font-size: 13px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .workshops__panel,
    .workshops__trigger-icon::before,
    .workshops__trigger-icon::after {
      transition: none;
    }
  }
</style>
