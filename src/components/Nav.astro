<nav class="nav" aria-label="Main navigation">
  <div class="nav__inner">
    <a href="#top" class="nav__brand">Nineville Studio</a>

    <button
      type="button"
      class="nav__toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <svg class="nav__icon nav__icon--open" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
        <line x1="4" y1="7" x2="20" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <line x1="4" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <line x1="4" y1="17" x2="20" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <svg class="nav__icon nav__icon--close" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
        <line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <line x1="19" y1="5" x2="5" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>

    <div id="nav-menu" class="nav__panel">
      <div class="nav__links">
        <a href="#bio" class="nav__link" data-section="bio">Bio</a>
        <a href="#mediums" class="nav__link" data-section="mediums">Mediums</a>
        <a href="#art" class="nav__link" data-section="art">Art</a>
        <a href="#commission" class="nav__link" data-section="commission">Commission</a>
      </div>
    </div>
  </div>

  <button type="button" class="nav__backdrop" aria-label="Close menu" tabindex="-1"></button>
</nav>

<script>
  const nav = document.querySelector('.nav');
  const toggle = document.querySelector('.nav__toggle');
  const panel = document.querySelector('.nav__panel');
  const backdrop = document.querySelector('.nav__backdrop');
  const links = document.querySelectorAll('.nav__link');
  const brand = document.querySelector<HTMLAnchorElement>('.nav__brand');
  const mobileQuery = window.matchMedia('(max-width: 767px)');

  function syncPanelA11y() {
    if (!panel) return;
    if (mobileQuery.matches) {
      panel.setAttribute('aria-hidden', String(!nav?.classList.contains('nav--open')));
    } else {
      panel.removeAttribute('aria-hidden');
      closeMenu();
    }
  }

  function setMenuOpen(isOpen: boolean) {
    const lenis = window.__lenis;
    if (lenis) {
      if (isOpen) lenis.stop();
      else lenis.start();
    }
    syncPanelA11y();
  }

  function closeMenu() {
    nav?.classList.remove('nav--open');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open menu');
    setMenuOpen(false);
  }

  function openMenu() {
    nav?.classList.add('nav--open');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Close menu');
    setMenuOpen(true);
  }

  toggle?.addEventListener('click', () => {
    if (nav?.classList.contains('nav--open')) closeMenu();
    else openMenu();
  });

  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && nav?.classList.contains('nav--open')) {
      closeMenu();
    }
  });

  links.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  brand?.addEventListener('click', () => {
    closeMenu();
    links.forEach((link) => link.classList.remove('is-active'));
  });

  const hero = document.querySelector('.hero');

  const onScroll = (scrollY: number) => {
    const heroEnd = hero?.offsetHeight ?? 0;
    const onHero = scrollY < heroEnd - 60;
    nav?.classList.toggle('nav--on-hero', onHero);
    nav?.classList.toggle('nav--scrolled', !onHero && scrollY > 24);
  };

  onScroll(window.scrollY);
  window.addEventListener('app-scroll', ((event: CustomEvent<{ scroll: number }>) => {
    onScroll(event.detail.scroll);
  }) as EventListener);
  window.addEventListener('scroll', () => onScroll(window.scrollY), { passive: true });

  const sections = ['bio', 'mediums', 'art', 'commission']
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];

  if (sections.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            links.forEach((link) => {
              link.classList.toggle('is-active', link.getAttribute('data-section') === id);
            });
          }
        });
      },
      { rootMargin: '-40% 0px -50% 0px', threshold: 0 }
    );

    sections.forEach((section) => observer.observe(section));
  }

  syncPanelA11y();
  mobileQuery.addEventListener('change', syncPanelA11y);
</script>

