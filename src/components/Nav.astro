    font-family: var(--font-serif);
    font-size: 16px;
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .nav__brand:hover {
    opacity: 0.7;
  }

  .nav__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
