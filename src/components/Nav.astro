<nav class="nav" aria-label="Main navigation">
  <div class="nav__inner">
    <a href="#top" class="nav__brand">Nineville Studio</a>

    <div class="nav__right">
      <div id="nav-menu" class="nav__panel">
        <div class="nav__links">
          <a href="#bio" class="nav__link" data-section="bio">Bio</a>
          <a href="#gallery" class="nav__link" data-section="gallery">Gallery</a>
          <a href="#mediums" class="nav__link" data-section="mediums">Mediums</a>
          <a href="#workshops" class="nav__link" data-section="workshops">Sip &amp; Paint</a>
        </div>
      </div>

      <a
        class="nav__cta"
        href="#get-in-touch"
        data-contact-trigger
        data-contact-topic="general"
        data-contact-subject="General inquiry"
        data-contact-message="What’s on your mind..."
      >
        Inquire &rarr;
      </a>

      <button
        type="button"
        class="nav__toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <svg class="nav__icon nav__icon--open" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <line x1="4" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <line x1="4" y1="17" x2="20" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <svg class="nav__icon nav__icon--close" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
          <line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <line x1="19" y1="5" x2="5" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <button type="button" class="nav__backdrop" aria-label="Close menu" tabindex="-1"></button>
</nav>

<script>
  const nav = document.querySelector('.nav');
  const toggle = document.querySelector('.nav__toggle');
  const panel = document.querySelector('.nav__panel');
  const backdrop = document.querySelector('.nav__backdrop');
  const links = document.querySelectorAll('.nav__link');
  const brand = document.querySelector<HTMLAnchorElement>('.nav__brand');
  const mobileQuery = window.matchMedia('(max-width: 767px)');

  function syncPanelA11y() {
    if (!panel) return;
    if (mobileQuery.matches) {
      panel.setAttribute('aria-hidden', String(!nav?.classList.contains('nav--open')));
    } else {
      panel.removeAttribute('aria-hidden');
      closeMenu();
    }
  }

  function setMenuOpen(isOpen: boolean) {
    const lenis = window.__lenis;
    if (lenis) {
      if (isOpen) lenis.stop();
      else lenis.start();
    }
    syncPanelA11y();
  }

  function closeMenu() {
    nav?.classList.remove('nav--open');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open menu');
    setMenuOpen(false);
  }

  function openMenu() {
    nav?.classList.add('nav--open');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Close menu');
    setMenuOpen(true);
  }

  toggle?.addEventListener('click', () => {
    if (nav?.classList.contains('nav--open')) closeMenu();
    else openMenu();
  });

  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && nav?.classList.contains('nav--open')) {
      closeMenu();
    }
  });

  links.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  brand?.addEventListener('click', () => {
    closeMenu();
    links.forEach((link) => link.classList.remove('is-active'));
    history.replaceState(null, '', window.location.pathname + window.location.search);
  });

  const hero = document.querySelector('.hero');

  const sectionIds = ['bio', 'gallery', 'mediums', 'workshops'];
  const sections = sectionIds
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];

  let activeId: string | null = null;
  let hashTimer = 0;
  let onHero = true;

  function setActiveSection(id: string | null) {
    if (id === activeId) return;
    activeId = id;

    links.forEach((link) => {
      link.classList.toggle('is-active', link.getAttribute('data-section') === id);
    });

    // Skip history writes on phones — replaceState during scroll feels clunky.
    if (mobileQuery.matches) return;

    window.clearTimeout(hashTimer);
    hashTimer = window.setTimeout(() => {
      const newHash = id ? `#${id}` : '';
      if (window.location.hash !== newHash) {
        const url = newHash || window.location.pathname + window.location.search;
        history.replaceState(null, '', url);
      }
    }, 220);
  }

  function currentSection(): string | null {
    const marker = window.innerHeight * 0.35;
    let current: string | null = null;
    for (const section of sections) {
      if (section.getBoundingClientRect().top - marker <= 0) current = section.id;
    }
    return current;
  }

  function applyNavChrome(isOnHero: boolean, scrollY: number) {
    onHero = isOnHero;
    nav?.classList.toggle('nav--on-hero', isOnHero);
    nav?.classList.toggle('nav--scrolled', !isOnHero && scrollY > 24);
    if (isOnHero) setActiveSection(null);
    else if (!mobileQuery.matches) setActiveSection(currentSection());
  }

  // Mobile: hero chrome via IntersectionObserver only — no per-frame
  // getBoundingClientRect / section scanning while flinging.
  if (mobileQuery.matches && hero && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      ([entry]) => {
        const visible = (entry?.intersectionRatio ?? 0) > 0.4;
        applyNavChrome(visible, window.scrollY);
      },
      { threshold: [0.25, 0.4, 0.6] }
    );
    io.observe(hero);
    applyNavChrome(true, window.scrollY);
  } else {
    let scrollRaf = 0;
    let lastScrollY = window.scrollY;

    const applyScrollState = (scrollY: number) => {
      lastScrollY = scrollY;
      const heroEnd = hero?.offsetHeight ?? 0;
      applyNavChrome(scrollY < heroEnd - 60, scrollY);
    };

    const scheduleScrollState = (scrollY: number) => {
      lastScrollY = scrollY;
      if (scrollRaf) return;
      scrollRaf = requestAnimationFrame(() => {
        scrollRaf = 0;
        applyScrollState(lastScrollY);
      });
    };

    applyScrollState(window.scrollY);
    window.addEventListener('app-scroll', ((event: CustomEvent<{ scroll: number }>) => {
      scheduleScrollState(event.detail.scroll);
    }) as EventListener);
  }

  syncPanelA11y();
  mobileQuery.addEventListener('change', syncPanelA11y);
</script>

