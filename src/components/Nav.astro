      right: var(--content-padding);
      left: auto;
      width: min(17.5rem, calc(100vw - var(--content-padding) * 2));
      pointer-events: none;
      visibility: hidden;
      opacity: 0;
      transform: translateY(-6px) scale(0.98);
      transform-origin: top right;
    transition:
      opacity var(--duration-normal) var(--ease-gentle),
      transform 0.5s var(--ease-gentle),
      visibility var(--duration-fast) var(--ease-gentle);
    }

