<nav class="nav" aria-label="Main navigation">
  <div class="nav__inner">
    <a href="#" class="nav__brand">Nineville Studio</a>

    <button
      type="button"
      class="nav__toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <svg class="nav__icon nav__icon--open" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
        <line x1="4" y1="7" x2="20" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <line x1="4" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <line x1="4" y1="17" x2="20" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <svg class="nav__icon nav__icon--close" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
        <line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <line x1="19" y1="5" x2="5" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>

    <div id="nav-menu" class="nav__links">
      <a href="#bio" class="nav__link" data-section="bio">Bio</a>
      <a href="#mediums" class="nav__link" data-section="mediums">Mediums</a>
      <a href="#art" class="nav__link" data-section="art">Art</a>
      <a href="#commission" class="nav__link" data-section="commission">Commission</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector('.nav');
  const toggle = document.querySelector('.nav__toggle');
  const links = document.querySelectorAll('.nav__link');

  function closeMenu() {
    nav?.classList.remove('nav--open');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open menu');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('nav--open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  links.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  const hero = document.querySelector('.hero');

  const onScroll = (scrollY: number) => {
    const heroEnd = hero?.offsetHeight ?? 0;
    const onHero = scrollY < heroEnd - 60;
    nav?.classList.toggle('nav--on-hero', onHero);
    nav?.classList.toggle('nav--scrolled', !onHero && scrollY > 24);
  };

  onScroll(window.scrollY);
  window.addEventListener('app-scroll', ((event: CustomEvent<{ scroll: number }>) => {
    onScroll(event.detail.scroll);
  }) as EventListener);
  window.addEventListener('scroll', () => onScroll(window.scrollY), { passive: true });

  const sections = ['bio', 'mediums', 'art', 'commission']
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];

  if (sections.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            links.forEach((link) => {
              link.classList.toggle('is-active', link.getAttribute('data-section') === id);
            });
          }
        });
      },
      { rootMargin: '-40% 0px -50% 0px', threshold: 0 }
    );

    sections.forEach((section) => observer.observe(section));
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(var(--veil-dark), 0.88);
    border-bottom: 0.5px solid rgba(184, 154, 106, 0.15);
    transition:
      background var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      border-color var(--duration-normal) var(--ease-out);
  }

  /* Landing — lighter bar over the painting */
  .nav--on-hero {
    background: rgba(var(--veil-dark), 0.42);
    border-bottom-color: rgba(251, 246, 234, 0.12);
    box-shadow: none;
  }

  .nav--on-hero .nav__brand,
  .nav--on-hero .nav__toggle,
  .nav--on-hero .nav__link {
    color: var(--sand-50);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.35);
  }

  .nav--on-hero .nav__link:hover,
  .nav--on-hero .nav__link.is-active {
    color: var(--sand-200);
  }

  .nav--on-hero .nav__link::after {
    background: var(--sand-200);
  }

  .nav__brand,
  .nav__toggle,
  .nav__link {
    color: var(--text-on-veil);
    text-shadow: none;
  }

  .nav__brand:hover,
  .nav__toggle:hover {
    opacity: 0.85;
  }

  .nav__link:hover,
  .nav__link.is-active {
    color: var(--sand-200);
  }

  .nav__link::after {
    background: var(--sand-300);
  }

  .nav--scrolled {
    background: rgba(var(--veil-dark), 0.92);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
    border-bottom-color: rgba(184, 154, 106, 0.2);
  }

  .nav__inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--content-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 56px;
  }

  .nav__brand {
    font-family: var(--font-serif);
    font-size: 16px;
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .nav__brand:hover {
    opacity: 0.7;
  }

  .nav__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .nav__toggle:hover {
    opacity: 0.65;
  }

  .nav__icon {
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .nav__icon--close {
    display: none;
  }

  .nav--open .nav__icon--open {
    display: none;
  }

  .nav--open .nav__icon--close {
    display: block;
  }

  .nav__links {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    position: fixed;
    inset: 0;
    top: 56px;
    background: rgba(var(--veil-dark), 0.95);
    z-index: 99;
  }

  .nav--open .nav__links {
    display: flex;
  }

  .nav__link {
    font-family: var(--font-serif);
    font-size: 28px;
    letter-spacing: -0.01em;
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      opacity var(--duration-fast) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
    opacity: 0;
    transform: translateY(12px);
  }

  .nav--open .nav__link {
    opacity: 1;
    transform: translateY(0);
  }

  .nav--open .nav__link:nth-child(1) { transition-delay: 60ms; }
  .nav--open .nav__link:nth-child(2) { transition-delay: 110ms; }
  .nav--open .nav__link:nth-child(3) { transition-delay: 160ms; }
  .nav--open .nav__link:nth-child(4) { transition-delay: 210ms; }

  @media (min-width: 768px) {
    .nav__toggle {
      display: none;
    }

    .nav__links {
      display: flex;
      position: static;
      flex-direction: row;
      align-items: center;
      gap: var(--space-4);
      background: none;
      inset: auto;
    }

    .nav__link {
      font-family: var(--font-sans);
      font-size: 13px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      opacity: 1;
      transform: none;
      transition: color var(--duration-fast) var(--ease-out);
      transition-delay: 0ms;
      background: none;
    }

    .nav__link::after {
      content: '';
      display: block;
      width: 0;
      height: 1px;
      margin-top: 2px;
      background: var(--sand-300);
      transition: width var(--duration-normal) var(--ease-out);
    }

    .nav--on-hero .nav__link::after {
      background: var(--sand-200);
    }

    .nav__link:hover::after,
    .nav__link.is-active::after {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__links,
    .nav__link {
      transition: none;
    }

    .nav--open .nav__link {
      transition-delay: 0ms;
    }
  }
</style>
