  }

  .nav--on-hero .nav__link:hover,
  .nav--on-hero .nav__link.is-active {
    color: var(--sand-200);
  }

  .nav--open {
    background: rgba(var(--veil-dark), 0.94);
    border-bottom-color: rgba(184, 154, 106, 0.22);
  }

  .nav--on-hero.nav--open .nav__brand,
  .nav--on-hero.nav--open .nav__toggle {
    color: var(--text-on-veil);
    text-shadow: none;
  }

  .nav__brand,
  .nav__toggle,
  .nav__link {
    color: var(--text-on-veil);
    text-shadow: none;
  }

  .nav__brand:hover,
  .nav__toggle:hover {
    opacity: 0.85;
  }

  .nav__link:hover,
  .nav__link.is-active {
    color: var(--sand-200);
  }

  .nav__link::after {
    background: var(--sand-300);
  }

  .nav--scrolled {
    background: rgba(var(--veil-dark), 0.92);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
    border-bottom-color: rgba(184, 154, 106, 0.2);
  }

  .nav__inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--content-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 56px;
  }

