---
import { works, formatLightboxMeta } from '../data/works';
import { site } from '../data/site';

const lightboxPayload = {
  email: site.email,
  works: works.map((work) => ({
    id: work.id,
    slug: work.slug,
    title: work.title,
    description: work.detailDescription ?? work.description,
    meta: formatLightboxMeta(work),
    status: work.status ?? null,
    images: work.images,
  })),
};
---

<div
  id="art-lightbox"
  class="art-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Artwork viewer"
  hidden
>
  <div class="art-lightbox__backdrop" data-lightbox-close tabindex="-1"></div>

  <button type="button" class="art-lightbox__close" data-lightbox-close aria-label="Close">
    <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
      <line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
      <line x1="19" y1="5" x2="5" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
    </svg>
  </button>

  <button type="button" class="art-lightbox__nav art-lightbox__nav--prev" data-lightbox-prev aria-label="Previous photo" hidden>
    <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M14 6 L8 12 L14 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </button>

  <button type="button" class="art-lightbox__nav art-lightbox__nav--next" data-lightbox-next aria-label="Next photo" hidden>
    <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M10 6 L16 12 L10 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </button>

  <div class="art-lightbox__stage-wrap">
    <div class="art-lightbox__zoom-stage" data-lightbox-zoom-stage></div>
    <p class="art-lightbox__zoom-hint" data-zoom-hint hidden>Pinch or double-tap to zoom</p>
  </div>
</div>

{/* Build-time catalog JSON — keeps fs scanning out of the client bundle */}
<script type="application/json" id="gallery-works-data" set:html={JSON.stringify(lightboxPayload)} />

<script>
  import '../scripts/art-lightbox.ts';
</script>

<style is:global>
  .art-lightbox__zoom-stage .pswp {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .art-lightbox__zoom-stage .pswp__bg {
    display: none;
  }

  .art-lightbox--desktop .art-lightbox__zoom-stage .pswp__img {
    cursor: zoom-in;
  }

  .art-lightbox--zoomed .art-lightbox__zoom-stage .pswp__img {
    cursor: grab;
  }
</style>

<style>
  .art-lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    padding: var(--space-2);
    box-sizing: border-box;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.4s var(--ease-gentle),
      visibility 0.4s var(--ease-gentle);
  }

  .art-lightbox.is-open {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
  }

  .art-lightbox.is-closing {
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
  }

  .art-lightbox[hidden] {
    display: none;
  }

  .art-lightbox__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(14, 16, 22, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    pointer-events: auto;
    opacity: 0;
    transition: opacity 0.45s var(--ease-gentle);
  }

  .art-lightbox.is-open .art-lightbox__backdrop {
    opacity: 1;
  }

  .art-lightbox__stage-wrap {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    gap: var(--space-2);
    pointer-events: none;
    opacity: 0;
    transform: translateY(12px) scale(0.985);
    transition:
      opacity 0.45s var(--ease-gentle),
      transform 0.55s var(--ease-gentle);
  }

  .art-lightbox.is-open .art-lightbox__stage-wrap {
    opacity: 1;
    transform: none;
  }

  .art-lightbox.is-closing .art-lightbox__stage-wrap {
    opacity: 0;
    transform: translateY(8px) scale(0.99);
  }

  .art-lightbox__zoom-stage {
    position: relative;
    width: min(92vw, 1200px);
    height: min(86dvh, 900px);
    pointer-events: auto;
  }

  .art-lightbox--touch .art-lightbox__zoom-stage {
    touch-action: none;
  }

  .art-lightbox__zoom-hint {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
    opacity: 0.75;
    pointer-events: none;
  }

  .art-lightbox__zoom-hint[hidden] {
    display: none;
  }

  .art-lightbox__close {
    position: fixed;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(32, 36, 48, 0.75);
    color: var(--sand-50);
    cursor: pointer;
    pointer-events: auto;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .art-lightbox__close:hover {
    background: rgba(48, 52, 64, 0.9);
  }

  .art-lightbox__nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(32, 36, 48, 0.75);
    color: var(--sand-50);
    cursor: pointer;
    pointer-events: auto;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .art-lightbox__nav[hidden] {
    display: none;
  }

  .art-lightbox__nav:hover {
    background: rgba(48, 52, 64, 0.9);
  }

  .art-lightbox--zoomed .art-lightbox__nav {
    opacity: 0.25;
    pointer-events: none;
  }

  .art-lightbox__nav--prev {
    left: var(--space-3);
  }

  .art-lightbox__nav--next {
    right: var(--space-3);
    left: auto;
  }

  @media (max-width: 767px) {
    .art-lightbox__zoom-stage {
      width: 100vw;
      height: 82dvh;
    }

    .art-lightbox__close {
      top: calc(env(safe-area-inset-top, 0px) + var(--space-2));
      right: var(--space-2);
    }

    .art-lightbox__nav {
      width: 40px;
      height: 40px;
    }

    .art-lightbox__nav--prev {
      left: var(--space-1);
    }

    .art-lightbox__nav--next {
      right: var(--space-1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .art-lightbox,
    .art-lightbox__backdrop,
    .art-lightbox__stage-wrap {
      transition: none;
    }
  }
</style>
