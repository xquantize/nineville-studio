---
import { works, formatWorkMeta, formatLightboxMeta } from '../data/works';

const worksForLightbox = works.map((work) => ({
  id: work.id,
  title: work.title,
  description: work.detailDescription ?? work.description,
  meta: formatWorkMeta(work),
  details: formatLightboxMeta(work),
  status: work.status ?? null,
  images: work.images,
}));
---

<div
  id="art-lightbox"
  class="art-lightbox"
  role="dialog"
  aria-modal="true"
  aria-labelledby="art-lightbox-title"
  aria-describedby="art-lightbox-desc"
  hidden
>
  <div class="art-lightbox__backdrop" data-lightbox-close tabindex="-1"></div>

  <div class="art-lightbox__panel">
    <button type="button" class="art-lightbox__close" data-lightbox-close aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
        <line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
        <line x1="19" y1="5" x2="5" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
      </svg>
    </button>

    <div class="art-lightbox__layout">
      <div class="art-lightbox__image-wrap">
        <button type="button" class="art-lightbox__nav art-lightbox__nav--prev" data-lightbox-prev aria-label="Previous photo" hidden>
          <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14 6 L8 12 L14 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>

        <button type="button" class="art-lightbox__nav art-lightbox__nav--next" data-lightbox-next aria-label="Next photo" hidden>
          <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M10 6 L16 12 L10 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>

        <img class="art-lightbox__image" src="" alt="" width="1200" height="1500" decoding="async" />
        <p class="art-lightbox__caption" hidden></p>
      </div>

      <div class="art-lightbox__details">
        <p class="art-lightbox__counter" aria-live="polite"></p>
        <h3 id="art-lightbox-title" class="art-lightbox__title"></h3>
        <p id="art-lightbox-desc" class="art-lightbox__desc"></p>
        <p class="art-lightbox__meta"></p>
        <p class="art-lightbox__status" hidden></p>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ worksForLightbox }}>
  const lightbox = document.getElementById('art-lightbox');
  const imageEl = lightbox?.querySelector('.art-lightbox__image');
  const captionEl = lightbox?.querySelector('.art-lightbox__caption');
  const titleEl = lightbox?.querySelector('.art-lightbox__title');
  const descEl = lightbox?.querySelector('.art-lightbox__desc');
  const metaEl = lightbox?.querySelector('.art-lightbox__meta');
  const statusEl = lightbox?.querySelector('.art-lightbox__status');
  const counterEl = lightbox?.querySelector('.art-lightbox__counter');
  const prevBtn = lightbox?.querySelector('[data-lightbox-prev]');
  const nextBtn = lightbox?.querySelector('[data-lightbox-next]');
  const closeTargets = lightbox?.querySelectorAll('[data-lightbox-close]');
  const focusableSelector =
    'button:not([hidden]), [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';

  const statusLabels = {
    available: 'Available',
    sold: 'Sold',
    'private collection': 'Private collection',
  };

  let workIndex = 0;
  let imageIndex = 0;
  let lastTrigger = null;

  function currentWork() {
    return worksForLightbox[workIndex];
  }

  function setLenisPaused(paused) {
    const lenis = window.__lenis;
    if (!lenis) return;
    if (paused) lenis.stop();
    else lenis.start();
  }

  function renderImage() {
    const work = currentWork();
    const photo = work?.images[imageIndex];
    if (!work || !photo || !imageEl || !titleEl || !descEl || !metaEl || !counterEl) return;

    imageEl.src = photo.src;
    imageEl.alt = photo.alt;
    titleEl.textContent = work.title;
    descEl.textContent = work.description;
    metaEl.textContent = work.details;

    if (statusEl) {
      if (work.status && statusLabels[work.status]) {
        statusEl.textContent = statusLabels[work.status];
        statusEl.dataset.status = work.status;
        statusEl.hidden = false;
      } else {
        statusEl.textContent = '';
        statusEl.removeAttribute('data-status');
        statusEl.hidden = true;
      }
    }

    const hasMultiple = work.images.length > 1;
    if (prevBtn) prevBtn.hidden = !hasMultiple;
    if (nextBtn) nextBtn.hidden = !hasMultiple;

    if (hasMultiple) {
      counterEl.textContent = `Photo ${imageIndex + 1} of ${work.images.length}`;
      counterEl.hidden = false;
    } else {
      counterEl.textContent = '';
      counterEl.hidden = true;
    }

    if (captionEl) {
      if (photo.caption) {
        captionEl.textContent = photo.caption;
        captionEl.hidden = false;
      } else {
        captionEl.textContent = '';
        captionEl.hidden = true;
      }
    }
  }

  function trapFocus(event) {
    if (!lightbox || lightbox.hidden || event.key !== 'Tab') return;

    const focusable = Array.from(lightbox.querySelectorAll(focusableSelector)).filter(
      (el) => !el.hasAttribute('disabled')
    );
    if (!focusable.length) return;

    const first = focusable[0];
    const last = focusable[focusable.length - 1];

    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  }

  function open(index, trigger) {
    if (!lightbox || !worksForLightbox.length) return;

    if (lightbox.parentElement !== document.body) {
      document.body.appendChild(lightbox);
    }

    workIndex = index;
    imageIndex = 0;
    lastTrigger = trigger ?? null;
    renderImage();
    lightbox.hidden = false;
    setLenisPaused(true);
    document.body.style.overflow = 'hidden';
    lightbox.querySelector('.art-lightbox__close')?.focus();
    document.addEventListener('keydown', onKeydown);
    document.addEventListener('keydown', trapFocus);
  }

  function close() {
    if (!lightbox || lightbox.hidden) return;

    lightbox.hidden = true;
    setLenisPaused(false);
    document.body.style.overflow = '';
    document.removeEventListener('keydown', onKeydown);
    document.removeEventListener('keydown', trapFocus);

    if (lastTrigger instanceof HTMLElement) {
      lastTrigger.focus();
    }
  }

  function showRelative(delta) {
    const work = currentWork();
    if (!work || work.images.length <= 1) return;

    imageIndex = (imageIndex + delta + work.images.length) % work.images.length;
    renderImage();
  }

  function onKeydown(event) {
    if (!lightbox || lightbox.hidden) return;

    if (event.key === 'Escape') {
      event.preventDefault();
      close();
    } else if (event.key === 'ArrowLeft') {
      const work = currentWork();
      if (work && work.images.length > 1) {
        event.preventDefault();
        showRelative(-1);
      }
    } else if (event.key === 'ArrowRight') {
      const work = currentWork();
      if (work && work.images.length > 1) {
        event.preventDefault();
        showRelative(1);
      }
    }
  }

  document.querySelectorAll('[data-work-open]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const index = Number(trigger.getAttribute('data-work-open'));
      if (!Number.isNaN(index)) open(index, trigger);
    });
  });

  prevBtn?.addEventListener('click', () => showRelative(-1));
  nextBtn?.addEventListener('click', () => showRelative(1));
  closeTargets?.forEach((el) => el.addEventListener('click', close));

  if (lightbox && lightbox.parentElement !== document.body) {
    document.body.appendChild(lightbox);
  }
</script>

<style>
  .art-lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    padding: var(--space-2);
    box-sizing: border-box;
    pointer-events: none;
  }

  .art-lightbox:not([hidden]) {
    pointer-events: auto;
  }

  .art-lightbox[hidden] {
    display: none;
  }

  .art-lightbox__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(14, 16, 22, 0.88);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    pointer-events: auto;
  }

  .art-lightbox__panel {
    position: relative;
    z-index: 1;
    width: min(1100px, calc(100vw - var(--space-4)));
    max-height: min(92dvh, 900px);
    margin: auto;
    background: rgba(var(--veil-dark), 0.96);
    border: 1px solid rgba(184, 154, 106, 0.18);
    border-radius: 6px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
    overflow: hidden;
    pointer-events: auto;
    animation: lightbox-in var(--duration-normal) var(--ease-out) both;
  }

  @keyframes lightbox-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .art-lightbox__layout {
    display: flex;
    flex-direction: column;
    max-height: min(92dvh, 900px);
  }

  .art-lightbox__image-wrap {
    flex: 1 1 auto;
    background: rgba(0, 0, 0, 0.25);
    display: grid;
    place-items: center;
    gap: var(--space-2);
    padding: var(--space-4);
    position: relative;
  }

  .art-lightbox__image {
    display: block;
    max-width: 100%;
    max-height: min(50dvh, 560px);
    width: auto;
    height: auto;
    object-fit: contain;
    object-position: center;
    border-radius: 2px;
  }

  .art-lightbox__caption {
    margin: 0;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
  }

  .art-lightbox__caption[hidden] {
    display: none;
  }

  .art-lightbox__details {
    flex-shrink: 0;
    padding: var(--space-3) var(--space-4) var(--space-4);
    border-top: 1px solid rgba(184, 154, 106, 0.12);
    color: var(--text-on-veil);
  }

  .art-lightbox__counter {
    margin: 0 0 var(--space-1);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
  }

  .art-lightbox__counter[hidden] {
    display: none;
  }

  .art-lightbox__title {
    margin: 0 0 var(--space-2);
    font-size: clamp(22px, 3vw, 28px);
    color: var(--sand-50);
  }

  .art-lightbox__desc {
    margin: 0 0 var(--space-2);
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-on-veil);
    max-width: 52ch;
  }

  .art-lightbox__meta {
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
  }

  .art-lightbox__status {
    margin: var(--space-1) 0 0;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sand-500);
  }

  .art-lightbox__status[data-status='sold'],
  .art-lightbox__status[data-status='private collection'] {
    color: var(--text-on-veil-muted);
  }

  .art-lightbox__status[hidden] {
    display: none;
  }

  .art-lightbox__close {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(32, 36, 48, 0.75);
    color: var(--sand-50);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .art-lightbox__close:hover {
    background: rgba(48, 52, 64, 0.9);
  }

  .art-lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(32, 36, 48, 0.75);
    color: var(--sand-50);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .art-lightbox__nav[hidden] {
    display: none;
  }

  .art-lightbox__nav:hover {
    background: rgba(48, 52, 64, 0.9);
  }

  .art-lightbox__nav--prev {
    left: var(--space-2);
  }

  .art-lightbox__nav--next {
    right: var(--space-2);
    left: auto;
  }

  @media (min-width: 768px) {
    .art-lightbox__layout {
      display: grid;
      grid-template-columns: 1fr min(360px, 38%);
      align-items: stretch;
      max-height: min(88dvh, 860px);
    }

    .art-lightbox__image-wrap {
      min-height: min(80dvh, 760px);
      padding: var(--space-6);
      border-right: 1px solid rgba(184, 154, 106, 0.12);
    }

    .art-lightbox__image {
      max-height: min(72dvh, 700px);
    }

    .art-lightbox__details {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: var(--space-6) var(--space-4);
      border-top: none;
      overflow-y: auto;
    }
  }

  @media (max-width: 767px) {
    .art-lightbox {
      padding: 0;
      align-items: stretch;
    }

    .art-lightbox__panel {
      width: 100%;
      height: 100dvh;
      max-height: 100dvh;
      border-radius: 0;
      border-left: none;
      border-right: none;
      display: flex;
      flex-direction: column;
      box-shadow: none;
    }

    .art-lightbox__layout {
      flex: 1;
      min-height: 0;
      max-height: none;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    .art-lightbox__image-wrap {
      min-height: auto;
      padding: calc(env(safe-area-inset-top, 0px) + 52px) var(--space-2) var(--space-2);
    }

    .art-lightbox__image {
      max-height: min(42dvh, 360px);
    }

    .art-lightbox__details {
      padding: var(--space-3) var(--space-3) calc(var(--space-4) + env(safe-area-inset-bottom, 0px));
    }

    .art-lightbox__desc {
      font-size: 14px;
    }

    .art-lightbox__close {
      top: calc(env(safe-area-inset-top, 0px) + var(--space-1));
      right: var(--space-1);
    }

    .art-lightbox__nav {
      width: 40px;
      height: 40px;
    }

    .art-lightbox__nav--prev {
      left: var(--space-1);
    }

    .art-lightbox__nav--next {
      right: var(--space-1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .art-lightbox__panel {
      animation: none;
    }
  }
</style>
