---
---

<div
  id="art-lightbox"
  class="art-lightbox"
  role="dialog"
  aria-modal="true"
  aria-labelledby="art-lightbox-title"
  aria-describedby="art-lightbox-desc"
  hidden
>
  <div class="art-lightbox__backdrop" data-lightbox-close tabindex="-1"></div>

  <div class="art-lightbox__panel">
    <button type="button" class="art-lightbox__close" data-lightbox-close aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
        <line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
        <line x1="19" y1="5" x2="5" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
      </svg>
    </button>

    <div class="art-lightbox__layout">
      <div class="art-lightbox__image-wrap">
        <button type="button" class="art-lightbox__nav art-lightbox__nav--prev" data-lightbox-prev aria-label="Previous photo" hidden>
          <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14 6 L8 12 L14 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>

        <button type="button" class="art-lightbox__nav art-lightbox__nav--next" data-lightbox-next aria-label="Next photo" hidden>
          <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M10 6 L16 12 L10 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>

        <div class="art-lightbox__zoom-stage" data-lightbox-zoom-stage>
          <img class="art-lightbox__image" src="" alt="" width="1200" height="1500" decoding="async" />
        </div>
        <p class="art-lightbox__zoom-hint" data-zoom-hint hidden>Pinch or double-tap to zoom</p>
        <p class="art-lightbox__caption" hidden></p>
      </div>

      <div class="art-lightbox__details">
        <p class="art-lightbox__counter" aria-live="polite"></p>
        <h3 id="art-lightbox-title" class="art-lightbox__title"></h3>
        <p id="art-lightbox-desc" class="art-lightbox__desc"></p>
        <p class="art-lightbox__meta"></p>
        <p class="art-lightbox__status" hidden></p>
        <a class="art-lightbox__enquire" data-lightbox-enquire hidden>Enquire about this piece</a>
      </div>
    </div>
  </div>
</div>

<script>
  import '../scripts/art-lightbox.ts';
</script>

<style is:global>
  .medium-zoom-overlay {
    z-index: 10000;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .medium-zoom-image {
    z-index: 10001;
  }
</style>

<style>
  .art-lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    padding: var(--space-2);
    box-sizing: border-box;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.4s var(--ease-gentle),
      visibility 0.4s var(--ease-gentle);
  }

  .art-lightbox.is-open {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
  }

  .art-lightbox.is-closing {
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
  }

  .art-lightbox[hidden] {
    display: none;
  }

  .art-lightbox__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(14, 16, 22, 0.88);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    pointer-events: auto;
    opacity: 0;
    transition: opacity 0.45s var(--ease-gentle);
  }

  .art-lightbox.is-open .art-lightbox__backdrop {
    opacity: 1;
  }

  .art-lightbox__panel {
    position: relative;
    z-index: 1;
    width: min(1100px, calc(100vw - var(--space-4)));
    max-height: min(92dvh, 900px);
    margin: auto;
    background: rgba(var(--veil-dark), 0.96);
    border: 1px solid rgba(184, 154, 106, 0.18);
    border-radius: 6px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
    overflow: hidden;
    pointer-events: auto;
    opacity: 0;
    transform: translateY(12px) scale(0.985);
    transition:
      opacity 0.45s var(--ease-gentle),
      transform 0.55s var(--ease-gentle);
  }

  .art-lightbox.is-open .art-lightbox__panel {
    opacity: 1;
    transform: none;
  }

  .art-lightbox.is-closing .art-lightbox__panel {
    opacity: 0;
    transform: translateY(8px) scale(0.99);
  }

  .art-lightbox__layout {
    display: flex;
    flex-direction: column;
    max-height: min(92dvh, 900px);
  }

  .art-lightbox__image-wrap {
    flex: 1 1 auto;
    background: rgba(0, 0, 0, 0.25);
    display: grid;
    place-items: center;
    gap: var(--space-1);
    padding: var(--space-4);
    position: relative;
  }

  .art-lightbox__zoom-stage {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 100%;
    max-height: min(50dvh, 560px);
    overflow: hidden;
  }

  .art-lightbox--touch .art-lightbox__zoom-stage {
    touch-action: none;
  }

  .art-lightbox--desktop .art-lightbox__image {
    cursor: zoom-in;
  }

  .art-lightbox--zoomed .art-lightbox__nav {
    opacity: 0.25;
    pointer-events: none;
  }

  .art-lightbox__zoom-hint {
    margin: 0;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
    opacity: 0.8;
  }

  .art-lightbox__zoom-hint[hidden] {
    display: none;
  }

  .art-lightbox__image {
    display: block;
    max-width: 100%;
    max-height: min(50dvh, 560px);
    width: auto;
    height: auto;
    object-fit: contain;
    object-position: center;
    border-radius: 2px;
    opacity: 1;
    transition: opacity 0.35s var(--ease-gentle);
  }

  .art-lightbox__image.is-changing {
    opacity: 0.35;
  }

  .art-lightbox__caption {
    margin: 0;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
  }

  .art-lightbox__caption[hidden] {
    display: none;
  }

  .art-lightbox__details {
    flex-shrink: 0;
    padding: var(--space-3) var(--space-4) var(--space-4);
    border-top: 1px solid rgba(184, 154, 106, 0.12);
    color: var(--text-on-veil);
  }

  .art-lightbox__counter {
    margin: 0 0 var(--space-1);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
  }

  .art-lightbox__counter[hidden] {
    display: none;
  }

  .art-lightbox__title {
    margin: 0 0 var(--space-2);
    font-size: clamp(22px, 3vw, 28px);
    color: var(--sand-50);
  }

  .art-lightbox__desc {
    margin: 0 0 var(--space-2);
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-on-veil);
    max-width: 52ch;
  }

  .art-lightbox__meta {
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
  }

  .art-lightbox__status {
    margin: var(--space-1) 0 0;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sand-500);
  }

  .art-lightbox__status[data-status='sold'],
  .art-lightbox__status[data-status='private collection'] {
    color: var(--text-on-veil-muted);
  }

  .art-lightbox__status[hidden] {
    display: none;
  }

  .art-lightbox__enquire {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--space-3);
    padding: 12px 22px;
    min-height: 44px;
    border-radius: 100px;
    background: var(--sand-50);
    color: var(--sand-900);
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      background var(--duration-gentle) var(--ease-gentle),
      box-shadow var(--duration-gentle) var(--ease-gentle);
  }

  .art-lightbox__enquire:hover {
    background: var(--sand-200);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .art-lightbox__enquire[hidden] {
    display: none;
  }

  .art-lightbox__close {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(32, 36, 48, 0.75);
    color: var(--sand-50);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .art-lightbox__close:hover {
    background: rgba(48, 52, 64, 0.9);
  }

  .art-lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(32, 36, 48, 0.75);
    color: var(--sand-50);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .art-lightbox__nav[hidden] {
    display: none;
  }

  .art-lightbox__nav:hover {
    background: rgba(48, 52, 64, 0.9);
  }

  .art-lightbox__nav--prev {
    left: var(--space-2);
  }

  .art-lightbox__nav--next {
    right: var(--space-2);
    left: auto;
  }

  @media (min-width: 768px) {
    .art-lightbox__layout {
      display: grid;
      grid-template-columns: 1fr min(360px, 38%);
      align-items: stretch;
      max-height: min(88dvh, 860px);
    }

    .art-lightbox__image-wrap {
      min-height: min(80dvh, 760px);
      padding: var(--space-6);
      border-right: 1px solid rgba(184, 154, 106, 0.12);
    }

    .art-lightbox__zoom-stage {
      max-height: min(72dvh, 700px);
    }

    .art-lightbox__image {
      max-height: min(72dvh, 700px);
    }

    .art-lightbox__details {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: var(--space-6) var(--space-4);
      border-top: none;
      overflow-y: auto;
    }
  }

  @media (max-width: 767px) {
    .art-lightbox {
      padding: 0;
      align-items: stretch;
    }

    .art-lightbox__panel {
      width: 100%;
      height: 100dvh;
      max-height: 100dvh;
      border-radius: 0;
      border-left: none;
      border-right: none;
      display: flex;
      flex-direction: column;
      box-shadow: none;
    }

    .art-lightbox__layout {
      flex: 1;
      min-height: 0;
      max-height: none;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    .art-lightbox__image-wrap {
      min-height: auto;
      padding: calc(env(safe-area-inset-top, 0px) + 52px) var(--space-2) var(--space-2);
    }

    .art-lightbox__zoom-stage {
      max-height: min(42dvh, 360px);
    }

    .art-lightbox__image {
      max-height: min(42dvh, 360px);
    }

    .art-lightbox__details {
      padding: var(--space-3) var(--space-3) calc(var(--space-4) + env(safe-area-inset-bottom, 0px));
    }

    .art-lightbox__desc {
      font-size: 14px;
    }

    .art-lightbox__close {
      top: calc(env(safe-area-inset-top, 0px) + var(--space-1));
      right: var(--space-1);
    }

    .art-lightbox__nav {
      width: 40px;
      height: 40px;
    }

    .art-lightbox__nav--prev {
      left: var(--space-1);
    }

    .art-lightbox__nav--next {
      right: var(--space-1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .art-lightbox,
    .art-lightbox__backdrop,
    .art-lightbox__panel,
    .art-lightbox__image {
      transition: none;
    }
  }
</style>
