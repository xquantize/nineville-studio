<script>
  import Lenis from 'lenis';

  const img = document.querySelector('.scroll-bg__img') as HTMLImageElement | null;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  // Touch / coarse / narrow: never run Lenis — it fights native fling.
  const useNativeScroll =
    reducedMotion ||
    !finePointer ||
    window.matchMedia('(hover: none)').matches ||
    window.matchMedia('(pointer: coarse)').matches ||
    window.matchMedia('(max-width: 767px)').matches;

  const panBackground = !useNativeScroll;
  const BASE_SCALE = 1.016;

  let panMetrics = { maxPan: 0, docH: 0 };
  let targetPan = 0;
  let currentPan = 0;
  let motionRafId = 0;

  function updatePanMetrics() {
    if (!img?.complete) return;

    const viewH = window.innerHeight;
    const imgH = img.getBoundingClientRect().height;
    panMetrics.maxPan = Math.max(0, imgH - viewH);
    panMetrics.docH = Math.max(0, document.documentElement.scrollHeight - viewH);
  }

  function panOffset(scrollY: number) {
    if (!img?.complete || panMetrics.docH <= 0) return 0;
    return (scrollY / panMetrics.docH) * panMetrics.maxPan;
  }

  function applyBackgroundTransform() {
    if (!img) return;
    img.style.transform = `translate3d(0, ${(-currentPan).toFixed(2)}px, 0) scale(${BASE_SCALE})`;
  }

  function motionFrame() {
    const panDelta = targetPan - currentPan;
    if (Math.abs(panDelta) >= 0.05) {
      currentPan += panDelta * 0.11;
      applyBackgroundTransform();
      motionRafId = requestAnimationFrame(motionFrame);
      return;
    }

    currentPan = targetPan;
    applyBackgroundTransform();
    motionRafId = 0;
  }

  function startMotionLoop() {
    if (motionRafId) return;
    motionRafId = requestAnimationFrame(motionFrame);
  }

  function setTargetPan(scrollY: number) {
    if (!panBackground) return;
    targetPan = panOffset(scrollY);

    if (Math.abs(targetPan - currentPan) >= 0.05) {
      startMotionLoop();
      return;
    }

    currentPan = targetPan;
    applyBackgroundTransform();
  }

  function emitScroll(scrollY: number) {
    window.dispatchEvent(new CustomEvent('app-scroll', { detail: { scroll: scrollY } }));
  }

  function initWithLenis() {
    updatePanMetrics();

    const lenis = new Lenis({
      autoRaf: true,
      anchors: true,
      lerp: 0.095,
      duration: 1.55,
      smoothWheel: true,
      syncTouch: false,
      wheelMultiplier: 0.9,
      touchMultiplier: 1,
      infinite: false,
    });

    window.__lenis = lenis;

    lenis.on('scroll', ({ scroll }) => {
      setTargetPan(scroll);
      emitScroll(scroll);
    });

    window.addEventListener('resize', () => {
      updatePanMetrics();
      setTargetPan(lenis.scroll);
    });

    window.addEventListener('orientationchange', () => {
      window.setTimeout(() => {
        updatePanMetrics();
        setTargetPan(lenis.scroll);
      }, 200);
    });

    setTargetPan(0);
    emitScroll(0);
  }

  function initNative() {
    if (img) img.style.transform = '';

    const onScroll = () => {
      emitScroll(window.scrollY);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  function start() {
    if (useNativeScroll) {
      initNative();
      return;
    }

    initWithLenis();
  }

  start();

  if (img && !img.complete) {
    img.addEventListener(
      'load',
      () => {
        updatePanMetrics();
        setTargetPan(window.__lenis ? window.__lenis.scroll : window.scrollY);
      },
      { once: true }
    );
  }
</script>
