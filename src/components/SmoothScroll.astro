<script>
  import Lenis from 'lenis';

  const img = document.querySelector('.scroll-bg__img') as HTMLImageElement | null;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let panMetrics = { maxPan: 0, docH: 0 };

  function updatePanMetrics() {
    if (!img?.complete) return;

    const viewH = window.innerHeight;
    const imgH = img.getBoundingClientRect().height;
    panMetrics.maxPan = Math.max(0, imgH - viewH);
    panMetrics.docH = Math.max(0, document.documentElement.scrollHeight - viewH);
  }

  function panOffset(scrollY: number) {
    if (!img?.complete || panMetrics.docH <= 0) return 0;
    return (scrollY / panMetrics.docH) * panMetrics.maxPan;
  }

  function applyPan(scrollY: number) {
    if (!img) return;
    img.style.transform = `translate3d(0, ${-panOffset(scrollY)}px, 0)`;
  }

  function emitScroll(scrollY: number) {
    window.dispatchEvent(new CustomEvent('app-scroll', { detail: { scroll: scrollY } }));
  }

  function initWithLenis() {
    updatePanMetrics();

    const lenis = new Lenis({
      autoRaf: true,
      anchors: {
        offset: -56,
      },
      lerp: 0.075,
      duration: 1.35,
      smoothWheel: true,
      syncTouch: window.matchMedia('(pointer: fine)').matches,
      wheelMultiplier: 0.85,
      touchMultiplier: 1,
      infinite: false,
    });

    window.__lenis = lenis;

    lenis.on('scroll', ({ scroll }) => {
      applyPan(scroll);
      emitScroll(scroll);
    });

    window.addEventListener('resize', () => {
      updatePanMetrics();
      applyPan(lenis.scroll);
    });

    window.addEventListener('orientationchange', () => {
      window.setTimeout(() => {
        updatePanMetrics();
        applyPan(lenis.scroll);
      }, 200);
    });

    applyPan(0);
    emitScroll(0);
  }

  function initNative() {
    const onScroll = () => {
      updatePanMetrics();
      const y = window.scrollY;
      applyPan(y);
      emitScroll(y);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    onScroll();
  }

  function start() {
    if (reducedMotion) {
      initNative();
      return;
    }
    initWithLenis();
  }

  if (img?.complete) {
    start();
  } else {
    img?.addEventListener('load', start, { once: true });
  }
</script>
