<script>
  import Lenis from 'lenis';

  const img = document.querySelector('.scroll-bg__img') as HTMLImageElement | null;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  const ambientMotion = !reducedMotion;

  const BASE_SCALE = 1.016;
  const AMBIENT_SCALE = 0.005;
  const MOUSE_X_MAX = 8;
  const MOUSE_Y_MAX = 5;

  let panMetrics = { maxPan: 0, docH: 0 };
  let targetPan = 0;
  let currentPan = 0;
  let motionRafId = 0;
  let motionStart = performance.now();

  let mouseTargetX = 0;
  let mouseTargetY = 0;
  let mouseCurrentX = 0;
  let mouseCurrentY = 0;

  function updatePanMetrics() {
    if (!img?.complete) return;

    const viewH = window.innerHeight;
    const imgH = img.getBoundingClientRect().height;
    panMetrics.maxPan = Math.max(0, imgH - viewH);
    panMetrics.docH = Math.max(0, document.documentElement.scrollHeight - viewH);
  }

  function panOffset(scrollY: number) {
    if (!img?.complete || panMetrics.docH <= 0) return 0;
    return (scrollY / panMetrics.docH) * panMetrics.maxPan;
  }

  function ambientOffset(time: number) {
    const t = (time - motionStart) * 0.001;
    return {
      x: Math.sin(t * 0.11) * 5 + Math.sin(t * 0.063) * 2,
      y: Math.cos(t * 0.095) * 4 + Math.cos(t * 0.051) * 1.5,
      scale: BASE_SCALE + Math.sin(t * 0.082) * AMBIENT_SCALE,
    };
  }

  function applyBackgroundTransform() {
    if (!img) return;

    const ambient = ambientMotion ? ambientOffset(performance.now()) : { x: 0, y: 0, scale: 1 };
    const mouseX = ambientMotion && finePointer ? mouseCurrentX : 0;
    const mouseY = ambientMotion && finePointer ? mouseCurrentY : 0;
    const x = ambient.x + mouseX;
    const y = -currentPan + ambient.y + mouseY;

    img.style.transform = `translate3d(${x.toFixed(2)}px, ${y.toFixed(2)}px, 0) scale(${ambient.scale.toFixed(4)})`;
  }

  function motionFrame() {
    if (ambientMotion && finePointer) {
      mouseCurrentX += (mouseTargetX - mouseCurrentX) * 0.06;
      mouseCurrentY += (mouseTargetY - mouseCurrentY) * 0.06;
    }

    const panDelta = targetPan - currentPan;
    if (Math.abs(panDelta) >= 0.05) {
      currentPan += panDelta * 0.11;
    } else {
      currentPan = targetPan;
    }

    applyBackgroundTransform();
    motionRafId = requestAnimationFrame(motionFrame);
  }

  function startMotionLoop() {
    if (motionRafId) return;
    motionRafId = requestAnimationFrame(motionFrame);
  }

  function stopMotionLoop() {
    if (!motionRafId) return;
    cancelAnimationFrame(motionRafId);
    motionRafId = 0;
  }

  function setTargetPan(scrollY: number) {
    targetPan = panOffset(scrollY);

    if (ambientMotion) {
      startMotionLoop();
      return;
    }

    currentPan = targetPan;
    applyBackgroundTransform();
  }

  function emitScroll(scrollY: number) {
    window.dispatchEvent(new CustomEvent('app-scroll', { detail: { scroll: scrollY } }));
  }

  function bindPointerParallax() {
    if (!ambientMotion || !finePointer) return;

    window.addEventListener(
      'pointermove',
      (event) => {
        const nx = event.clientX / window.innerWidth - 0.5;
        const ny = event.clientY / window.innerHeight - 0.5;
        mouseTargetX = nx * MOUSE_X_MAX * 2;
        mouseTargetY = ny * MOUSE_Y_MAX * 2;
      },
      { passive: true }
    );

    window.addEventListener(
      'pointerleave',
      () => {
        mouseTargetX = 0;
        mouseTargetY = 0;
      },
      { passive: true }
    );
  }

  function bindVisibilityPause() {
    if (!ambientMotion) return;

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stopMotionLoop();
      else startMotionLoop();
    });
  }

  function initWithLenis() {
    updatePanMetrics();

    const lenis = new Lenis({
      autoRaf: true,
      anchors: true,
      lerp: 0.095,
      duration: 1.55,
      smoothWheel: true,
      syncTouch: finePointer,
      wheelMultiplier: 0.9,
      touchMultiplier: 1,
      infinite: false,
    });

    window.__lenis = lenis;

    lenis.on('scroll', ({ scroll }) => {
      setTargetPan(scroll);
      emitScroll(scroll);
    });

    window.addEventListener('resize', () => {
      updatePanMetrics();
      setTargetPan(lenis.scroll);
    });

    window.addEventListener('orientationchange', () => {
      window.setTimeout(() => {
        updatePanMetrics();
        setTargetPan(lenis.scroll);
      }, 200);
    });

    setTargetPan(0);
    emitScroll(0);
  }

  function initNative() {
    const onScroll = () => {
      updatePanMetrics();
      const y = window.scrollY;
      setTargetPan(y);
      emitScroll(y);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    onScroll();
  }

  function start() {
    bindPointerParallax();
    bindVisibilityPause();

    if (reducedMotion) {
      initNative();
      return;
    }

    initWithLenis();
    startMotionLoop();
  }

  if (img?.complete) {
    start();
  } else {
    img?.addEventListener('load', start, { once: true });
  }
</script>
