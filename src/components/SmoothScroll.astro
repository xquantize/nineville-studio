<script>
  import Lenis from 'lenis';

  const img = document.querySelector('.scroll-bg__img') as HTMLImageElement | null;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let panMetrics = { maxPan: 0, docH: 0 };
  let targetPan = 0;
  let currentPan = 0;
  let panRafId = 0;

  function navOffset() {
    const value = getComputedStyle(document.documentElement).getPropertyValue('--nav-height').trim();
    const parsed = Number.parseFloat(value);
    return Number.isFinite(parsed) ? parsed : 56;
  }

  function updatePanMetrics() {
    if (!img?.complete) return;

    const viewH = window.innerHeight;
    const imgH = img.getBoundingClientRect().height;
    panMetrics.maxPan = Math.max(0, imgH - viewH);
    panMetrics.docH = Math.max(0, document.documentElement.scrollHeight - viewH);
  }

  function panOffset(scrollY: number) {
    if (!img?.complete || panMetrics.docH <= 0) return 0;
    return (scrollY / panMetrics.docH) * panMetrics.maxPan;
  }

  function applyPanFrame() {
    if (!img) return;

    const delta = targetPan - currentPan;
    if (Math.abs(delta) < 0.05) {
      currentPan = targetPan;
      img.style.transform = `translate3d(0, ${-currentPan.toFixed(2)}px, 0)`;
      panRafId = 0;
      return;
    }

    currentPan += delta * 0.11;
    img.style.transform = `translate3d(0, ${-currentPan.toFixed(2)}px, 0)`;
    panRafId = requestAnimationFrame(applyPanFrame);
  }

  function setTargetPan(scrollY: number) {
    targetPan = panOffset(scrollY);
    if (!panRafId) {
      panRafId = requestAnimationFrame(applyPanFrame);
    }
  }

  function emitScroll(scrollY: number) {
    window.dispatchEvent(new CustomEvent('app-scroll', { detail: { scroll: scrollY } }));
  }

  function initWithLenis() {
    updatePanMetrics();

    const lenis = new Lenis({
      autoRaf: true,
      anchors: {
        offset: -navOffset(),
      },
      lerp: 0.095,
      duration: 1.55,
      smoothWheel: true,
      syncTouch: window.matchMedia('(pointer: fine)').matches,
      wheelMultiplier: 0.9,
      touchMultiplier: 1,
      infinite: false,
    });

    window.__lenis = lenis;

    lenis.on('scroll', ({ scroll }) => {
      setTargetPan(scroll);
      emitScroll(scroll);
    });

    window.addEventListener('resize', () => {
      updatePanMetrics();
      setTargetPan(lenis.scroll);
    });

    window.addEventListener('orientationchange', () => {
      window.setTimeout(() => {
        updatePanMetrics();
        setTargetPan(lenis.scroll);
      }, 200);
    });

    setTargetPan(0);
    emitScroll(0);
  }

  function initNative() {
    const onScroll = () => {
      updatePanMetrics();
      const y = window.scrollY;
      setTargetPan(y);
      emitScroll(y);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    onScroll();
  }

  function start() {
    if (reducedMotion) {
      initNative();
      return;
    }
    initWithLenis();
  }

  if (img?.complete) {
    start();
  } else {
    img?.addEventListener('load', start, { once: true });
  }
</script>
