---
import { works, formatWorkMeta, getWorkCover } from '../data/works';
import MediaFrame from './MediaFrame.astro';
---

<section id="art" class="panel">
  <div class="panel-inner">
    <p class="section-kicker" data-reveal>Selected works</p>
    <h2 class="section-heading" data-reveal>Art</h2>

    <div class="art__grid">
      {
        works.map((work, index) => {
          const cover = getWorkCover(work);
          return (
            <button
              type="button"
              class="work-card"
              data-reveal-fade
              data-work-open={index}
              aria-label={`View ${work.title}`}
            >
              <div class="work-card__image-wrap">
                <MediaFrame
                  src={cover.src}
                  alt={cover.alt}
                  width={400}
                  height={500}
                />
              </div>
              <div class="work-card__body">
                <h3 class="work-card__title">{work.title}</h3>
                <p class="work-card__desc">{work.description}</p>
                <p class="work-card__meta">{formatWorkMeta(work)}</p>
              </div>
            </button>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .art__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  .work-card {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: none;
    color: inherit;
    font: inherit;
    text-align: left;
    cursor: pointer;
  }

  .work-card:focus-visible {
    outline: 2px solid var(--sand-500);
    outline-offset: 4px;
  }

  .work-card__image-wrap {
    overflow: hidden;
    border-radius: 4px 4px 0 0;
    aspect-ratio: 4 / 5;
  }

  .work-card__image-wrap .media-frame__img {
    transition: transform 1.1s var(--ease-gentle);
  }

  .work-card:hover .work-card__image-wrap .media-frame__img {
    transform: scale(1.015);
  }

  .work-card__body {
    background: var(--card-bg);
    padding: var(--space-2);
    border-radius: 0 0 4px 4px;
  }

  .work-card__title {
    margin: 0 0 0.35rem;
    font-size: 17px;
  }

  .work-card__desc {
    margin: 0 0 0.5rem;
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-on-veil-muted);
  }

  .work-card__meta {
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
  }

  @media (max-width: 767px) {
    .work-card__body {
      padding: var(--space-1) var(--space-1) var(--space-2);
    }

    .work-card__title {
      font-size: 14px;
      line-height: 1.25;
    }

    .work-card__desc {
      display: none;
    }

    .work-card__meta {
      font-size: 10px;
      letter-spacing: 0.08em;
    }

    .work-card:hover .work-card__image-wrap .media-frame__img {
      transform: none;
    }
  }

  @media (min-width: 768px) {
    .art__grid {
      gap: var(--space-4);
    }
  }

  @media (min-width: 1024px) {
    .art__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card__image-wrap .media-frame__img {
      transition: none;
    }

    .work-card:hover .work-card__image-wrap .media-frame__img {
      transform: none;
    }
  }
</style>
