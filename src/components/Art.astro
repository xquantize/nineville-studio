---
import { works, formatWorkMeta, getWorkCover } from '../data/works';
import ArtLightbox from './ArtLightbox.astro';
---

<section id="art" class="panel">
  <div class="panel-inner">
    <p class="section-kicker" data-reveal>Selected works</p>
    <h2 class="section-heading" data-reveal>Art</h2>

    <div class="art__grid">
      {
        works.map((work, index) => {
          const cover = getWorkCover(work);
          return (
            <button
              type="button"
              class="work-card"
              data-reveal
              data-reveal-stagger
              data-work-open={index}
              aria-label={`View ${work.title}`}
            >
              <div class="work-card__image-wrap">
                <img
                  src={cover.src}
                  alt={cover.alt}
                  width="400"
                  height="500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="work-card__body">
                <h3 class="work-card__title">{work.title}</h3>
                <p class="work-card__desc">{work.description}</p>
                <p class="work-card__meta">{formatWorkMeta(work)}</p>
              </div>
            </button>
          );
        })
      }
    </div>
  </div>
</section>

<ArtLightbox />

<style>
  .art__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .work-card {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: none;
    color: inherit;
    font: inherit;
    text-align: left;
    cursor: pointer;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .work-card:hover {
    transform: translateY(-2px);
  }

  .work-card:focus-visible {
    outline: 2px solid var(--sand-500);
    outline-offset: 4px;
  }

  .work-card__image-wrap {
    overflow: hidden;
    border-radius: 4px 4px 0 0;
    aspect-ratio: 4 / 5;
  }

  .work-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-out);
  }

  .work-card:hover .work-card__image-wrap img {
    transform: scale(1.02);
  }

  .work-card__body {
    background: var(--card-bg);
    padding: var(--space-2);
    border-radius: 0 0 4px 4px;
  }

  .work-card__title {
    margin: 0 0 0.35rem;
    font-size: 17px;
  }

  .work-card__desc {
    margin: 0 0 0.5rem;
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-on-veil-muted);
  }

  .work-card__meta {
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-kicker);
  }

  @media (min-width: 640px) {
    .art__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .art__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card:hover {
      transform: none;
    }

    .work-card__image-wrap img {
      transition: none;
    }

    .work-card:hover .work-card__image-wrap img {
      transform: none;
    }
  }
</style>
