---
import { site } from '../data/site';
---

<section class="panel">
  <div class="panel-inner commission">
    <h2 id="commission" class="commission__heading" data-reveal>Commissions</h2>
    <p class="commission__body" data-reveal>
      Commissions are currently open. Get in touch to discuss a piece for your space.
    </p>
    <a class="commission__button" href={`mailto:${site.email}`} data-reveal>
      Email Laura
    </a>
  </div>
</section>

<style>
  .commission {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .commission__heading {
    margin: 0 0 var(--space-3);
    font-size: 32px;
  }

  .commission__body {
    margin: 0 0 var(--space-4);
    font-size: 16px;
    line-height: 1.65;
  }

  .commission__button {
    display: inline-block;
    background: var(--sand-900);
    color: var(--sand-50);
    padding: 14px 32px;
    border-radius: 100px;
    font-family: var(--font-sans);
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      background var(--duration-gentle) var(--ease-gentle),
      box-shadow var(--duration-gentle) var(--ease-gentle);
    min-height: 44px;
    line-height: 1.2;
  }

  .commission__button:hover {
    background: var(--sand-700);
    box-shadow: 0 6px 20px rgba(43, 36, 25, 0.12);
  }

  .commission__button:active {
    box-shadow: none;
    transform: scale(0.98);
  }

  @media (max-width: 767px) {
    .commission__heading {
      font-size: 28px;
    }

    .commission__button {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      max-width: 280px;
      margin: 0 auto;
    }
  }
</style>
