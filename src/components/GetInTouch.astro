---
import { site } from '../data/site';
---

<section id="get-in-touch" class="contact" data-contact-section data-contact-email={site.email}>
  <div class="panel-inner">
    <div class="contact__wrap">
      <header class="contact__intro" data-reveal>
        <p class="section-kicker">Get in touch</p>
        <h2 class="contact__title">Write to <span class="contact__name">Laura</span></h2>
      </header>

      <form class="contact__form" data-contact-form data-reveal novalidate>
        <div class="contact__chooser">
          <div class="contact__topics" role="tablist" aria-label="Inquiry type">
            <button
              type="button"
              class="contact__topic is-active"
              role="tab"
              aria-selected="true"
              data-contact-trigger
              data-contact-topic="general"
              data-contact-subject="General inquiry"
              data-contact-message="What’s on your mind..."
            >
              General
            </button>
            <button
              type="button"
              class="contact__topic"
              role="tab"
              aria-selected="false"
              data-contact-trigger
              data-contact-topic="artwork"
              data-contact-subject="Artwork inquiry"
              data-contact-message="Ask about availability, sizing, or anything you’d like to know..."
            >
              Artwork
            </button>
            <button
              type="button"
              class="contact__topic"
              role="tab"
              aria-selected="false"
              data-contact-trigger
              data-contact-topic="commissions"
              data-contact-subject="Commission inquiry"
              data-contact-message="Share your vision — subject, mood, colours, space it’s for..."
            >
              Commissions
            </button>
            <button
              type="button"
              class="contact__topic"
              role="tab"
              aria-selected="false"
              data-contact-trigger
              data-contact-topic="workshops"
              data-contact-subject="Private Sip & Paint inquiry"
              data-contact-workshop="private"
              data-contact-message="Any further details you’d like to share — theme, colour palette, ideas, vibe..."
            >
              Workshops
            </button>
          </div>

          <p class="contact__topic-hint" data-contact-topic-hint>
            Say hello, ask a question, or share whatever’s on your mind.
          </p>
        </div>

        <input type="hidden" name="topic" value="general" data-contact-topic />
        <input type="hidden" name="subject" value="General inquiry" data-contact-subject />

        <div class="contact__row">
          <label class="contact__field">
            <span>Name <abbr class="contact__req" title="Required">*</abbr></span>
            <input class="contact__input" name="name" autocomplete="name" required />
          </label>
          <label class="contact__field">
            <span>Email <abbr class="contact__req" title="Required">*</abbr></span>
            <input class="contact__input" type="email" name="email" autocomplete="email" required />
          </label>
        </div>

        <label class="contact__field" data-contact-artwork-field hidden>
          <span>Artwork</span>
          <input
            class="contact__input"
            name="artwork"
            placeholder="Which piece?"
            data-contact-artwork
          />
        </label>

        <label class="contact__field" data-contact-size-field hidden>
          <span>Approx size</span>
          <input
            class="contact__input"
            name="size"
            placeholder="e.g. 120 × 90 cm"
            data-contact-size
          />
        </label>

        <input type="hidden" name="workshop" value="" data-contact-workshop />

        <div class="contact__workshop-extra" data-contact-workshop-details hidden>
          <div class="contact__row">
            <label class="contact__field">
              <span>Number of guests</span>
              <input
                class="contact__input"
                name="guests"
                type="number"
                min="1"
                inputmode="numeric"
                placeholder="e.g. 10"
              />
            </label>
            <label class="contact__field">
              <span>Preferred date</span>
              <input class="contact__input contact__input--date" name="date" type="date" />
            </label>
          </div>

          <label class="contact__field">
            <span>Location <abbr class="contact__req" title="Required">*</abbr></span>
            <input
              class="contact__input"
              name="location"
              placeholder="Where should we host it?"
              data-contact-location
            />
          </label>

          <label class="contact__field">
            <span>Occasion</span>
            <input
              class="contact__input"
              name="occasion"
              placeholder="e.g. birthday, hen party, team day"
            />
          </label>
        </div>

        <label class="contact__field">
          <span data-contact-message-label>
            <span data-contact-message-label-text>Message</span>{' '}
            <abbr class="contact__req" title="Required">*</abbr>
          </span>
          <textarea
            class="contact__input contact__textarea"
            name="message"
            rows="4"
            data-contact-message
            placeholder="What’s on your mind..."
            required
          ></textarea>
        </label>

        <button class="contact__submit" type="submit">Send &rarr;</button>
      </form>
    </div>
  </div>
</section>

<script>
  const section = document.querySelector<HTMLElement>('[data-contact-section]');
  if (section) {
    const email = section.dataset.contactEmail ?? '';
    const form = section.querySelector<HTMLFormElement>('[data-contact-form]');
    const topicEl = section.querySelector<HTMLInputElement>('input[data-contact-topic]');
    const subjectEl = section.querySelector<HTMLInputElement>('input[data-contact-subject]');
    const messageEl = section.querySelector<HTMLTextAreaElement>('textarea[data-contact-message]');
    const artworkEl = section.querySelector<HTMLInputElement>('input[data-contact-artwork]');
    const artworkField = section.querySelector<HTMLElement>('[data-contact-artwork-field]');
    const sizeEl = section.querySelector<HTMLInputElement>('input[data-contact-size]');
    const sizeField = section.querySelector<HTMLElement>('[data-contact-size-field]');
    const workshopEl = section.querySelector<HTMLInputElement>('input[data-contact-workshop]');
    const workshopDetails = section.querySelector<HTMLElement>('[data-contact-workshop-details]');
    const locationEl = section.querySelector<HTMLInputElement>('input[data-contact-location]');
    const messageLabel = section.querySelector<HTMLElement>('[data-contact-message-label-text]');
    const topicHint = section.querySelector<HTMLElement>('[data-contact-topic-hint]');
    const topicBtns = Array.from(section.querySelectorAll<HTMLElement>('.contact__topic'));
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let hasTriedSubmit = false;

    const defaults = {
      general: {
        subject: 'General inquiry',
        message: 'What’s on your mind...',
        messageLabel: 'Message',
        hint: 'Say hello, ask a question, or share whatever’s on your mind.',
      },
      artwork: {
        subject: 'Artwork inquiry',
        message: 'Ask about availability, sizing, or anything you’d like to know...',
        messageLabel: 'Message',
        hint: 'Ask about a piece — availability, sizing, or anything you’d like to know.',
      },
      commissions: {
        subject: 'Commission inquiry',
        message: 'Share your vision — subject, mood, colours, space it’s for...',
        messageLabel: 'Your vision',
        hint: 'Tell Laura about a custom artwork you’d love made.',
      },
      workshops: {
        subject: 'Private Sip & Paint inquiry',
        message:
          'Any further details you’d like to share — theme, colour palette, ideas, vibe...',
        messageLabel: 'Event details',
        hint: 'Book a private Sip & Paint — guests, date, location, and vibe.',
      },
    } as const;

    type Topic = keyof typeof defaults;

    function isTopic(value: string | undefined): value is Topic {
      return Boolean(value && value in defaults);
    }

    function setWorkshopMode(on: boolean) {
      if (workshopDetails) workshopDetails.hidden = !on;
      if (workshopEl) workshopEl.value = on ? 'private' : '';
      if (locationEl) {
        locationEl.required = on;
        if (!on) {
          locationEl.value = '';
          clearFieldError(locationEl);
        }
      }
    }

    function setMessageLabel(topic: Topic) {
      if (messageLabel) messageLabel.textContent = defaults[topic].messageLabel;
    }

    function setTopicHint(topic: Topic) {
      if (!topicHint) return;
      const next = defaults[topic].hint;
      if (topicHint.textContent === next) return;
      topicHint.textContent = next;
      if (reduceMotion) return;
      topicHint.classList.remove('is-swap');
      void topicHint.offsetWidth;
      topicHint.classList.add('is-swap');
    }

    function showContextFields(topic: Topic) {
      if (artworkField) {
        artworkField.hidden = topic !== 'artwork';
        if (topic !== 'artwork' && artworkEl) artworkEl.value = '';
      }
      if (sizeField) {
        sizeField.hidden = topic !== 'commissions';
        if (topic !== 'commissions' && sizeEl) sizeEl.value = '';
      }

      const isWorkshop = topic === 'workshops';
      setWorkshopMode(isWorkshop);
      setMessageLabel(topic);
      setTopicHint(topic);

      if (!isWorkshop && workshopDetails) {
        workshopDetails.querySelectorAll<HTMLInputElement>('input').forEach((input) => {
          if (input !== workshopEl) input.value = '';
        });
      }
    }

    function applyIntent(trigger: HTMLElement, shouldScroll: boolean) {
      const topic = isTopic(trigger.dataset.contactTopic) ? trigger.dataset.contactTopic : 'general';
      const fallback = defaults[topic];
      const artwork = (trigger.dataset.contactArtwork || '').trim();

      let subject = trigger.dataset.contactSubject || fallback.subject;
      let message = trigger.dataset.contactMessage || fallback.message;

      if (artwork) {
        subject = trigger.dataset.contactSubject || `Artwork inquiry: ${artwork}`;
        message =
          trigger.dataset.contactMessage ||
          `Anything you’d like to know about “${artwork}”...`;
      }

      if (topicEl) topicEl.value = topic;
      if (subjectEl) subjectEl.value = subject;
      if (messageEl) {
        messageEl.value = '';
        messageEl.placeholder = message;
      }

      showContextFields(topic);

      if (topic === 'artwork' && artworkEl) {
        artworkEl.value = artwork;
      }

      topicBtns.forEach((btn) => {
        const on = btn.dataset.contactTopic === topic;
        btn.classList.toggle('is-active', on);
        btn.setAttribute('aria-selected', String(on));
      });

      if (shouldScroll) {
        // Let overlay unlock / Lenis restart settle before scrolling.
        requestAnimationFrame(() => {
          requestAnimationFrame(() => scrollContactIntoView());
        });
      }
    }

    function scrollContactIntoView() {
      const wrap = section.querySelector<HTMLElement>('.contact__wrap') ?? section;
      const nav = document.querySelector<HTMLElement>('.nav');
      const navBottom = Math.ceil(nav?.getBoundingClientRect().bottom ?? 56);
      const height = wrap.getBoundingClientRect().height;
      const free = window.innerHeight - navBottom - height;

      // Keep the panel optically balanced: a bit less air above than below
      // (equal math still read top-heavy once the nav is in view).
      const topPad = free > 0 ? Math.max(10, free * 0.28) : 10;
      const offset = -(navBottom + topPad);

      const lenis = window.__lenis;
      if (lenis) {
        lenis.scrollTo(wrap, {
          offset,
          immediate: reduceMotion,
          duration: reduceMotion ? 0 : 1.15,
        });
        return;
      }

      const scrollY = window.scrollY;
      const absoluteTop = wrap.getBoundingClientRect().top + scrollY;
      window.scrollTo({
        top: Math.max(0, absoluteTop + offset),
        behavior: reduceMotion ? 'auto' : 'smooth',
      });
    }

    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      const trigger = target?.closest<HTMLElement>('[data-contact-trigger]');
      if (!trigger) return;
      event.preventDefault();
      applyIntent(trigger, !section.contains(trigger));
    });

    function clearFieldError(field: HTMLInputElement | HTMLTextAreaElement) {
      field.classList.remove('is-invalid');
      field.removeAttribute('aria-invalid');
    }

    function markFieldError(field: HTMLInputElement | HTMLTextAreaElement) {
      field.classList.add('is-invalid');
      field.setAttribute('aria-invalid', 'true');
    }

    function isFieldFilled(field: HTMLInputElement | HTMLTextAreaElement) {
      const value = field.value.trim();
      if (!value) return false;
      if (field.type === 'email') {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
      }
      return true;
    }

    function getActiveRequired() {
      return Array.from(
        form?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
          'input[required], textarea[required]'
        ) ?? []
      ).filter((field) => field.offsetParent !== null || field === document.activeElement);
    }

    form?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach((field) => {
      field.addEventListener('input', () => {
        if (!hasTriedSubmit) return;
        if (isFieldFilled(field)) clearFieldError(field);
      });
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!email || !form) return;

      hasTriedSubmit = true;

      let firstInvalid: HTMLInputElement | HTMLTextAreaElement | null = null;
      getActiveRequired().forEach((field) => {
        if (!isFieldFilled(field)) {
          markFieldError(field);
          if (!firstInvalid) firstInvalid = field;
        } else {
          clearFieldError(field);
        }
      });

      if (firstInvalid) {
        firstInvalid.focus({ preventScroll: true });
        firstInvalid.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'center' });
        return;
      }

      const data = new FormData(form);
      const name = String(data.get('name') ?? '').trim();
      const replyTo = String(data.get('email') ?? '').trim();
      const topic = String(data.get('topic') ?? 'general').trim();
      const artwork = String(data.get('artwork') ?? '').trim();
      const size = String(data.get('size') ?? '').trim();
      const workshop = String(data.get('workshop') ?? '').trim();
      const guests = String(data.get('guests') ?? '').trim();
      const date = String(data.get('date') ?? '').trim();
      const location = String(data.get('location') ?? '').trim();
      const occasion = String(data.get('occasion') ?? '').trim();
      let subject = String(data.get('subject') ?? defaults.general.subject).trim();
      const message = String(data.get('message') ?? '').trim();

      if (artwork && !subject.includes(artwork)) {
        subject = `Artwork inquiry: ${artwork}`;
      }
      if (workshop === 'private') subject = subject || 'Private Sip & Paint inquiry';

      const body = [
        name ? `Name: ${name}` : '',
        replyTo ? `Email: ${replyTo}` : '',
        topic ? `Inquiry type: ${topic}` : '',
        artwork ? `Artwork: ${artwork}` : '',
        size ? `Approx size: ${size}` : '',
        workshop === 'private' ? 'Workshop: Private session' : '',
        guests ? `Number of guests: ${guests}` : '',
        date ? `Preferred date: ${date}` : '',
        location ? `Location: ${location}` : '',
        occasion ? `Occasion: ${occasion}` : '',
        '',
        message,
      ]
        .filter((line, index, arr) => line || (index > 0 && arr[index - 1]))
        .join('\n');

      window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  }
</script>

<style>
  .contact {
    padding: clamp(2.5rem, 5vw, 4rem) 0 max(clamp(5rem, 18vh, 10rem), 36vh);
    scroll-margin-top: calc(var(--scroll-anchor-offset) + var(--space-3));
  }

  .contact__wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: clamp(1.15rem, 2.8vw, 1.85rem) clamp(1.15rem, 3vw, 2rem);
    border: none;
    border-radius: 0;
    background: transparent;
  }

  .contact__intro {
    margin-bottom: clamp(1.1rem, 2.2vw, 1.5rem);
  }

  .contact__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(36px, 6vw, 56px);
    line-height: 0.92;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--sand-50);
  }

  .contact__name {
    color: #ff7f89;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }

  .contact__chooser {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact__topics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.45rem;
    padding: 0.2rem 0;
    border: none;
    border-radius: 0;
    background: transparent;
  }

  .contact__topic-hint {
    margin: 0;
    padding: 0.15rem 0.15rem 0 0.85rem;
    border-left: 2px solid rgba(255, 127, 137, 0.7);
    color: rgba(232, 226, 212, 0.72);
    font-size: 13.5px;
    line-height: 1.45;
    letter-spacing: 0.01em;
    transition: opacity 0.22s var(--ease-out), transform 0.22s var(--ease-out);
  }

  .contact__topic-hint.is-swap {
    animation: contact-hint-in 0.28s var(--ease-out);
  }

  @keyframes contact-hint-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__topic-hint.is-swap {
      animation: none;
    }
  }

  .contact__topic {
    margin: 0;
    min-height: 42px;
    padding: 0.55rem 0.65rem;
    border: none;
    border-radius: 7px;
    background: transparent;
    color: var(--text-on-veil-muted);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    cursor: pointer;
    position: relative;
    transition:
      color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  .contact__topic::after {
    content: '';
    position: absolute;
    left: 0.65rem;
    right: 0.65rem;
    bottom: 0.35rem;
    height: 1.5px;
    background: transparent;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .contact__topic:hover {
    color: var(--sand-50);
  }

  .contact__topic.is-active {
    color: var(--sand-50);
    background: rgba(255, 127, 137, 0.1);
  }

  .contact__topic.is-active::after {
    background: #ff7f89;
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.15rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-on-veil-muted);
  }

  .contact__req {
    margin-left: 0.15em;
    color: #ff7f89;
    text-decoration: none;
    font-weight: 500;
  }

  .contact__field[hidden] {
    display: none;
  }

  .contact__input {
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    padding: 0.72rem 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-on-veil);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.45;
    outline: none;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .contact__input::placeholder {
    color: rgba(232, 226, 212, 0.38);
  }

  .contact__input:hover {
    border-color: rgba(255, 255, 255, 0.25);
  }

  .contact__input:focus {
    border-color: rgba(255, 127, 137, 0.7);
    background: rgba(255, 255, 255, 0.06);
  }

  .contact__input.is-invalid,
  .contact__input.is-invalid:hover,
  .contact__input.is-invalid:focus {
    border-color: #ff5964;
    background: rgba(255, 89, 100, 0.1);
    box-shadow: 0 0 0 3px rgba(255, 89, 100, 0.4);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 6rem;
  }

  .contact__input--date {
    appearance: none;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .contact__input--date::-webkit-calendar-picker-indicator {
    filter: invert(1);
    opacity: 0.55;
    cursor: pointer;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .contact__input--date:hover::-webkit-calendar-picker-indicator {
    opacity: 0.9;
  }

  .contact__workshop-extra {
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }

  .contact__workshop-extra[hidden] {
    display: none;
  }

  .contact__submit {
    align-self: start;
    margin-top: 0.25rem;
    min-height: 42px;
    padding: 0.7rem 1.2rem;
    border: none;
    border-radius: 999px;
    background: #ff7f89;
    color: #1a1e28;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      transform var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  .contact__submit:hover {
    background: #ff96a0;
  }

  .contact__submit:active {
    transform: scale(0.98);
  }

  @media (min-width: 640px) {
    .contact__topics {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .contact__row {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 767px) {
    .contact {
      padding-top: var(--space-6);
      padding-bottom: var(--space-6);
    }

    .contact__wrap {
      padding: var(--space-4) var(--space-3);
    }
  }
</style>
